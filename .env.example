PORT=3010
APP_URL=http://localhost:3010
APP_TIME_ZONE=Asia/Nicosia
TZ=Asia/Nicosia
CRON_SECRET=replace-with-a-long-random-secret
ADMIN_PASSWORD=replace-with-a-strong-unique-admin-password
# Optional independent signing key. When omitted, the password derives it.
ADMIN_SESSION_SECRET=
ADMIN_SESSION_HOURS=12
# Internal owner placeholder until real multi-user auth exists.
APP_DEFAULT_USER_ID=owner

FIREBASE_PROJECT_ID=
# Compatibility alias accepted by config.js; prefer FIREBASE_PROJECT_ID on the backend.
VITE_FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_ATTEMPTS=3
CLOUDINARY_RETRY_BASE_MS=500
CLOUDINARY_FOLDER=chanter-auto-poster/uploads

AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-2.5-flash
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CAPTION_MODEL=gpt-5.5
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-vl-max
AUTO_CAPTION_REQUEST_TIMEOUT_MS=120000
AUTO_CAPTION_FFMPEG_TIMEOUT_MS=120000
AUTO_CAPTION_MAX_AUDIO_SECONDS=600
AUTO_CAPTION_MAX_TRANSCRIPT_CHARS=12000
# Optional overrides. Bundled FFmpeg and FFprobe are used by default.
FFMPEG_PATH=
FFPROBE_PATH=

# Auto Music uses the local music-library catalog and embeds audio with FFmpeg.
# 0.15 to 0.25 when the source video already has audio.
AUTO_MUSIC_BACKGROUND_VOLUME=0.20
AUTO_MUSIC_FADE_SECONDS=0.8
AUTO_MUSIC_RENDER_TIMEOUT_MS=600000
AUTO_MUSIC_TOKEN_TTL_MINUTES=30
# Optional independent HMAC secret. ADMIN_SESSION_SECRET or ADMIN_PASSWORD is used when omitted.
AUTO_MUSIC_TOKEN_SECRET=

TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:3010/auth/tiktok/callback
TIKTOK_SCOPES=user.info.basic,video.publish
TIKTOK_CONTENT_POST_INIT_URL=https://open.tiktokapis.com/v2/post/publish/content/init/
TIKTOK_PRIVACY_LEVEL=SELF_ONLY
TIKTOK_REQUEST_TIMEOUT_MS=30000
TIKTOK_UPLOAD_TIMEOUT_MS=900000
SCHEDULER_STALE_LOCK_MINUTES=20
SCHEDULER_MAX_CLAIM_ATTEMPTS=3
# Legacy alias accepted by config.js; prefer SCHEDULER_MAX_CLAIM_ATTEMPTS.
SCHEDULER_MAX_ATTEMPTS=
# Set by Render in production. Leave blank locally.
RENDER_INSTANCE_ID=

# Keep Instagram hidden unless this is intentionally enabled.
ENABLE_INSTAGRAM=false
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:3010/auth/instagram/callback
META_GRAPH_VERSION=v24.0
META_AUTH_URL=
META_GRAPH_BASE_URL=https://graph.facebook.com
INSTAGRAM_SCOPES=instagram_basic,instagram_content_publish,pages_show_list,pages_read_engagement
META_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
FACEBOOK_PAGE_ID=
INSTAGRAM_TEST_MODE=true
INSTAGRAM_PUBLISH_ENABLED=false
INSTAGRAM_STATUS_POLL_ATTEMPTS=5
INSTAGRAM_STATUS_POLL_INTERVAL_MS=3000
# Legacy Instagram aliases accepted by config.js; prefer META_* names above.
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_REDIRECT_URI=
INSTAGRAM_GRAPH_VERSION=
INSTAGRAM_ACCESS_TOKEN=

PUBLIC_BASE_URL=https://chanterr.com
