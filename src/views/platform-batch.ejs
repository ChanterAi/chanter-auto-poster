<!DOCTYPE html>
<html lang="el">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="robots" content="noindex">
  <title>Έλεγχος παρτίδας — CHANTER Platform</title>
  <link rel="stylesheet" href="/platform/platform.css">
</head>
<body>
  <div class="shell">
    <header class="platform-header">
      <div class="brand">
        <span class="wordmark">CHANTER</span>
        <span class="product">Platform</span>
      </div>
      <nav class="header-nav">
        <a href="/platform">Πλατφόρμα</a>
        <a href="/platform/autoposter">AutoPoster</a>
      </nav>
    </header>

    <div class="breadcrumb">
      <a href="/platform">Πλατφόρμα</a> / <a href="/platform/autoposter">AutoPoster</a> / Παρτίδα
    </div>
    <h1 class="page-title">Έλεγχος παρτίδας</h1>
    <p class="page-subtitle">
      Ελέγξτε κάθε βίντεο, διορθώστε ό,τι χρειάζεται και εγκρίνετε.
      Οι εγκεκριμένες δημοσιεύσεις προγραμματίζονται με ασφάλεια — ποτέ άμεσα.
      &middot; Review each video, edit freely, then accept. Accepted items are scheduled safely — never immediately.
    </p>

    <div id="notice" class="notice hidden"></div>

    <div class="panel" id="summary-panel">
      <div class="batch-summary" id="batch-summary">
        <span class="stat"><span class="spin"></span> Φόρτωση παρτίδας…</span>
      </div>
      <div class="batch-actions">
        <button id="accept-all-btn" class="btn btn-primary" disabled>Αποδοχή όλων</button>
        <button id="resume-btn" class="btn hidden">Συνέχιση προετοιμασίας</button>
        <button id="refresh-btn" class="btn btn-quiet">Ανανέωση</button>
      </div>
      <div class="danger-zone">
        <button id="delete-batch-btn" class="btn btn-danger">Διαγραφή παρτίδας</button>
      </div>
    </div>

    <h2 class="section-title">Βίντεο παρτίδας</h2>
    <div id="items"></div>

    <p class="footer-note">
      Κάθε στοιχείο παραμένει προσχέδιο μέχρι να το εγκρίνετε. Η ώρα δημοσίευσης μετατίθεται αυτόματα σε ασφαλές
      μελλοντικό σημείο (τουλάχιστον <%= safetyBufferMinutes %> λεπτά μπροστά) αν έχει περάσει.
      &middot; Every item stays a draft until you accept it.
    </p>
  </div>

  <script>
    (function () {
      'use strict';

      var BATCH_ID = <%- JSON.stringify(batchId) %>;
      var API_BASE = '/api/platform/batches/' + encodeURIComponent(BATCH_ID);

      var ITEM_STATES = {
        preparing: ['Προετοιμασία…', 'chip-preparing'],
        ready: ['Έτοιμο', 'chip-ready'],
        needs_attention: ['Χρειάζεται προσοχή', 'chip-attention'],
        accepted: ['Εγκρίθηκε', 'chip-accepted']
      };
      var BATCH_STATES = {
        preparing: ['Προετοιμασία', 'chip-preparing'],
        ready: ['Έτοιμη για έλεγχο', 'chip-ready'],
        attention_required: ['Χρειάζεται προσοχή', 'chip-attention'],
        completed: ['Ολοκληρώθηκε', 'chip-completed'],
        empty: ['Κενή', 'chip-neutral']
      };
      var PROBLEM_LABELS = {
        missing_caption: 'Λείπει λεζάντα — γράψτε μία πριν την αποδοχή.',
        missing_media: 'Λείπει το αρχείο πολυμέσων.',
        missing_schedule: 'Δεν έχει οριστεί ώρα δημοσίευσης.',
        schedule_in_past: 'Η ώρα έχει περάσει — θα μετατεθεί αυτόματα σε ασφαλές σημείο κατά την αποδοχή.',
        missing_youtube_title: 'Λείπει τίτλος YouTube — συμπληρώστε τον πριν την αποδοχή.'
      };
      var PROVIDER_LABELS = { tiktok: 'TikTok', youtube: 'YouTube' };

      var currentView = null;
      var destinations = [];
      var dirtyItems = {};
      var pollTimer = null;

      function destinationKey(provider, accountId) {
        return provider + '|' + accountId;
      }

      function loadDestinations() {
        return fetch('/api/platform/destinations', { headers: { Accept: 'application/json' } })
          .then(function (response) { return response.json(); })
          .then(function (payload) {
            if (payload.ok && Array.isArray(payload.destinations)) destinations = payload.destinations;
          })
          .catch(function () { destinations = []; });
      }

      function chip(map, key) {
        var meta = map[key] || [key, 'chip-neutral'];
        return '<span class="chip ' + meta[1] + '">' + meta[0] + '</span>';
      }

      function showNotice(message, kind) {
        var el = document.getElementById('notice');
        el.textContent = message;
        el.className = 'notice ' + (kind === 'error' ? 'notice-error' : 'notice-ok');
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }

      function formatLocal(iso) {
        if (!iso) return '—';
        return new Date(iso).toLocaleString('el-GR', {
          day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit'
        });
      }

      function isoToLocalInput(iso) {
        if (!iso) return '';
        var date = new Date(iso);
        if (isNaN(date.getTime())) return '';
        var pad = function (value) { return String(value).padStart(2, '0'); };
        return date.getFullYear() + '-' + pad(date.getMonth() + 1) + '-' + pad(date.getDate())
          + 'T' + pad(date.getHours()) + ':' + pad(date.getMinutes());
      }

      function api(path, options) {
        options = options || {};
        options.headers = Object.assign({ 'Accept': 'application/json' }, options.headers || {});
        return fetch(API_BASE + (path || ''), options).then(function (response) {
          return response.json().then(function (payload) { return payload; });
        });
      }

      // ── Grouping (read model only — canonical truth stays the flat item list) ──
      // Destination copies of the same source video share `sourceIndex`. A
      // classic single-destination batch has one member per group, so it
      // renders through the exact same flat item list as before this change.
      function groupItems(items) {
        var byKey = {};
        var groups = [];
        items.forEach(function (item) {
          var key = (item.sourceIndex === null || item.sourceIndex === undefined) ? ('item:' + item.id) : ('src:' + item.sourceIndex);
          if (!byKey[key]) {
            byKey[key] = { key: key, sourceIndex: item.sourceIndex, members: [] };
            groups.push(byKey[key]);
          }
          byKey[key].members.push(item);
        });
        groups.forEach(function (group) {
          group.members.sort(function (a, b) { return (a.batchOrder || 0) - (b.batchOrder || 0); });
        });
        groups.sort(function (a, b) {
          var aIdx = (a.sourceIndex === null || a.sourceIndex === undefined) ? Infinity : a.sourceIndex;
          var bIdx = (b.sourceIndex === null || b.sourceIndex === undefined) ? Infinity : b.sourceIndex;
          if (aIdx !== bIdx) return aIdx - bIdx;
          return (a.members[0].batchOrder || 0) - (b.members[0].batchOrder || 0);
        });
        return groups;
      }

      // ── Rendering ──

      function renderSummary(view) {
        var batch = view.batch;
        var counts = batch.counts || {};
        var summary = document.getElementById('batch-summary');
        var fanOut = Number(batch.destinationCount || 1) > 1;
        summary.innerHTML =
          (fanOut
            ? '<span class="stat">Βίντεο: <strong>' + (batch.videoCount || 0) + '</strong></span>' +
              '<span class="stat">Προορισμοί: <strong>' + (batch.destinationCount || 1) + '</strong></span>'
            : '<span class="stat">Κανάλι: <strong>' + (batch.accountLabel || batch.accountId) + '</strong></span>') +
          '<span class="stat">Εγγραφές: <strong>' + (counts.total || 0) + '</strong></span>' +
          '<span class="stat">Έτοιμα: <strong>' + (counts.ready || 0) + '</strong></span>' +
          '<span class="stat">Σε προετοιμασία: <strong>' + (counts.preparing || 0) + '</strong></span>' +
          '<span class="stat">Προσοχή: <strong>' + (counts.needsAttention || 0) + '</strong></span>' +
          '<span class="stat">Εγκεκριμένα: <strong>' + (counts.accepted || 0) + '</strong></span>' +
          (batch.deletedCount > 0 ? '<span class="stat">Διαγράφηκαν: <strong>' + batch.deletedCount + '</strong></span>' : '') +
          chip(BATCH_STATES, batch.status);

        var acceptable = view.items.filter(function (item) { return item.readyToAccept; }).length;
        var acceptAll = document.getElementById('accept-all-btn');
        acceptAll.disabled = acceptable === 0;
        acceptAll.textContent = acceptable > 0 ? 'Αποδοχή όλων (' + acceptable + ')' : 'Αποδοχή όλων';

        var resume = document.getElementById('resume-btn');
        var hasFailedPrep = view.items.some(function (item) {
          return item.preparation && item.preparation.status === 'failed' && !item.approved;
        });
        resume.classList.toggle('hidden', !(batch.status === 'preparing' || hasFailedPrep));
      }

      function itemFieldsHtml(item) {
        var problems = (item.validationProblems || [])
          .map(function (problem) { return PROBLEM_LABELS[problem] || ''; })
          .filter(Boolean);
        var prep = item.preparation || null;
        var prepError = prep && prep.status === 'failed' && prep.error ? prep.error : '';
        var prepNote = '';
        if (prep && prep.status === 'succeeded') {
          prepNote = prep.fallbackUsed
            ? 'Η λεζάντα δημιουργήθηκε τοπικά (χωρίς AI πάροχο) — ελέγξτε την πριν την αποδοχή.'
            : 'Λεζάντα και hashtags από ' + (prep.provider || 'AI') + ' — ελέγξτε πριν την αποδοχή.';
        }

        var currentKey = destinationKey(item.provider, item.accountId);
        var knownDestination = destinations.some(function (dest) {
          return destinationKey(dest.provider, dest.accountId) === currentKey;
        });
        var destinationOptions = destinations.map(function (dest) {
          var key = destinationKey(dest.provider, dest.accountId);
          return '<option value="' + escapeAttr(key) + '"' + (key === currentKey ? ' selected' : '') + '>'
            + escapeHtml((PROVIDER_LABELS[dest.provider] || dest.providerDisplayName || dest.provider) + ' — ' + dest.label)
            + '</option>';
        }).join('');
        if (!knownDestination) {
          destinationOptions = '<option value="' + escapeAttr(currentKey) + '" selected>'
            + escapeHtml((PROVIDER_LABELS[item.provider] || item.provider) + ' — ' + (item.username ? '@' + item.username : item.accountId) + ' (μη διαθέσιμο)')
            + '</option>' + destinationOptions;
        }
        var youtubeTitle = item.providerMetadata && item.providerMetadata.youtube
          ? item.providerMetadata.youtube.title
          : '';

        return (item.duplicateWarning ? '<div class="item-warning">' + item.duplicateWarning + '</div>' : '') +
          (prepError ? '<div class="item-error">Η προετοιμασία απέτυχε: ' + prepError + '</div>' : '') +
          (problems.length > 0 ? '<div class="item-warning">' + problems.join('<br>') + '</div>' : '') +
          (prepNote ? '<div class="item-note">' + prepNote + '</div>' : '') +
          (item.approved
            ? ''
            : '<div>' +
                '<label class="field-label">Προορισμός &middot; Destination</label>' +
                '<select class="field-destination">' + destinationOptions + '</select>' +
              '</div>') +
          '<div class="youtube-title-wrap' + (item.provider === 'youtube' ? '' : ' hidden') + '">' +
            '<label class="field-label">Τίτλος YouTube (υποχρεωτικός, έως 100 χαρακτήρες) &middot; YouTube title</label>' +
            '<input type="text" class="field-youtube-title" maxlength="100" value="' + escapeAttr(youtubeTitle) + '">' +
          '</div>' +
          '<div>' +
            '<label class="field-label">Λεζάντα &middot; Caption</label>' +
            '<textarea class="field-caption">' + escapeHtml(item.caption || '') + '</textarea>' +
          '</div>' +
          '<div>' +
            '<label class="field-label">Hashtags</label>' +
            '<input type="text" class="field-hashtags" value="' + escapeAttr(item.hashtags || '') + '">' +
          '</div>' +
          '<div>' +
            '<label class="field-label">Ώρα δημοσίευσης &middot; Release time</label>' +
            '<input type="datetime-local" class="field-schedule" value="' + isoToLocalInput(item.scheduledAt) + '">' +
          '</div>';
      }

      function itemCard(item, options) {
        options = options || {};
        var card = document.createElement('div');
        card.className = 'item-card' + (item.approved ? ' accepted' : '') + (options.showMedia === false ? ' no-media' : '');
        card.dataset.postId = item.id;

        var headLabel = options.numberLabel
          ? options.numberLabel + ' &middot; ' + escapeHtml(PROVIDER_LABELS[item.provider] || item.provider) + ' — ' + escapeHtml(item.username ? '@' + item.username : item.accountId)
          : escapeHtml(PROVIDER_LABELS[item.provider] || item.provider) + ' — ' + escapeHtml(item.username ? '@' + item.username : item.accountId);

        card.innerHTML =
          (options.showMedia === false ? '' :
            '<div class="item-media">' +
              (item.mediaUrl
                ? '<video src="' + item.mediaUrl + '" controls preload="metadata" muted></video>'
                : '<div class="item-error">Χωρίς πολυμέσα</div>') +
              '<div class="item-file">' + (item.originalName || item.fileName || '') + '</div>' +
            '</div>') +
          '<div>' +
            '<div class="item-head">' +
              '<span class="item-order">' + headLabel + '</span>' +
              chip(ITEM_STATES, item.itemState) +
            '</div>' +
            '<div class="item-fields">' + itemFieldsHtml(item) + '</div>' +
            '<div class="item-footer">' +
              '<span class="item-scheduled">' +
                (item.approved
                  ? 'Εγκρίθηκε — προγραμματισμένο για ' + formatLocal(item.scheduledAt)
                  : 'Προτεινόμενη ώρα: ' + formatLocal(item.scheduledAt)) +
              '</span>' +
              '<div class="item-buttons">' +
                '<button class="btn save-btn">Αποθήκευση</button>' +
                (item.approved
                  ? ''
                  : '<button class="btn btn-primary accept-btn"' + (item.readyToAccept ? '' : ' disabled') + '>Αποδοχή</button>') +
                (item.approved
                  ? ''
                  : '<button class="btn btn-danger delete-btn">Διαγραφή</button>') +
              '</div>' +
            '</div>' +
          '</div>';

        bindItemCard(card, item);
        return card;
      }

      function escapeHtml(value) {
        return String(value).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
      }
      function escapeAttr(value) {
        return escapeHtml(value).replace(/"/g, '&quot;');
      }

      function bindItemCard(card, item) {
        var markDirty = function () { dirtyItems[item.id] = true; };
        card.querySelectorAll('.field-caption, .field-hashtags, .field-schedule, .field-youtube-title').forEach(function (field) {
          field.addEventListener('input', markDirty);
        });

        // The destination selector reveals the YouTube title field before
        // anything is saved, so the operator always sees what the new
        // destination will require.
        var destinationSelect = card.querySelector('.field-destination');
        if (destinationSelect) {
          destinationSelect.addEventListener('change', function () {
            markDirty();
            var provider = destinationSelect.value.split('|')[0];
            card.querySelector('.youtube-title-wrap').classList.toggle('hidden', provider !== 'youtube');
          });
        }

        card.querySelector('.save-btn').addEventListener('click', function () {
          var saveBtn = card.querySelector('.save-btn');
          saveBtn.disabled = true;

          var selectedProvider = item.provider;
          var selectedAccountId = item.accountId;
          if (destinationSelect) {
            var parts = destinationSelect.value.split('|');
            selectedProvider = parts[0];
            selectedAccountId = parts.slice(1).join('|');
          }
          var destinationChanged = selectedProvider !== item.provider || selectedAccountId !== item.accountId;
          var titleField = card.querySelector('.field-youtube-title');
          var titleValue = titleField ? titleField.value : '';

          // Step 1 (only when the destination moved): apply the destination
          // through its dedicated endpoint, carrying the title when the new
          // provider requires one.
          var destinationStep = destinationChanged
            ? api('/items/' + encodeURIComponent(item.id) + '/destination', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                  provider: selectedProvider,
                  accountId: selectedAccountId,
                  youtubeTitle: selectedProvider === 'youtube' ? titleValue : undefined
                })
              }).then(function (payload) {
                if (!payload.ok) throw new Error(payload.reason || 'Η αλλαγή προορισμού απέτυχε.');
              })
            : Promise.resolve();

          // Step 2: caption/hashtags/schedule (+ title edit when the item
          // already lives on YouTube and the destination did not move).
          destinationStep.then(function () {
            var body = {
              caption: card.querySelector('.field-caption').value,
              hashtags: card.querySelector('.field-hashtags').value,
              scheduleInput: {
                value: card.querySelector('.field-schedule').value,
                timezoneOffsetMinutes: new Date().getTimezoneOffset()
              }
            };
            if (!destinationChanged && selectedProvider === 'youtube') body.youtubeTitle = titleValue;
            return api('/items/' + encodeURIComponent(item.id), {
              method: 'PATCH',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(body)
            });
          }).then(function (payload) {
            saveBtn.disabled = false;
            if (payload.ok) {
              delete dirtyItems[item.id];
              showNotice('Οι αλλαγές αποθηκεύτηκαν.', 'ok');
              loadBatch();
            } else {
              showNotice(payload.reason || 'Η αποθήκευση απέτυχε.', 'error');
            }
          }).catch(function (error) {
            saveBtn.disabled = false;
            showNotice((error && error.message) || 'Η αποθήκευση απέτυχε — ελέγξτε τη σύνδεση.', 'error');
            loadBatch();
          });
        });

        var acceptBtn = card.querySelector('.accept-btn');
        if (acceptBtn) {
          acceptBtn.addEventListener('click', function () {
            acceptBtn.disabled = true;
            api('/items/' + encodeURIComponent(item.id) + '/accept', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: '{}'
            }).then(function (payload) {
              if (payload.ok && payload.accepted && payload.accepted.length === 1) {
                showNotice('Εγκρίθηκε. Προγραμματίστηκε για ' + formatLocal(payload.accepted[0].scheduledAt) + '.', 'ok');
              } else {
                var reason = payload.failed && payload.failed[0] ? payload.failed[0].reason : (payload.reason || 'Η αποδοχή απέτυχε.');
                showNotice(reason, 'error');
              }
              loadBatch();
            }).catch(function () {
              acceptBtn.disabled = false;
              showNotice('Η αποδοχή απέτυχε — ελέγξτε τη σύνδεση.', 'error');
            });
          });
        }

        var deleteBtn = card.querySelector('.delete-btn');
        if (deleteBtn) {
          deleteBtn.addEventListener('click', function () {
            var confirmed = window.confirm(
              'Διαγραφή αυτού του βίντεο από την παρτίδα; Η ενέργεια δεν αναιρείται.\n\n' +
              'Delete this video from the batch? This cannot be undone.'
            );
            if (!confirmed) return;
            deleteBtn.disabled = true;
            api('/items/' + encodeURIComponent(item.id) + '/delete', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: '{}'
            }).then(function (payload) {
              if (payload.ok) {
                delete dirtyItems[item.id];
                showNotice('Το βίντεο διαγράφηκε.', 'ok');
              } else {
                deleteBtn.disabled = false;
                showNotice(payload.reason || 'Η διαγραφή απέτυχε.', 'error');
              }
              loadBatch();
            }).catch(function () {
              deleteBtn.disabled = false;
              showNotice('Η διαγραφή απέτυχε — ελέγξτε τη σύνδεση.', 'error');
            });
          });
        }
      }

      function renderItems(view) {
        var container = document.getElementById('items');
        var focused = document.activeElement;
        var focusedCard = focused && focused.closest ? focused.closest('.item-card') : null;
        var seenPostIds = {};

        var groups = groupItems(view.items);
        var fanOut = groups.some(function (group) { return group.members.length > 1; });

        if (!fanOut) {
          // Single-destination batch: render exactly the flat list this page
          // has always used, unchanged.
          view.items.forEach(function (item, index) {
            seenPostIds[item.id] = true;
            var existing = container.querySelector('.item-card[data-post-id="' + item.id + '"]');
            if (existing && (dirtyItems[item.id] || existing === focusedCard)) return;
            var fresh = itemCard(item, { numberLabel: '#' + (index + 1), showMedia: true });
            if (existing) container.replaceChild(fresh, existing);
            else container.appendChild(fresh);
          });
          container.querySelectorAll('.video-group').forEach(function (group) { group.remove(); });
        } else {
          groups.forEach(function (group, groupIndex) {
            var groupKey = 'group:' + group.key;
            var groupEl = container.querySelector('[data-group-key="' + groupKey + '"]');
            var isDirtyGroup = group.members.some(function (member) {
              return dirtyItems[member.id] || (focusedCard && focusedCard.dataset.postId === member.id);
            });
            if (groupEl && isDirtyGroup) {
              group.members.forEach(function (member) { seenPostIds[member.id] = true; });
              return;
            }

            var freshGroup = document.createElement('div');
            freshGroup.className = 'video-group';
            freshGroup.dataset.groupKey = groupKey;
            var head = document.createElement('div');
            head.className = 'video-group-head';
            var first = group.members[0];
            head.innerHTML = '<span class="video-group-title">Βίντεο #' + (groupIndex + 1) +
              (first.originalName ? ' &middot; ' + escapeHtml(first.originalName) : '') +
              ' &middot; ' + group.members.length + ' ' + (group.members.length === 1 ? 'προορισμός' : 'προορισμοί') + '</span>';
            freshGroup.appendChild(head);

            if (first.mediaUrl) {
              var mediaWrap = document.createElement('div');
              mediaWrap.className = 'video-group-media';
              mediaWrap.innerHTML = '<video src="' + first.mediaUrl + '" controls preload="metadata" muted></video>';
              freshGroup.appendChild(mediaWrap);
            }

            group.members.forEach(function (item) {
              seenPostIds[item.id] = true;
              freshGroup.appendChild(itemCard(item, { numberLabel: null, showMedia: false }));
            });

            if (groupEl) container.replaceChild(freshGroup, groupEl);
            else container.appendChild(freshGroup);
          });
          container.querySelectorAll('.item-card').forEach(function (card) {
            if (!card.closest('.video-group')) card.remove();
          });
        }

        // Drop cards/groups for items that no longer exist (deleted).
        container.querySelectorAll('.item-card[data-post-id]').forEach(function (card) {
          if (!seenPostIds[card.dataset.postId]) {
            var group = card.closest('.video-group');
            if (group && group.querySelectorAll('.item-card').length === 1) group.remove();
            else card.remove();
          }
        });
      }

      // ── Data flow ──

      function loadBatch() {
        return api('', {}).then(function (payload) {
          if (!payload.ok) {
            showNotice(payload.reason || 'Η παρτίδα δεν βρέθηκε.', 'error');
            return;
          }
          currentView = payload;
          renderSummary(payload);
          renderItems(payload);
          schedulePoll(payload);
        }).catch(function () {
          showNotice('Η φόρτωση απέτυχε — ελέγξτε τη σύνδεση.', 'error');
        });
      }

      function schedulePoll(view) {
        if (pollTimer) { clearTimeout(pollTimer); pollTimer = null; }
        if (view.batch.status === 'preparing') {
          pollTimer = setTimeout(loadBatch, 3500);
        }
      }

      document.getElementById('refresh-btn').addEventListener('click', function () { loadBatch(); });

      document.getElementById('resume-btn').addEventListener('click', function () {
        var resumeBtn = document.getElementById('resume-btn');
        resumeBtn.disabled = true;
        api('/prepare', { method: 'POST' }).then(function (payload) {
          resumeBtn.disabled = false;
          if (payload.ok) showNotice('Η προετοιμασία συνεχίζεται.', 'ok');
          else showNotice(payload.reason || 'Η προετοιμασία δεν μπόρεσε να συνεχιστεί.', 'error');
          loadBatch();
        }).catch(function () { resumeBtn.disabled = false; });
      });

      document.getElementById('accept-all-btn').addEventListener('click', function () {
        var acceptAllBtn = document.getElementById('accept-all-btn');
        acceptAllBtn.disabled = true;
        api('/accept-all', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: '{}'
        }).then(function (payload) {
          var blockedDetail = '';
          if (payload.failed && payload.failed.length > 0 && currentView) {
            var names = {};
            currentView.items.forEach(function (item) { names[item.id] = item.originalName || item.fileName || item.id; });
            blockedDetail = payload.failed.slice(0, 3).map(function (failure) {
              return '«' + (names[failure.id] || failure.id) + '»: ' + failure.reason;
            }).join(' ');
            if (payload.failed.length > 3) blockedDetail += ' (+' + (payload.failed.length - 3) + ' ακόμη)';
          }
          if (payload.accepted && payload.accepted.length > 0) {
            var message = 'Εγκρίθηκαν ' + payload.accepted.length + ' εγγραφές με ασφαλή προγραμματισμό.';
            if (payload.failed && payload.failed.length > 0) {
              message += ' Μπλοκαρισμένα: ' + payload.failed.length + '. ' + blockedDetail;
            }
            showNotice(message, payload.failed && payload.failed.length > 0 ? 'error' : 'ok');
          } else {
            showNotice(blockedDetail || payload.reason || 'Δεν υπάρχουν έτοιμα στοιχεία για αποδοχή.', 'error');
          }
          loadBatch();
        }).catch(function () {
          acceptAllBtn.disabled = false;
          showNotice('Η αποδοχή απέτυχε — ελέγξτε τη σύνδεση.', 'error');
        });
      });

      document.getElementById('delete-batch-btn').addEventListener('click', function () {
        if (!currentView) return;
        var pendingCount = currentView.items.filter(function (item) { return !item.approved; }).length;
        var approvedCount = currentView.items.length - pendingCount;
        var message = 'Διαγραφή ολόκληρης της παρτίδας; Θα διαγραφούν ' + pendingCount + ' μη εγκεκριμένα στοιχεία.' +
          (approvedCount > 0 ? ' ' + approvedCount + ' εγκεκριμένα στοιχεία θα διατηρηθούν.' : '') +
          ' Η ενέργεια δεν αναιρείται.\n\n' +
          'Delete the entire batch? This cannot be undone.';
        if (!window.confirm(message)) return;

        var deleteBatchBtn = document.getElementById('delete-batch-btn');
        deleteBatchBtn.disabled = true;
        api('/delete', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: '{}'
        }).then(function (payload) {
          var deletedCount = payload.deleted ? payload.deleted.length : 0;
          var blockedCount = payload.blocked ? payload.blocked.length : 0;
          var failedCount = payload.failed ? payload.failed.length : 0;
          var summary = 'Διαγράφηκαν ' + deletedCount + ' στοιχεία.';
          if (blockedCount > 0) summary += ' Μπλοκαρισμένα (εγκεκριμένα): ' + blockedCount + '.';
          if (failedCount > 0) summary += ' Απέτυχαν: ' + failedCount + '.';
          if (payload.batchClosed) {
            showNotice(summary + ' Η παρτίδα έκλεισε.', 'ok');
            setTimeout(function () { window.location.href = '/platform/autoposter'; }, 1200);
            return;
          }
          deleteBatchBtn.disabled = false;
          showNotice(summary, (blockedCount > 0 || failedCount > 0) ? 'error' : 'ok');
          loadBatch();
        }).catch(function () {
          deleteBatchBtn.disabled = false;
          showNotice('Η διαγραφή απέτυχε — ελέγξτε τη σύνδεση.', 'error');
        });
      });

      loadDestinations().then(loadBatch);
    })();
  </script>
</body>
</html>
