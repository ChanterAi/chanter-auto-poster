<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= appName %></title>
    <style>
      :root {
        --bg: #030303;
        --surface: rgba(255, 255, 255, 0.02);
        --surface-raised: rgba(255, 255, 255, 0.04);
        --border: rgba(255, 255, 255, 0.06);
        --border-hover: rgba(255, 255, 255, 0.1);
        --violet: #7c3aed;
        --violet-bright: #8b5cf6;
        --violet-glow: rgba(124, 58, 237, 0.25);
        --text: #fafafa;
        --text-secondary: #a1a1aa;
        --text-muted: #71717a;
        --danger: #ef4444;
        --danger-muted: rgba(239, 68, 68, 0.12);
        --warning: #eab308;
        --warning-muted: rgba(234, 179, 8, 0.12);
        --success: #22c55e;
        --success-muted: rgba(34, 197, 94, 0.12);
        --radius: 16px;
        --radius-sm: 10px;
      }

      * { box-sizing: border-box; margin: 0; padding: 0; }

      html { background: var(--bg); }

      body {
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        color: var(--text);
        background: var(--bg);
        line-height: 1.5;
        -webkit-font-smoothing: antialiased;
      }

      body::before {
        content: "";
        position: fixed;
        inset: 0;
        z-index: 0;
        background:
          radial-gradient(ellipse 80% 50% at 50% -10%, rgba(124, 58, 237, 0.07), transparent),
          radial-gradient(ellipse 60% 40% at 80% 80%, rgba(124, 58, 237, 0.03), transparent);
        pointer-events: none;
      }

      .app {
        position: relative;
        z-index: 1;
        max-width: 1100px;
        margin: 0 auto;
        padding: 28px 24px 80px;
      }

      /* Topbar */
      .topbar {
        margin-bottom: 28px;
      }

      .topbar-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        padding: 14px 18px;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        backdrop-filter: blur(24px);
      }

      .brand {
        display: flex;
        align-items: center;
        gap: 14px;
      }

      .brand-mark {
        width: 38px;
        height: 38px;
        border-radius: 10px;
        background: linear-gradient(135deg, var(--violet), #4c1d95);
        box-shadow: 0 0 20px var(--violet-glow);
        display: grid;
        place-items: center;
      }

      .brand-mark::after {
        content: "C";
        font-weight: 800;
        font-size: 17px;
        color: white;
      }

      .brand-title {
        font-size: 17px;
        font-weight: 800;
        letter-spacing: -0.02em;
        color: var(--text);
        line-height: 1.2;
      }

      .brand-sub {
        font-size: 11px;
        font-weight: 700;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.06em;
      }

      .topbar-actions {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
      }

      /* Pills */
      .pill {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 6px 12px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 700;
        border: 1px solid var(--border);
        background: var(--surface-raised);
        color: var(--text-secondary);
        white-space: nowrap;
      }

      .pill-connected {
        border-color: rgba(34, 197, 94, 0.25);
        background: var(--success-muted);
        color: var(--success);
      }

      .pill-offline {
        border-color: rgba(234, 179, 8, 0.25);
        background: var(--warning-muted);
        color: var(--warning);
      }

      .pill-creator {
        padding: 4px 12px 4px 4px;
        gap: 8px;
      }

      .pill-creator img {
        width: 22px;
        height: 22px;
        border-radius: 50%;
        object-fit: cover;
        background: var(--surface);
      }

      .dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: currentColor;
        box-shadow: 0 0 10px currentColor;
      }

      /* Buttons */
      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        height: 36px;
        padding: 0 14px;
        border-radius: var(--radius-sm);
        font-size: 13px;
        font-weight: 700;
        border: 1px solid transparent;
        cursor: pointer;
        text-decoration: none;
        transition: all 0.2s ease;
        background: none;
        color: inherit;
        font-family: inherit;
      }

      .btn-primary {
        background: var(--violet);
        color: white;
        box-shadow: 0 4px 16px var(--violet-glow);
      }

      .btn-primary:hover {
        background: var(--violet-bright);
        transform: translateY(-1px);
        box-shadow: 0 6px 22px var(--violet-glow);
      }

      .btn-ghost {
        border-color: var(--border);
        color: var(--text-secondary);
        background: transparent;
      }

      .btn-ghost:hover {
        border-color: var(--border-hover);
        background: var(--surface-raised);
        color: var(--text);
      }

      .btn-danger {
        border-color: rgba(239, 68, 68, 0.25);
        color: #fca5a5;
        background: transparent;
      }

      .btn-danger:hover {
        background: var(--danger-muted);
        border-color: rgba(239, 68, 68, 0.4);
      }

      .btn-secondary {
        border-color: var(--border);
        color: var(--text-secondary);
        background: transparent;
      }

      .btn-secondary:hover {
        border-color: var(--border-hover);
        background: var(--surface-raised);
        color: var(--text);
      }

      /* Notice */
      .notice {
        margin-bottom: 24px;
        padding: 14px 18px;
        border-radius: var(--radius-sm);
        border: 1px solid rgba(139, 92, 246, 0.2);
        background: rgba(124, 58, 237, 0.08);
        color: var(--text);
        font-size: 14px;
        font-weight: 500;
      }

      /* Layout */
      .dashboard-grid {
        display: grid;
        grid-template-columns: 1.2fr 0.8fr;
        gap: 20px;
        margin-bottom: 32px;
      }

      /* Panels */
      .panel {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 24px;
        backdrop-filter: blur(24px);
      }

      .panel-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 20px;
      }

      .panel-head h2 {
        font-size: 16px;
        font-weight: 800;
        letter-spacing: -0.01em;
      }

      .panel-meta {
        font-size: 13px;
        font-weight: 700;
        color: var(--text-muted);
        font-variant-numeric: tabular-nums;
      }

      /* Forms */
      .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
      }

      .form-grid .wide {
        grid-column: 1 / -1;
      }

      label {
        display: grid;
        gap: 8px;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: var(--text-muted);
      }

      .field-note {
        display: block;
        font-size: 12px;
        font-weight: 500;
        text-transform: none;
        color: var(--text-muted);
        letter-spacing: 0;
        line-height: 1.4;
      }

      input,
      select,
      textarea {
        width: 100%;
        background: rgba(0, 0, 0, 0.35);
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        padding: 10px 12px;
        color: var(--text);
        font-size: 14px;
        font-family: inherit;
        outline: none;
        transition: all 0.2s ease;
      }

      input:focus,
      select:focus,
      textarea:focus {
        border-color: var(--violet);
        box-shadow: 0 0 0 3px var(--violet-glow);
      }

      input::placeholder,
      textarea::placeholder {
        color: var(--text-muted);
      }

      input[type="file"] {
        padding: 12px;
        cursor: pointer;
        min-height: 56px;
      }

      input[type="file"]::file-selector-button {
        margin-right: 12px;
        padding: 6px 12px;
        border-radius: 6px;
        border: 1px solid var(--border);
        background: var(--surface-raised);
        color: var(--text-secondary);
        font-weight: 600;
        cursor: pointer;
      }

      textarea {
        min-height: 80px;
        resize: vertical;
      }

      select {
        appearance: none;
        background-image: url("data:image/svg+xml,%3Csvg width='10' height='6' viewBox='0 0 10 6' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1l4 4 4-4' stroke='%2371717a' stroke-width='1.5' fill='none' fill-rule='evenodd'/%3E%3C/svg%3E");
        background-repeat: no-repeat;
        background-position: right 12px center;
        padding-right: 32px;
      }

      .actions {
        display: flex;
        gap: 10px;
        margin-top: 16px;
        flex-wrap: wrap;
      }

      .actions .btn {
        height: 40px;
        padding: 0 18px;
      }

      /* Queue */
      .queue-section {
        margin-bottom: 32px;
      }

      .section-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 20px;
      }

      .section-head h2 {
        font-size: 18px;
        font-weight: 800;
      }

      .count {
        font-size: 13px;
        font-weight: 700;
        color: var(--text-muted);
      }

      .queue-list {
        display: grid;
        gap: 16px;
      }

      .queue-card {
        display: grid;
        grid-template-columns: 140px 1fr;
        gap: 20px;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 20px;
        backdrop-filter: blur(24px);
        transition: border-color 0.2s ease, transform 0.2s ease;
      }

      .queue-card:hover {
        border-color: var(--border-hover);
        transform: translateY(-1px);
      }

      .queue-thumb {
        position: relative;
        width: 140px;
        aspect-ratio: 4 / 5;
        border-radius: var(--radius-sm);
        overflow: hidden;
        background: #0a0a0a;
        border: 1px solid var(--border);
        flex-shrink: 0;
      }

      .queue-thumb img,
      .queue-thumb video {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
      }

      .queue-thumb .thumb-placeholder {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: contain;
        padding: 24px;
        opacity: 0;
        filter: saturate(0.8);
      }

      .queue-thumb.is-missing [data-preview-media] {
        display: none;
      }

      .queue-thumb.is-missing .thumb-placeholder {
        opacity: 0.4;
      }

      .media-chip {
        position: absolute;
        bottom: 8px;
        right: 8px;
        padding: 4px 8px;
        border-radius: 6px;
        background: rgba(0, 0, 0, 0.65);
        backdrop-filter: blur(10px);
        font-size: 10px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: var(--violet-bright);
        border: 1px solid var(--border);
      }

      .queue-main {
        min-width: 0;
        display: flex;
        flex-direction: column;
        gap: 14px;
      }

      .queue-top {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 12px;
      }

      .queue-title h3 {
        font-size: 15px;
        font-weight: 700;
        color: var(--text);
        overflow-wrap: anywhere;
        line-height: 1.3;
      }

      .queue-meta {
        font-size: 13px;
        color: var(--text-muted);
        font-weight: 500;
        margin-top: 4px;
      }

      .caption-preview {
        font-size: 14px;
        color: var(--text-secondary);
        line-height: 1.5;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }

      .result-message {
        font-size: 13px;
        line-height: 1.5;
        padding: 10px 14px;
        border-radius: var(--radius-sm);
        background: rgba(0, 0, 0, 0.25);
        border: 1px solid var(--border);
        color: var(--text-secondary);
      }

      .result-message.is-failed {
        border-color: rgba(239, 68, 68, 0.18);
        background: var(--danger-muted);
        color: #fca5a5;
      }

      /* Badges */
      .badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 5px 10px;
        border-radius: 999px;
        font-size: 11px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        border: 1px solid var(--border);
        background: var(--surface-raised);
        color: var(--text-muted);
        white-space: nowrap;
        flex-shrink: 0;
      }

      .badge::before {
        content: "";
        width: 5px;
        height: 5px;
        border-radius: 50%;
        background: currentColor;
      }

      .badge.pending,
      .badge.scheduled {
        border-color: rgba(234, 179, 8, 0.25);
        background: var(--warning-muted);
        color: var(--warning);
      }

      .badge.ready,
      .badge.verification {
        border-color: rgba(139, 92, 246, 0.25);
        background: rgba(139, 92, 246, 0.08);
        color: #c4b5fd;
      }

      .badge.posted,
      .badge.accepted {
        border-color: rgba(34, 197, 94, 0.25);
        background: var(--success-muted);
        color: var(--success);
      }

      .badge.publishing {
        border-color: rgba(6, 182, 212, 0.25);
        background: rgba(6, 182, 212, 0.08);
        color: #67e8f9;
      }

      .badge.failed {
        border-color: rgba(239, 68, 68, 0.2);
        background: var(--danger-muted);
        color: #fca5a5;
      }

      /* Card forms */
      .schedule-form {
        display: grid;
        gap: 12px;
      }

      .schedule-row {
        display: grid;
        grid-template-columns: 1fr 0.5fr auto;
        gap: 12px;
        align-items: end;
      }

      .card-actions {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
      }

      .advanced {
        margin-top: 4px;
      }

      .advanced summary {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: var(--text-muted);
        cursor: pointer;
        user-select: none;
      }

      .advanced-body {
        margin-top: 12px;
        display: grid;
        gap: 12px;
      }

      .advanced pre {
        background: rgba(0, 0, 0, 0.35);
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        padding: 14px;
        font-size: 12px;
        line-height: 1.6;
        color: var(--text-secondary);
        overflow: auto;
        max-height: 240px;
        white-space: pre-wrap;
        overflow-wrap: anywhere;
      }

      /* Empty states */
      .empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 60px 24px;
        border: 1px dashed var(--border);
        border-radius: var(--radius);
        background: var(--surface);
        color: var(--text-muted);
        text-align: center;
      }

      .empty-state p {
        font-size: 15px;
        font-weight: 700;
        color: var(--text-secondary);
      }

      .empty-state span {
        font-size: 13px;
      }

      /* History */
      .history-panel {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        backdrop-filter: blur(24px);
      }

      .history-panel > summary {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 20px 24px;
        cursor: pointer;
        font-size: 16px;
        font-weight: 800;
        list-style: none;
      }

      .history-panel > summary::-webkit-details-marker {
        display: none;
      }

      .history-panel > summary::after {
        content: "Expand";
        font-size: 12px;
        font-weight: 700;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.04em;
      }

      .history-panel[open] > summary::after {
        content: "Collapse";
      }

      .history-list {
        padding: 0 24px 24px;
        display: grid;
        gap: 12px;
      }

      .history-card {
        display: grid;
        grid-template-columns: 100px 1fr;
        gap: 16px;
        padding: 16px;
        border-radius: var(--radius-sm);
        border: 1px solid var(--border);
        background: rgba(0, 0, 0, 0.2);
        transition: border-color 0.2s ease;
      }

      .history-card:hover {
        border-color: var(--border-hover);
      }

      .history-card .queue-thumb {
        width: 100px;
        aspect-ratio: 1;
      }

      .history-empty {
        padding: 40px;
        text-align: center;
        color: var(--text-muted);
        font-size: 14px;
      }

      /* Responsive */
      @media (max-width: 860px) {
        .dashboard-grid {
          grid-template-columns: 1fr;
        }

        .queue-card {
          grid-template-columns: 1fr;
        }

        .queue-thumb {
          width: 100%;
          aspect-ratio: 16 / 10;
        }

        .schedule-row {
          grid-template-columns: 1fr;
        }

        .history-card {
          grid-template-columns: 1fr;
        }

        .history-card .queue-thumb {
          width: 100%;
          aspect-ratio: 16 / 10;
        }
      }

      @media (max-width: 640px) {
        .app {
          padding: 16px 16px 60px;
        }

        .topbar-inner {
          flex-direction: column;
          align-items: flex-start;
        }

        .topbar-actions {
          width: 100%;
        }

        .queue-top {
          flex-direction: column;
        }

        .actions .btn,
        .card-actions .btn,
        .schedule-row .btn {
          width: 100%;
          justify-content: center;
        }
      }
    </style>
  </head>
  <body>
    <%
      const statusOf = (post) => String((post && post.status) || 'pending').toLowerCase();
      const activePosts = posts.filter((post) => statusOf(post) !== 'posted');
      const historyPosts = posts.filter((post) => statusOf(post) === 'posted');
      const privacyOptions = Array.isArray(creatorInfo && creatorInfo.privacy_level_options) && creatorInfo.privacy_level_options.length > 0
        ? creatorInfo.privacy_level_options
        : ['SELF_ONLY'];
      const displayResultLabel = (result) => {
        const tone = String((result && result.tone) || '').toLowerCase();
        const label = String((result && result.stateLabel) || '').toLowerCase();

        if (tone === 'failed' || label.includes('failed')) return 'Failed';
        if (tone === 'verification' || label.includes('verification')) return 'Needs verification';
        if (tone === 'accepted' || label.includes('posted') || label.includes('accepted')) return 'Posted / API accepted';
        if (tone === 'publishing' || label.includes('publishing')) return 'Publishing';
        return 'Scheduled';
      };
      const captionPreview = (post) => helpers.fullCaption(post) || 'No caption';
      const selectedPrivacy = (post) => {
        const value = String((post && post.privacyLevel) || 'SELF_ONLY').trim() || 'SELF_ONLY';
        return privacyOptions.includes(value) ? value : privacyOptions[0];
      };
    %>

    <div class="app">
      <header class="topbar">
        <div class="topbar-inner">
          <div class="brand">
            <div class="brand-mark"></div>
            <div class="brand-text">
              <div class="brand-title">CHANTER</div>
              <div class="brand-sub">Auto Poster</div>
            </div>
          </div>
          <div class="topbar-actions">
            <% if (tiktokConfigured) { %>
              <div class="pill pill-connected">
                <span class="dot"></span>
                TikTok Connected
              </div>
              <% if (creatorInfo) { %>
                <div class="pill pill-creator">
                  <img src="<%= creatorInfo.creator_avatar_url || '/assets/chanter-logo.png' %>" alt="" />
                  <span><%= creatorInfo.creator_username ? `@${creatorInfo.creator_username}` : (creatorInfo.creator_nickname || 'Creator') %></span>
                </div>
              <% } %>
              <a class="btn btn-ghost" href="/disconnect/tiktok">Disconnect</a>
            <% } else { %>
              <div class="pill pill-offline">
                <span class="dot"></span>
                Manual Mode
              </div>
              <a class="btn btn-primary" href="/connect/tiktok">Connect TikTok</a>
            <% } %>
          </div>
        </div>
      </header>

      <% if (notice) { %>
        <div class="notice"><%= notice %></div>
      <% } %>

      <div class="dashboard-grid" aria-label="Poster controls">
        <section class="panel">
          <div class="panel-head">
            <h2>Upload</h2>
          </div>
          <form action="/upload" method="post" enctype="multipart/form-data" data-upload-form>
            <div class="form-grid">
              <label class="wide">
                Media
                <input type="file" name="images" accept="image/*,video/mp4,video/quicktime,video/webm,video/*" multiple required data-media-upload />
              </label>
              <label>
                Caption
                <textarea name="caption" placeholder="Write a caption..."></textarea>
              </label>
              <label>
                Hashtags
                <textarea name="hashtags" placeholder="#chanter #viral"></textarea>
              </label>
            </div>
            <div class="actions">
              <button type="submit" class="btn btn-primary">Upload</button>
            </div>
          </form>
        </section>

        <section class="panel">
          <div class="panel-head">
            <h2>Schedule</h2>
            <span class="panel-meta"><%= settings.dailyPostTime %></span>
          </div>
          <form action="/settings" method="post">
            <label>
              Daily time
              <input type="time" name="dailyPostTime" value="<%= settings.dailyPostTime %>" required />
            </label>
            <div class="actions">
              <button type="submit" class="btn btn-primary">Save schedule</button>
            </div>
          </form>
          <form action="/schedule" method="post">
            <div class="actions" style="margin-top: 8px;">
              <button type="submit" class="btn btn-secondary">Rebuild queue</button>
            </div>
          </form>
        </section>
      </div>

      <section class="queue-section" aria-label="Queue">
        <div class="section-head">
          <h2>Queue</h2>
          <span class="count"><%= activePosts.length %> active</span>
        </div>

        <% if (activePosts.length === 0) { %>
          <div class="empty-state">
            <p>Queue empty</p>
            <span>Upload media to get started</span>
          </div>
        <% } %>

        <div class="queue-list">
          <% activePosts.forEach(function(post) { %>
            <% const mediaPath = helpers.mediaPath(post); %>
            <% const mediaType = helpers.mediaType(post); %>
            <% const result = helpers.postResult(post); %>
            <article class="queue-card" data-post-card>
              <% if (mediaPath) { %>
                <a class="queue-thumb" href="<%= mediaPath %>" target="_blank" rel="noreferrer">
                  <img class="thumb-placeholder" src="/assets/chanter-logo.png" alt="" />
                  <% if (mediaType === 'video') { %>
                    <video src="<%= mediaPath %>" muted playsinline preload="metadata" data-preview-media></video>
                  <% } else { %>
                    <img src="<%= mediaPath %>" alt="<%= post.originalName %>" loading="lazy" data-preview-media />
                  <% } %>
                  <span class="media-chip"><%= helpers.mediaLabel(post) %></span>
                </a>
              <% } else { %>
                <div class="queue-thumb is-missing">
                  <img class="thumb-placeholder" src="/assets/chanter-logo.png" alt="" />
                  <span class="media-chip"><%= helpers.mediaLabel(post) %></span>
                </div>
              <% } %>

              <div class="queue-main">
                <div class="queue-top">
                  <div class="queue-title">
                    <h3><%= post.originalName %></h3>
                    <p class="queue-meta"><%= helpers.formatDateTime(post.scheduledAt) %></p>
                  </div>
                  <span class="badge <%= result.tone %>" data-result-badge><%= displayResultLabel(result) %></span>
                </div>

                <p class="caption-preview"><%= captionPreview(post) %></p>

                <% if (result.message && result.tone === 'failed') { %>
                  <p class="result-message is-failed"><%= result.message %></p>
                <% } else if (result.message && result.tone !== 'scheduled' && result.tone !== 'posted' && result.tone !== 'accepted') { %>
                  <p class="result-message"><%= result.message %></p>
                <% } %>

                <form
                  class="schedule-form"
                  action="/posts/<%= post.id %>"
                  method="post"
                  data-edit-form
                  data-media-type="<%= mediaType %>"
                  data-has-local-media="<%= helpers.hasLocalMedia(post) ? 'true' : 'false' %>"
                >
                  <input type="hidden" name="caption" value="<%= post.caption || '' %>" />
                  <input type="hidden" name="hashtags" value="<%= post.hashtags || '' %>" />
                  <input type="hidden" name="timezoneOffsetMinutes" data-timezone-offset />
                  <div class="schedule-row">
                    <label>
                      <span class="field-note">Publishes automatically at this time in your local timezone.</span>
                      <input type="datetime-local" name="scheduledAt" value="<%= helpers.dateTimeInput(post.scheduledAt) %>" />
                    </label>
                    <label>
                      Privacy
                      <select name="privacyLevel">
                        <% privacyOptions.forEach(function(option) { %>
                          <option value="<%= option %>" <%= selectedPrivacy(post) === option ? 'selected' : '' %>><%= option %></option>
                        <% }); %>
                      </select>
                    </label>
                    <button type="submit" class="btn btn-primary">Save</button>
                  </div>
                  <details class="advanced">
                    <summary>Advanced</summary>
                    <div class="advanced-body">
                      <label>
                        Public image URL
                        <input
                          type="url"
                          name="publicImageUrl"
                          value="<%= post.publicImageUrl || '' %>"
                          placeholder="<%= mediaType === 'video' ? 'Not required for video posts' : 'https://example.com/image.png' %>"
                          data-public-image-url
                        />
                      </label>
                      <% if (result.hasDebug) { %>
                        <pre><%= result.debugJson %></pre>
                      <% } %>
                    </div>
                  </details>
                </form>

                <div class="card-actions">
                  <form class="inline-action" action="/posts/<%= post.id %>/prepare" method="post" data-publish-form onsubmit="return confirm('Post now? This ignores the schedule.');">
                    <input type="hidden" name="force" value="1" />
                    <button type="submit" class="btn btn-secondary">Post now</button>
                  </form>
                  <form class="inline-action" action="/posts/<%= post.id %>/delete" method="post">
                    <button type="submit" class="btn btn-danger">Delete</button>
                  </form>
                </div>
              </div>
            </article>
          <% }); %>
        </div>
      </section>

      <details class="history-panel">
        <summary>
          <span>History</span>
          <span class="count"><%= historyPosts.length %> posted</span>
        </summary>
        <div class="history-list">
          <% if (historyPosts.length === 0) { %>
            <div class="history-empty">No posted history</div>
          <% } %>

          <% historyPosts.forEach(function(post) { %>
            <% const mediaPath = helpers.mediaPath(post); %>
            <% const mediaType = helpers.mediaType(post); %>
            <% const result = helpers.postResult(post); %>
            <article class="history-card">
              <% if (mediaPath) { %>
                <a class="queue-thumb" href="<%= mediaPath %>" target="_blank" rel="noreferrer">
                  <img class="thumb-placeholder" src="/assets/chanter-logo.png" alt="" />
                  <% if (mediaType === 'video') { %>
                    <video src="<%= mediaPath %>" muted playsinline preload="metadata" data-preview-media></video>
                  <% } else { %>
                    <img src="<%= mediaPath %>" alt="<%= post.originalName %>" loading="lazy" data-preview-media />
                  <% } %>
                  <span class="media-chip"><%= helpers.mediaLabel(post) %></span>
                </a>
              <% } else { %>
                <div class="queue-thumb is-missing">
                  <img class="thumb-placeholder" src="/assets/chanter-logo.png" alt="" />
                  <span class="media-chip"><%= helpers.mediaLabel(post) %></span>
                </div>
              <% } %>

              <div class="queue-main">
                <div class="queue-top">
                  <div class="queue-title">
                    <h3><%= post.originalName %></h3>
                    <p class="queue-meta"><%= helpers.formatDateTime(post.postedAt || post.scheduledAt) %></p>
                  </div>
                  <span class="badge <%= result.tone %>"><%= displayResultLabel(result) %></span>
                </div>
                <p class="caption-preview"><%= captionPreview(post) %></p>
                <div class="card-actions">
                  <form class="inline-action" action="/posts/<%= post.id %>/delete" method="post">
                    <button type="submit" class="btn btn-danger">Remove from history</button>
                  </form>
                </div>
                <% if (result.hasDebug) { %>
                  <details class="advanced">
                    <summary>Advanced</summary>
                    <div class="advanced-body">
                      <pre><%= result.debugJson %></pre>
                    </div>
                  </details>
                <% } %>
              </div>
            </article>
          <% }); %>
        </div>
      </details>
    </div>

    <script>
      function copyText(value) {
        if (navigator.clipboard && window.isSecureContext) {
          return navigator.clipboard.writeText(value);
        }

        const fallback = document.createElement('textarea');
        fallback.value = value;
        fallback.setAttribute('readonly', '');
        fallback.style.position = 'fixed';
        fallback.style.opacity = '0';
        document.body.appendChild(fallback);
        fallback.select();
        document.execCommand('copy');
        fallback.remove();
        return Promise.resolve();
      }

      document.querySelectorAll('.copy-button').forEach((button) => {
        button.addEventListener('click', async () => {
          const target = document.getElementById(button.dataset.target);
          if (!target) return;

          await copyText(target.value);
          const originalText = button.textContent;
          button.textContent = 'Copied';
          window.setTimeout(() => {
            button.textContent = originalText;
          }, 1200);
        });
      });

      function getFileKind(file) {
        const type = String(file.type || '').toLowerCase();
        const name = String(file.name || '').toLowerCase();

        if (type.startsWith('image/')) return 'photo';
        if (type.startsWith('video/')) return 'video';
        if (/\.(png|jpe?g|webp|gif)$/i.test(name)) return 'photo';
        if (/\.(mp4|mov|webm)$/i.test(name)) return 'video';
        return '';
      }

      document.querySelectorAll('[data-upload-form]').forEach((form) => {
        const input = form.querySelector('[data-media-upload]');
        if (!input) return;

        const validateUpload = () => {
          const files = Array.from(input.files || []);
          let message = '';

          if (files.length === 0) {
            message = 'Choose at least one image or video file.';
          } else if (files.some((file) => !getFileKind(file))) {
            message = 'Use image files or MP4, MOV, or WebM video files.';
          }

          input.setCustomValidity(message);
          return !message;
        };

        input.addEventListener('change', validateUpload);
        form.addEventListener('submit', (event) => {
          if (!validateUpload()) {
            event.preventDefault();
            input.reportValidity();
          }
        });
      });

      document.querySelectorAll('[data-timezone-offset]').forEach((input) => {
        input.value = String(new Date().getTimezoneOffset());
      });

      document.querySelectorAll('[data-edit-form]').forEach((form) => {
        const input = form.querySelector('[data-public-image-url]');
        if (!input) return;

        const validatePostMedia = () => {
          const mediaType = form.dataset.mediaType;
          const hasLocalMedia = form.dataset.hasLocalMedia === 'true';
          const hasPublicImageUrl = input.value.trim().length > 0;
          const missingPhotoSource = mediaType === 'photo' && !hasLocalMedia && !hasPublicImageUrl;

          input.setCustomValidity(missingPhotoSource ? 'Add an image file or public image URL for photo posts.' : '');
          return !missingPhotoSource;
        };

        input.addEventListener('input', validatePostMedia);
        form.addEventListener('submit', (event) => {
          if (!validatePostMedia()) {
            event.preventDefault();
            input.reportValidity();
          }
        });
      });

      document.querySelectorAll('[data-publish-form]').forEach((form) => {
        form.addEventListener('submit', () => {
          const card = form.closest('[data-post-card]');
          const badge = card ? card.querySelector('[data-result-badge]') : null;
          const button = form.querySelector('button');

          if (button) {
            button.disabled = true;
            button.textContent = 'Publishing';
          }

          if (badge) {
            badge.className = 'badge publishing';
            badge.textContent = 'Publishing';
          }
        });
      });

      document.querySelectorAll('[data-preview-media]').forEach((media) => {
        const markMissing = () => {
          const thumb = media.closest('.queue-thumb');
          if (thumb) thumb.classList.add('is-missing');
        };

        media.addEventListener('error', markMissing);

        if (media.tagName === 'IMG' && media.complete && media.naturalWidth === 0) {
          markMissing();
        }
      });
    </script>
  </body>
</html>