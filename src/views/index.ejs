<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= appName %></title>
    <style>
      :root {
        color-scheme: dark;
        --bg: #050506;
        --surface: rgba(13, 13, 18, 0.86);
        --surface-strong: rgba(18, 18, 24, 0.94);
        --field: rgba(255, 255, 255, 0.055);
        --ink: #fbf7ff;
        --text: #e9e3f1;
        --muted: #aca2b8;
        --quiet: #777080;
        --line: rgba(226, 211, 255, 0.12);
        --line-strong: rgba(226, 211, 255, 0.24);
        --violet: #a970ff;
        --violet-bright: #d8c2ff;
        --cyan: #6ee7f2;
        --green: #9de8c3;
        --amber: #ffd17a;
        --red: #ff9297;
        --shadow: 0 28px 80px rgba(0, 0, 0, 0.58);
        --shadow-soft: 0 16px 38px rgba(0, 0, 0, 0.36);
      }

      * {
        box-sizing: border-box;
      }

      html {
        background: var(--bg);
      }

      body {
        min-height: 100vh;
        margin: 0;
        background:
          linear-gradient(180deg, rgba(169, 112, 255, 0.12), rgba(5, 5, 6, 0) 260px),
          linear-gradient(135deg, rgba(255, 255, 255, 0.035), transparent 38%, rgba(169, 112, 255, 0.035)),
          var(--bg);
        color: var(--text);
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      }

      body::before {
        position: fixed;
        inset: 0;
        z-index: -1;
        content: "";
        background-image:
          linear-gradient(rgba(255, 255, 255, 0.024) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255, 255, 255, 0.018) 1px, transparent 1px);
        background-size: 64px 64px;
        mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.52), transparent 72%);
        pointer-events: none;
      }

      a {
        color: inherit;
      }

      h1,
      h2,
      h3,
      p {
        margin: 0;
      }

      .shell {
        width: min(1040px, calc(100% - 36px));
        margin: 0 auto;
        padding: 22px 0 64px;
      }

      .top-status {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 18px;
        margin-bottom: 28px;
        padding: 12px;
        border: 1px solid var(--line);
        border-radius: 12px;
        background: rgba(5, 5, 8, 0.82);
        box-shadow: var(--shadow-soft);
        backdrop-filter: blur(22px);
      }

      .brand {
        display: inline-flex;
        align-items: center;
        gap: 13px;
        min-width: 0;
      }

      .brand-logo {
        width: 58px;
        height: 58px;
        flex: 0 0 auto;
        border: 1px solid rgba(216, 194, 255, 0.34);
        border-radius: 12px;
        background: #08070b;
        box-shadow:
          inset 0 0 0 1px rgba(255, 255, 255, 0.05),
          0 0 32px rgba(169, 112, 255, 0.25);
        object-fit: cover;
      }

      .brand-text {
        display: grid;
        gap: 3px;
        min-width: 0;
      }

      .brand-title {
        color: var(--ink);
        font-size: 15px;
        font-weight: 820;
        line-height: 1.15;
        overflow-wrap: anywhere;
      }

      .brand-kicker,
      .muted {
        color: var(--quiet);
        font-size: 12px;
        font-weight: 680;
      }

      .status-actions,
      .actions,
      .card-actions {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 9px;
      }

      .status-actions {
        justify-content: flex-end;
      }

      .form-actions {
        margin-top: 14px;
      }

      .form-actions.tight {
        margin-top: 10px;
      }

      .connection-pill {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        min-height: 38px;
        border: 1px solid var(--line);
        border-radius: 999px;
        padding: 8px 13px;
        background: rgba(255, 255, 255, 0.045);
        color: var(--muted);
        font-size: 13px;
        font-weight: 760;
        white-space: nowrap;
      }

      .connection-pill::before,
      .badge::before {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        content: "";
      }

      .connection-pill.is-connected {
        border-color: rgba(110, 231, 242, 0.26);
        background: rgba(110, 231, 242, 0.08);
        color: #c8fbff;
      }

      .connection-pill.is-connected::before {
        background: var(--cyan);
        box-shadow: 0 0 16px rgba(110, 231, 242, 0.62);
      }

      .connection-pill.is-offline::before {
        background: var(--amber);
        box-shadow: 0 0 16px rgba(255, 209, 122, 0.38);
      }

      .creator-pill {
        display: inline-flex;
        align-items: center;
        gap: 9px;
        min-height: 38px;
        border: 1px solid var(--line);
        border-radius: 999px;
        padding: 5px 12px 5px 6px;
        background: rgba(255, 255, 255, 0.045);
      }

      .creator-avatar {
        width: 28px;
        height: 28px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.08);
        object-fit: cover;
      }

      .creator-name {
        display: grid;
        gap: 1px;
        min-width: 0;
      }

      .creator-name strong,
      .creator-name span {
        max-width: 180px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      .creator-name strong {
        color: var(--ink);
        font-size: 12px;
        line-height: 1.1;
      }

      .creator-name span {
        color: var(--muted);
        font-size: 11px;
      }

      .notice {
        margin-bottom: 18px;
        border: 1px solid rgba(169, 112, 255, 0.28);
        border-radius: 10px;
        padding: 12px 14px;
        background: rgba(169, 112, 255, 0.09);
        color: var(--ink);
      }

      .main-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.25fr) minmax(280px, 0.75fr);
        gap: 18px;
        align-items: start;
        margin-bottom: 28px;
      }

      .panel,
      .queue-card,
      .history-section {
        border: 1px solid var(--line);
        border-radius: 12px;
        background:
          linear-gradient(180deg, rgba(255, 255, 255, 0.036), transparent),
          var(--surface);
        box-shadow: var(--shadow);
        backdrop-filter: blur(18px);
      }

      .panel {
        padding: 22px;
      }

      .panel-head,
      .queue-head,
      .history-section summary {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
      }

      .panel-head,
      .queue-head {
        margin-bottom: 16px;
      }

      .panel-head h2,
      .queue-head h2 {
        color: var(--ink);
        font-size: 16px;
        line-height: 1.2;
        letter-spacing: 0;
      }

      .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
      }

      .form-grid .wide,
      .advanced {
        grid-column: 1 / -1;
      }

      label {
        display: grid;
        gap: 8px;
        color: var(--quiet);
        font-size: 11px;
        font-weight: 820;
        text-transform: uppercase;
      }

      input,
      select,
      textarea,
      button,
      .button {
        font: inherit;
      }

      input,
      select,
      textarea {
        width: 100%;
        border: 1px solid var(--line);
        border-radius: 10px;
        outline: none;
        background: var(--field);
        color: var(--ink);
        transition:
          border-color 160ms ease,
          background 160ms ease,
          box-shadow 160ms ease;
      }

      input {
        min-height: 44px;
        padding: 10px 12px;
      }

      select {
        min-height: 44px;
        padding: 10px 34px 10px 12px;
      }

      input[type="file"] {
        min-height: 56px;
        padding: 13px;
        color: var(--muted);
        background: rgba(255, 255, 255, 0.06);
      }

      input[type="file"]::file-selector-button {
        margin-right: 12px;
        border: 1px solid rgba(216, 194, 255, 0.28);
        border-radius: 9px;
        padding: 8px 11px;
        background: rgba(216, 194, 255, 0.11);
        color: var(--ink);
        cursor: pointer;
      }

      textarea {
        min-height: 88px;
        padding: 12px;
        resize: vertical;
      }

      input::placeholder,
      textarea::placeholder {
        color: #6f6878;
      }

      input:focus,
      select:focus,
      textarea:focus {
        border-color: rgba(169, 112, 255, 0.58);
        background: rgba(255, 255, 255, 0.075);
        box-shadow: 0 0 0 3px rgba(169, 112, 255, 0.13);
      }

      .field-note {
        color: var(--quiet);
        font-size: 12px;
        font-weight: 650;
        line-height: 1.35;
        text-transform: none;
      }

      button,
      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 42px;
        border: 1px solid transparent;
        border-radius: 10px;
        padding: 10px 15px;
        cursor: pointer;
        font-weight: 820;
        text-decoration: none;
        white-space: nowrap;
        transition:
          transform 160ms ease,
          border-color 160ms ease,
          background 160ms ease,
          color 160ms ease,
          box-shadow 160ms ease;
      }

      button:hover,
      .button:hover {
        transform: translateY(-1px);
      }

      button:focus-visible,
      .button:focus-visible {
        outline: 2px solid rgba(216, 194, 255, 0.82);
        outline-offset: 2px;
      }

      button:disabled {
        cursor: not-allowed;
        opacity: 0.5;
        transform: none;
      }

      .primary {
        background: linear-gradient(180deg, #e0cbff, var(--violet));
        color: #0a0712;
        box-shadow: 0 12px 26px rgba(169, 112, 255, 0.28);
      }

      .primary:hover {
        background: linear-gradient(180deg, #efe5ff, #b884ff);
        box-shadow: 0 14px 32px rgba(169, 112, 255, 0.36);
      }

      .secondary {
        border-color: var(--line);
        background: rgba(255, 255, 255, 0.048);
        color: var(--ink);
      }

      .secondary:hover {
        border-color: var(--line-strong);
        background: rgba(255, 255, 255, 0.082);
      }

      .danger {
        border-color: rgba(255, 146, 151, 0.34);
        background: rgba(255, 146, 151, 0.075);
        color: #ffc1c4;
      }

      .danger:hover {
        border-color: rgba(255, 146, 151, 0.58);
        background: rgba(255, 146, 151, 0.13);
      }

      .compact {
        min-height: 36px;
        padding: 8px 12px;
        font-size: 13px;
      }

      .inline-action {
        display: inline-flex;
        margin: 0;
      }

      .queue {
        display: grid;
        gap: 14px;
      }

      .queue-card {
        display: grid;
        grid-template-columns: 128px minmax(0, 1fr);
        gap: 18px;
        padding: 16px;
        background:
          linear-gradient(180deg, rgba(255, 255, 255, 0.036), transparent),
          var(--surface-strong);
      }

      .queue-card.is-history {
        grid-template-columns: 88px minmax(0, 1fr);
        padding: 12px;
        box-shadow: none;
      }

      .queue-thumb {
        position: relative;
        display: block;
        width: 100%;
        min-height: 156px;
        aspect-ratio: 4 / 5;
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 10px;
        background: #09090d;
      }

      .is-history .queue-thumb {
        min-height: 108px;
      }

      .queue-thumb [data-preview-media],
      .thumb-placeholder {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
      }

      .queue-thumb [data-preview-media] {
        display: block;
        object-fit: cover;
      }

      .thumb-placeholder {
        padding: 28px;
        object-fit: contain;
        opacity: 0;
        filter: saturate(0.8);
      }

      .queue-thumb.is-missing [data-preview-media] {
        display: none;
      }

      .queue-thumb.is-missing .thumb-placeholder {
        opacity: 0.56;
      }

      .media-chip {
        position: absolute;
        right: 9px;
        bottom: 9px;
        max-width: calc(100% - 18px);
        border: 1px solid rgba(216, 194, 255, 0.24);
        border-radius: 999px;
        padding: 5px 8px;
        background: rgba(5, 5, 7, 0.74);
        color: var(--violet-bright);
        font-size: 11px;
        font-weight: 820;
        backdrop-filter: blur(12px);
      }

      .queue-main {
        display: grid;
        gap: 12px;
        min-width: 0;
      }

      .queue-top {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 12px;
      }

      .queue-title {
        display: grid;
        gap: 6px;
        min-width: 0;
      }

      .queue-title h3 {
        color: var(--ink);
        font-size: 15px;
        line-height: 1.3;
        overflow-wrap: anywhere;
      }

      .queue-time,
      .caption-preview {
        color: var(--muted);
        font-size: 13px;
        line-height: 1.45;
      }

      .caption-preview {
        display: -webkit-box;
        overflow: hidden;
        -webkit-box-orient: vertical;
        -webkit-line-clamp: 2;
      }

      .badge {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        width: max-content;
        min-height: 28px;
        border: 1px solid var(--line);
        border-radius: 999px;
        padding: 5px 10px;
        background: rgba(255, 255, 255, 0.045);
        color: var(--muted);
        font-size: 12px;
        font-weight: 820;
        white-space: nowrap;
      }

      .badge::before {
        background: var(--quiet);
      }

      .badge.pending,
      .badge.scheduled {
        border-color: rgba(255, 209, 122, 0.26);
        color: #ffe2a2;
      }

      .badge.pending::before,
      .badge.scheduled::before {
        background: var(--amber);
      }

      .badge.ready,
      .badge.verification {
        border-color: rgba(216, 194, 255, 0.34);
        color: var(--violet-bright);
      }

      .badge.ready::before,
      .badge.verification::before {
        background: var(--violet);
        box-shadow: 0 0 14px rgba(169, 112, 255, 0.5);
      }

      .badge.posted,
      .badge.accepted {
        border-color: rgba(157, 232, 195, 0.28);
        color: #c5f5dc;
      }

      .badge.posted::before,
      .badge.accepted::before {
        background: var(--green);
      }

      .badge.publishing {
        border-color: rgba(110, 231, 242, 0.3);
        color: #c8fbff;
      }

      .badge.publishing::before {
        background: var(--cyan);
        box-shadow: 0 0 14px rgba(110, 231, 242, 0.5);
      }

      .badge.failed {
        border-color: rgba(255, 146, 151, 0.42);
        color: #ffc1c4;
      }

      .badge.failed::before {
        background: var(--red);
      }

      .schedule-form {
        display: grid;
        gap: 12px;
      }

      .schedule-row {
        display: grid;
        grid-template-columns: minmax(210px, 1fr) minmax(150px, 0.48fr) auto;
        gap: 12px;
        align-items: end;
      }

      .card-actions {
        padding-top: 2px;
      }

      .advanced,
      .history-section {
        margin-top: 14px;
      }

      .advanced summary,
      .history-section summary {
        cursor: pointer;
        color: var(--muted);
        font-size: 12px;
        font-weight: 820;
        text-transform: uppercase;
      }

      .advanced-body {
        display: grid;
        gap: 12px;
        margin-top: 12px;
      }

      .advanced pre {
        max-height: 220px;
        overflow: auto;
        margin: 0;
        border: 1px solid rgba(255, 255, 255, 0.075);
        border-radius: 10px;
        padding: 12px;
        background: rgba(0, 0, 0, 0.28);
        color: #dfd7ee;
        font-size: 12px;
        line-height: 1.5;
        white-space: pre-wrap;
        overflow-wrap: anywhere;
      }

      .history-section {
        padding: 14px;
      }

      .history-list {
        display: grid;
        gap: 10px;
        margin-top: 14px;
      }

      .history-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
      }

      .empty,
      .history-empty {
        display: grid;
        min-height: 150px;
        place-items: center;
        border: 1px dashed var(--line-strong);
        border-radius: 12px;
        background: rgba(255, 255, 255, 0.025);
        color: var(--quiet);
        text-align: center;
      }

      .history-empty {
        min-height: 90px;
      }

      .copy-cache {
        position: absolute;
        width: 1px;
        height: 1px;
        opacity: 0;
        pointer-events: none;
      }

      @media (max-width: 860px) {
        .main-grid,
        .queue-card,
        .queue-card.is-history,
        .schedule-row {
          grid-template-columns: 1fr;
        }

        .queue-thumb {
          min-height: 220px;
          aspect-ratio: 16 / 10;
        }
      }

      @media (max-width: 640px) {
        .shell {
          width: min(100% - 22px, 1040px);
          padding-top: 12px;
        }

        .top-status {
          align-items: flex-start;
          flex-direction: column;
        }

        .status-actions {
          justify-content: flex-start;
          width: 100%;
        }

        .connection-pill {
          white-space: normal;
        }

        .brand-logo {
          width: 50px;
          height: 50px;
        }

        .form-grid {
          grid-template-columns: 1fr;
        }

        .actions .button,
        .actions button,
        .card-actions .button,
        .card-actions button,
        .history-actions button,
        .inline-action,
        .schedule-row button {
          width: 100%;
        }

        .queue-top {
          align-items: flex-start;
          flex-direction: column;
        }
      }
    </style>
  </head>
  <body>
    <main class="shell">
      <%
        const statusOf = (post) => String((post && post.status) || 'pending').toLowerCase();
        const activePosts = posts.filter((post) => statusOf(post) !== 'posted');
        const historyPosts = posts.filter((post) => statusOf(post) === 'posted');
        const privacyOptions = Array.isArray(creatorInfo && creatorInfo.privacy_level_options) && creatorInfo.privacy_level_options.length > 0
          ? creatorInfo.privacy_level_options
          : ['SELF_ONLY'];
        const displayResultLabel = (result) => {
          const tone = String((result && result.tone) || '').toLowerCase();
          const label = String((result && result.stateLabel) || '').toLowerCase();

          if (tone === 'failed' || label.includes('failed')) return 'Failed';
          if (tone === 'verification' || label.includes('verification')) return 'Needs verification';
          if (tone === 'accepted' || label.includes('posted') || label.includes('accepted')) return 'Posted / API accepted';
          if (tone === 'publishing' || label.includes('publishing')) return 'Publishing';
          return 'Scheduled';
        };
        const captionPreview = (post) => helpers.fullCaption(post) || 'No caption';
        const selectedPrivacy = (post) => {
          const value = String((post && post.privacyLevel) || 'SELF_ONLY').trim() || 'SELF_ONLY';
          return privacyOptions.includes(value) ? value : privacyOptions[0];
        };
      %>

      <header class="top-status">
        <div class="brand">
          <img class="brand-logo" src="/assets/chanter-logo.png" alt="CHANTER logo" />
          <span class="brand-text">
            <span class="brand-title">CHANTER Auto Poster</span>
            <span class="brand-kicker">TikTok poster</span>
          </span>
        </div>
        <div class="status-actions">
          <div class="connection-pill <%= tiktokConfigured ? 'is-connected' : 'is-offline' %>"><%- tiktokConfigured ? 'TikTok Connected' : 'Manual Mode &middot; TikTok not connected' %></div>
          <% if (tiktokConfigured && creatorInfo) { %>
            <div class="creator-pill">
              <img class="creator-avatar" src="<%= creatorInfo.creator_avatar_url || '/assets/chanter-logo.png' %>" alt="" />
              <span class="creator-name">
                <strong><%= creatorInfo.creator_username ? `@${creatorInfo.creator_username}` : (creatorInfo.creator_nickname || 'TikTok creator') %></strong>
              </span>
            </div>
          <% } %>
          <% if (tiktokConfigured) { %>
            <a class="button secondary compact" href="/disconnect/tiktok">Disconnect</a>
          <% } else { %>
            <a class="button primary compact" href="/connect/tiktok">Connect TikTok</a>
          <% } %>
        </div>
      </header>

      <% if (notice) { %>
        <div class="notice"><%= notice %></div>
      <% } %>

      <section class="main-grid" aria-label="Poster controls">
        <article class="panel">
          <div class="panel-head">
            <h2>Upload</h2>
          </div>
          <form action="/upload" method="post" enctype="multipart/form-data" data-upload-form>
            <div class="form-grid">
              <label class="wide">
                Media
                <input type="file" name="images" accept="image/*,video/mp4,video/quicktime,video/webm,video/*" multiple required data-media-upload />
              </label>
              <label>
                Caption
                <textarea name="caption" placeholder="Caption"></textarea>
              </label>
              <label>
                Hashtags
                <textarea name="hashtags" placeholder="#chanter"></textarea>
              </label>
            </div>
            <div class="actions form-actions">
              <button type="submit" class="primary">Upload</button>
            </div>
          </form>
        </article>

        <article class="panel">
          <div class="panel-head">
            <h2>Schedule</h2>
            <span class="muted"><%= settings.dailyPostTime %></span>
          </div>
          <form action="/settings" method="post">
            <label>
              Daily time
              <input type="time" name="dailyPostTime" value="<%= settings.dailyPostTime %>" required />
            </label>
            <div class="actions form-actions">
              <button type="submit" class="primary">Save schedule</button>
            </div>
          </form>
          <form action="/schedule" method="post">
            <div class="actions form-actions tight">
              <button type="submit" class="secondary">Rebuild queue</button>
            </div>
          </form>
        </article>
      </section>

      <section aria-label="Queue">
        <div class="queue-head">
          <h2>Queue</h2>
          <span class="muted"><%= activePosts.length %> active</span>
        </div>

        <div class="queue">
          <% if (activePosts.length === 0) { %>
            <div class="empty">Queue empty</div>
          <% } %>

          <% activePosts.forEach(function(post) { %>
            <% const mediaPath = helpers.mediaPath(post); %>
            <% const mediaType = helpers.mediaType(post); %>
            <% const result = helpers.postResult(post); %>
            <article class="queue-card" data-post-card>
              <% if (mediaPath) { %>
                <a class="queue-thumb" href="<%= mediaPath %>" target="_blank" rel="noreferrer">
                  <img class="thumb-placeholder" src="/assets/chanter-logo.png" alt="" />
                  <% if (mediaType === 'video') { %>
                    <video src="<%= mediaPath %>" muted playsinline preload="metadata" data-preview-media></video>
                  <% } else { %>
                    <img src="<%= mediaPath %>" alt="<%= post.originalName %>" loading="lazy" data-preview-media />
                  <% } %>
                  <span class="media-chip"><%= helpers.mediaLabel(post) %></span>
                </a>
              <% } else { %>
                <div class="queue-thumb is-missing">
                  <img class="thumb-placeholder" src="/assets/chanter-logo.png" alt="" />
                  <span class="media-chip"><%= helpers.mediaLabel(post) %></span>
                </div>
              <% } %>

              <div class="queue-main">
                <header class="queue-top">
                  <div class="queue-title">
                    <h3><%= post.originalName %></h3>
                    <p class="queue-time"><%= helpers.formatDateTime(post.scheduledAt) %></p>
                  </div>
                  <span class="badge <%= result.tone %>" data-result-badge><%= displayResultLabel(result) %></span>
                </header>

                <p class="caption-preview"><%= captionPreview(post) %></p>

                <form
                  class="schedule-form"
                  action="/posts/<%= post.id %>"
                  method="post"
                  data-edit-form
                  data-media-type="<%= mediaType %>"
                  data-has-local-media="<%= helpers.hasLocalMedia(post) ? 'true' : 'false' %>"
                >
                  <input type="hidden" name="caption" value="<%= post.caption || '' %>" />
                  <input type="hidden" name="hashtags" value="<%= post.hashtags || '' %>" />
                  <input type="hidden" name="timezoneOffsetMinutes" data-timezone-offset />
                  <div class="schedule-row">
                    <label>
                      Date
                      <span class="field-note">Publishes automatically at this time.</span>
                      <span class="field-note">Uses your local time.</span>
                      <input type="datetime-local" name="scheduledAt" value="<%= helpers.dateTimeInput(post.scheduledAt) %>" />
                    </label>
                    <label>
                      Privacy
                      <select name="privacyLevel">
                        <% privacyOptions.forEach(function(option) { %>
                          <option value="<%= option %>" <%= selectedPrivacy(post) === option ? 'selected' : '' %>><%= option %></option>
                        <% }); %>
                      </select>
                    </label>
                    <button type="submit" class="primary">Save schedule</button>
                  </div>
                  <details class="advanced">
                    <summary>Advanced</summary>
                    <div class="advanced-body">
                      <label>
                        Public image URL
                        <input
                          type="url"
                          name="publicImageUrl"
                          value="<%= post.publicImageUrl || '' %>"
                          placeholder="<%= mediaType === 'video' ? 'Not required for video posts' : 'https://chanterr.com/media/tiktok-posts/test-image.png' %>"
                          data-public-image-url
                        />
                      </label>
                      <% if (result.hasDebug) { %>
                        <pre><%= result.debugJson %></pre>
                      <% } %>
                    </div>
                  </details>
                </form>

                <div class="card-actions">
                  <form class="inline-action" action="/posts/<%= post.id %>/prepare" method="post" data-publish-form onsubmit="return confirm('Post now? This ignores the schedule.');">
                    <input type="hidden" name="force" value="1" />
                    <button type="submit" class="secondary">Post now</button>
                  </form>
                  <form class="inline-action" action="/posts/<%= post.id %>/delete" method="post">
                    <button type="submit" class="danger">Delete</button>
                  </form>
                </div>
              </div>
            </article>
          <% }); %>
        </div>

        <details class="history-section">
          <summary>
            <span>History</span>
            <span class="muted"><%= historyPosts.length %> posted</span>
          </summary>
          <div class="history-list">
            <% if (historyPosts.length === 0) { %>
              <div class="history-empty">No posted history</div>
            <% } %>

            <% historyPosts.forEach(function(post) { %>
              <% const mediaPath = helpers.mediaPath(post); %>
              <% const mediaType = helpers.mediaType(post); %>
              <% const result = helpers.postResult(post); %>
              <article class="queue-card is-history">
                <% if (mediaPath) { %>
                  <a class="queue-thumb" href="<%= mediaPath %>" target="_blank" rel="noreferrer">
                    <img class="thumb-placeholder" src="/assets/chanter-logo.png" alt="" />
                    <% if (mediaType === 'video') { %>
                      <video src="<%= mediaPath %>" muted playsinline preload="metadata" data-preview-media></video>
                    <% } else { %>
                      <img src="<%= mediaPath %>" alt="<%= post.originalName %>" loading="lazy" data-preview-media />
                    <% } %>
                    <span class="media-chip"><%= helpers.mediaLabel(post) %></span>
                  </a>
                <% } else { %>
                  <div class="queue-thumb is-missing">
                    <img class="thumb-placeholder" src="/assets/chanter-logo.png" alt="" />
                    <span class="media-chip"><%= helpers.mediaLabel(post) %></span>
                  </div>
                <% } %>

                <div class="queue-main">
                  <header class="queue-top">
                    <div class="queue-title">
                      <h3><%= post.originalName %></h3>
                      <p class="queue-time"><%= helpers.formatDateTime(post.postedAt || post.scheduledAt) %></p>
                    </div>
                    <span class="badge <%= result.tone %>"><%= displayResultLabel(result) %></span>
                  </header>
                  <p class="caption-preview"><%= captionPreview(post) %></p>
                  <div class="history-actions">
                    <form class="inline-action" action="/posts/<%= post.id %>/delete" method="post">
                      <button type="submit" class="danger">Remove from history</button>
                    </form>
                  </div>
                  <% if (result.hasDebug) { %>
                    <details class="advanced">
                      <summary>Advanced</summary>
                      <div class="advanced-body">
                        <pre><%= result.debugJson %></pre>
                      </div>
                    </details>
                  <% } %>
                </div>
              </article>
            <% }); %>
          </div>
        </details>
      </section>
    </main>

    <script>
      function copyText(value) {
        if (navigator.clipboard && window.isSecureContext) {
          return navigator.clipboard.writeText(value);
        }

        const fallback = document.createElement('textarea');
        fallback.value = value;
        fallback.setAttribute('readonly', '');
        fallback.style.position = 'fixed';
        fallback.style.opacity = '0';
        document.body.appendChild(fallback);
        fallback.select();
        document.execCommand('copy');
        fallback.remove();
        return Promise.resolve();
      }

      document.querySelectorAll('.copy-button').forEach((button) => {
        button.addEventListener('click', async () => {
          const target = document.getElementById(button.dataset.target);
          if (!target) return;

          await copyText(target.value);
          const originalText = button.textContent;
          button.textContent = 'Copied';
          window.setTimeout(() => {
            button.textContent = originalText;
          }, 1200);
        });
      });

      function getFileKind(file) {
        const type = String(file.type || '').toLowerCase();
        const name = String(file.name || '').toLowerCase();

        if (type.startsWith('image/')) return 'photo';
        if (type.startsWith('video/')) return 'video';
        if (/\.(png|jpe?g|webp|gif)$/i.test(name)) return 'photo';
        if (/\.(mp4|mov|webm)$/i.test(name)) return 'video';
        return '';
      }

      document.querySelectorAll('[data-upload-form]').forEach((form) => {
        const input = form.querySelector('[data-media-upload]');
        if (!input) return;

        const validateUpload = () => {
          const files = Array.from(input.files || []);
          let message = '';

          if (files.length === 0) {
            message = 'Choose at least one image or video file.';
          } else if (files.some((file) => !getFileKind(file))) {
            message = 'Use image files or MP4, MOV, or WebM video files.';
          }

          input.setCustomValidity(message);
          return !message;
        };

        input.addEventListener('change', validateUpload);
        form.addEventListener('submit', (event) => {
          if (!validateUpload()) {
            event.preventDefault();
            input.reportValidity();
          }
        });
      });

      document.querySelectorAll('[data-timezone-offset]').forEach((input) => {
        input.value = String(new Date().getTimezoneOffset());
      });

      document.querySelectorAll('[data-edit-form]').forEach((form) => {
        const input = form.querySelector('[data-public-image-url]');
        if (!input) return;

        const validatePostMedia = () => {
          const mediaType = form.dataset.mediaType;
          const hasLocalMedia = form.dataset.hasLocalMedia === 'true';
          const hasPublicImageUrl = input.value.trim().length > 0;
          const missingPhotoSource = mediaType === 'photo' && !hasLocalMedia && !hasPublicImageUrl;

          input.setCustomValidity(missingPhotoSource ? 'Add an image file or public image URL for photo posts.' : '');
          return !missingPhotoSource;
        };

        input.addEventListener('input', validatePostMedia);
        form.addEventListener('submit', (event) => {
          if (!validatePostMedia()) {
            event.preventDefault();
            input.reportValidity();
          }
        });
      });

      document.querySelectorAll('[data-publish-form]').forEach((form) => {
        form.addEventListener('submit', () => {
          const card = form.closest('[data-post-card]');
          const badge = card ? card.querySelector('[data-result-badge]') : null;
          const button = form.querySelector('button');

          if (button) {
            button.disabled = true;
            button.textContent = 'Publishing';
          }

          if (badge) {
            badge.className = 'badge publishing';
            badge.textContent = 'Publishing';
          }
        });
      });

      document.querySelectorAll('[data-preview-media]').forEach((media) => {
        const markMissing = () => {
          const thumb = media.closest('.queue-thumb');
          if (thumb) thumb.classList.add('is-missing');
        };

        media.addEventListener('error', markMissing);

        if (media.tagName === 'IMG' && media.complete && media.naturalWidth === 0) {
          markMissing();
        }
      });
    </script>
  </body>
</html>
