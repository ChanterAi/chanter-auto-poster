<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= appName %></title>
    <style>
      :root {
        color-scheme: dark;
        --bg: #050507;
        --surface: rgba(12, 12, 17, 0.9);
        --surface-strong: rgba(17, 17, 24, 0.94);
        --surface-soft: rgba(255, 255, 255, 0.035);
        --field: rgba(255, 255, 255, 0.055);
        --ink: #f7f2ff;
        --text: #e9e2f4;
        --muted: #a79db5;
        --quiet: #756e82;
        --line: rgba(221, 207, 255, 0.12);
        --line-strong: rgba(221, 207, 255, 0.22);
        --violet: #a970ff;
        --violet-bright: #d7c0ff;
        --violet-soft: rgba(169, 112, 255, 0.14);
        --cyan: #6ee7f2;
        --green: #9de8c3;
        --amber: #ffd17a;
        --red: #ff9297;
        --shadow: 0 22px 70px rgba(0, 0, 0, 0.52);
        --shadow-soft: 0 14px 36px rgba(0, 0, 0, 0.34);
      }

      * {
        box-sizing: border-box;
      }

      html {
        background: var(--bg);
      }

      body {
        min-height: 100vh;
        margin: 0;
        background:
          linear-gradient(180deg, rgba(169, 112, 255, 0.12), rgba(5, 5, 7, 0) 330px),
          linear-gradient(135deg, rgba(255, 255, 255, 0.028), transparent 42%, rgba(110, 231, 242, 0.025)),
          var(--bg);
        color: var(--text);
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      }

      body::before {
        position: fixed;
        inset: 0;
        z-index: -1;
        content: "";
        background-image:
          linear-gradient(rgba(255, 255, 255, 0.028) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255, 255, 255, 0.022) 1px, transparent 1px);
        background-size: 54px 54px;
        mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.55), transparent 66%);
        pointer-events: none;
      }

      a {
        color: inherit;
      }

      h1,
      h2,
      h3,
      p {
        margin: 0;
      }

      .shell {
        width: min(1180px, calc(100% - 32px));
        margin: 0 auto;
        padding: 20px 0 56px;
      }

      .top-status {
        position: sticky;
        top: 12px;
        z-index: 5;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        min-height: 68px;
        margin: 0 0 20px;
        padding: 10px 12px;
        border: 1px solid var(--line);
        border-radius: 8px;
        background: rgba(7, 7, 11, 0.82);
        box-shadow: var(--shadow-soft);
        backdrop-filter: blur(22px);
      }

      .brand {
        display: inline-flex;
        align-items: center;
        gap: 12px;
        min-width: 0;
        font-weight: 780;
        letter-spacing: 0;
      }

      .brand-logo {
        width: 46px;
        height: 46px;
        flex: 0 0 auto;
        border: 1px solid rgba(215, 192, 255, 0.34);
        border-radius: 8px;
        background: #09080d;
        box-shadow:
          inset 0 0 0 1px rgba(255, 255, 255, 0.05),
          0 0 24px rgba(169, 112, 255, 0.24);
        object-fit: cover;
      }

      .brand-text {
        display: grid;
        gap: 2px;
        min-width: 0;
      }

      .brand-title {
        color: var(--ink);
        font-size: 15px;
        line-height: 1.15;
        overflow-wrap: anywhere;
      }

      .brand-kicker {
        color: var(--quiet);
        font-size: 12px;
        font-weight: 650;
      }

      .status-actions {
        display: inline-flex;
        align-items: center;
        justify-content: flex-end;
        gap: 8px;
        flex-wrap: wrap;
      }

      .connection-pill {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        min-height: 36px;
        padding: 8px 12px;
        border: 1px solid var(--line);
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.045);
        color: var(--muted);
        font-size: 13px;
        font-weight: 700;
        white-space: nowrap;
      }

      .connection-pill::before,
      .badge::before {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        content: "";
      }

      .connection-pill.is-connected {
        border-color: rgba(110, 231, 242, 0.26);
        background: rgba(110, 231, 242, 0.08);
        color: #c8fbff;
      }

      .connection-pill.is-connected::before {
        background: var(--cyan);
        box-shadow: 0 0 16px rgba(110, 231, 242, 0.62);
      }

      .connection-pill.is-offline::before {
        background: var(--amber);
        box-shadow: 0 0 16px rgba(255, 209, 122, 0.38);
      }

      .notice {
        margin-bottom: 16px;
        padding: 12px 14px;
        border: 1px solid rgba(169, 112, 255, 0.28);
        border-radius: 8px;
        background: rgba(169, 112, 255, 0.1);
        color: var(--ink);
        box-shadow: var(--shadow-soft);
      }

      .overview {
        display: grid;
        grid-template-columns: minmax(0, 1.42fr) minmax(270px, 0.58fr);
        gap: 16px;
        align-items: stretch;
        margin-bottom: 16px;
      }

      .panel,
      .today-card,
      .queue-card,
      .metrics {
        border: 1px solid var(--line);
        border-radius: 8px;
        background: var(--surface);
        box-shadow: var(--shadow);
        backdrop-filter: blur(18px);
      }

      .today-card {
        min-height: 312px;
        overflow: hidden;
      }

      .section-head,
      .panel-head,
      .queue-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
      }

      .section-head {
        padding: 18px 18px 0;
      }

      .section-head h1,
      .section-head h2,
      .panel-head h2,
      .queue-head h2 {
        color: var(--ink);
        font-size: 16px;
        line-height: 1.2;
        letter-spacing: 0;
      }

      .muted {
        color: var(--muted);
        font-size: 13px;
      }

      .today-content {
        display: grid;
        grid-template-columns: 252px 1fr;
        gap: 20px;
        min-height: 262px;
        padding: 18px;
      }

      .today-art,
      .queue-thumb {
        position: relative;
        display: block;
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 8px;
        background: #09090d;
      }

      .today-art {
        aspect-ratio: 4 / 5;
        box-shadow: 0 18px 38px rgba(0, 0, 0, 0.38);
      }

      .today-art img,
      .queue-thumb img {
        width: 100%;
        height: 100%;
        display: block;
        object-fit: cover;
      }

      .today-info {
        display: flex;
        flex-direction: column;
        justify-content: center;
        min-width: 0;
        padding: 6px 2px;
      }

      .today-info h2 {
        max-width: 540px;
        margin-top: 10px;
        color: var(--ink);
        font-size: 34px;
        line-height: 1.05;
        letter-spacing: 0;
        overflow-wrap: anywhere;
      }

      .caption-preview {
        max-width: 600px;
        margin-top: 14px;
        color: var(--muted);
        line-height: 1.55;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }

      .empty-today {
        display: grid;
        min-height: 256px;
        place-items: center;
        padding: 28px;
        text-align: center;
      }

      .empty-today-inner {
        display: grid;
        justify-items: center;
        gap: 10px;
        max-width: 360px;
      }

      .empty-logo {
        width: 72px;
        height: 72px;
        border: 1px solid rgba(215, 192, 255, 0.2);
        border-radius: 8px;
        opacity: 0.74;
        object-fit: cover;
        box-shadow: 0 0 34px rgba(169, 112, 255, 0.2);
      }

      .empty-today h2 {
        color: var(--ink);
        font-size: 22px;
        letter-spacing: 0;
      }

      .empty-today p {
        color: var(--quiet);
        font-size: 14px;
        line-height: 1.45;
      }

      .metrics {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1px;
        overflow: hidden;
        background: var(--line);
      }

      .metric {
        min-height: 104px;
        padding: 18px;
        background: rgba(13, 13, 19, 0.96);
      }

      .metric:first-child {
        grid-column: 1 / -1;
        min-height: 112px;
        background:
          linear-gradient(135deg, rgba(169, 112, 255, 0.18), rgba(255, 255, 255, 0.035)),
          rgba(13, 13, 19, 0.96);
      }

      .metric strong {
        display: block;
        color: var(--ink);
        font-size: 30px;
        line-height: 1;
      }

      .metric span {
        display: block;
        margin-top: 9px;
        color: var(--quiet);
        font-size: 11px;
        font-weight: 800;
        text-transform: uppercase;
      }

      .metric[data-tone="pending"] strong {
        color: var(--amber);
      }

      .metric[data-tone="ready"] strong {
        color: var(--violet-bright);
      }

      .metric[data-tone="posted"] strong {
        color: var(--green);
      }

      .metric[data-tone="failed"] strong {
        color: var(--red);
      }

      .control-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.42fr) minmax(270px, 0.58fr);
        gap: 16px;
        align-items: start;
        margin-bottom: 28px;
      }

      .panel {
        padding: 18px;
        background:
          linear-gradient(180deg, rgba(255, 255, 255, 0.035), transparent),
          var(--surface);
      }

      .panel-head {
        margin-bottom: 16px;
      }

      .panel-head .muted {
        color: var(--violet-bright);
      }

      .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
      }

      .form-grid .wide {
        grid-column: 1 / -1;
      }

      label {
        display: grid;
        gap: 8px;
        color: var(--quiet);
        font-size: 11px;
        font-weight: 780;
        text-transform: uppercase;
      }

      input,
      textarea,
      button,
      .button {
        font: inherit;
      }

      input,
      textarea {
        width: 100%;
        border: 1px solid var(--line);
        border-radius: 8px;
        outline: none;
        background: var(--field);
        color: var(--ink);
        transition:
          border-color 160ms ease,
          background 160ms ease,
          box-shadow 160ms ease;
      }

      input {
        min-height: 44px;
        padding: 10px 12px;
      }

      input[type="file"] {
        min-height: 54px;
        padding: 13px;
        color: var(--muted);
        background:
          linear-gradient(135deg, rgba(169, 112, 255, 0.12), rgba(255, 255, 255, 0.035)),
          var(--field);
      }

      input[type="file"]::file-selector-button {
        margin-right: 12px;
        border: 1px solid rgba(215, 192, 255, 0.28);
        border-radius: 8px;
        padding: 8px 11px;
        background: rgba(215, 192, 255, 0.1);
        color: var(--ink);
        cursor: pointer;
      }

      textarea {
        min-height: 94px;
        padding: 12px;
        resize: vertical;
      }

      input::placeholder,
      textarea::placeholder {
        color: #6d6678;
      }

      input:focus,
      textarea:focus {
        border-color: rgba(169, 112, 255, 0.56);
        background: rgba(255, 255, 255, 0.075);
        box-shadow: 0 0 0 3px rgba(169, 112, 255, 0.14);
      }

      .actions,
      .card-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
      }

      .actions {
        margin-top: 14px;
      }

      .inline-action {
        display: inline-flex;
        margin: 0;
      }

      button,
      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 40px;
        border: 1px solid transparent;
        border-radius: 8px;
        padding: 9px 14px;
        cursor: pointer;
        font-weight: 760;
        text-decoration: none;
        white-space: nowrap;
        transition:
          transform 160ms ease,
          border-color 160ms ease,
          background 160ms ease,
          color 160ms ease,
          box-shadow 160ms ease;
      }

      button:hover,
      .button:hover {
        transform: translateY(-1px);
      }

      button:focus-visible,
      .button:focus-visible {
        outline: 2px solid rgba(215, 192, 255, 0.8);
        outline-offset: 2px;
      }

      .primary {
        background: linear-gradient(180deg, #d8c2ff, var(--violet));
        color: #0b0714;
        box-shadow: 0 10px 24px rgba(169, 112, 255, 0.28);
      }

      .primary:hover {
        background: linear-gradient(180deg, #eadfff, #b481ff);
        box-shadow: 0 12px 30px rgba(169, 112, 255, 0.36);
      }

      .secondary {
        border-color: var(--line);
        background: rgba(255, 255, 255, 0.05);
        color: var(--ink);
      }

      .secondary:hover {
        border-color: var(--line-strong);
        background: rgba(255, 255, 255, 0.085);
      }

      .compact {
        min-height: 36px;
        padding: 8px 12px;
        font-size: 13px;
      }

      .danger {
        border-color: rgba(255, 146, 151, 0.35);
        background: rgba(255, 146, 151, 0.08);
        color: #ffc1c4;
      }

      .danger:hover {
        border-color: rgba(255, 146, 151, 0.58);
        background: rgba(255, 146, 151, 0.14);
      }

      .badge {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        width: max-content;
        min-height: 28px;
        border: 1px solid var(--line);
        border-radius: 999px;
        padding: 5px 10px;
        background: rgba(255, 255, 255, 0.045);
        color: var(--muted);
        font-size: 12px;
        font-weight: 800;
      }

      .badge::before {
        background: var(--quiet);
      }

      .badge.pending {
        border-color: rgba(255, 209, 122, 0.28);
        color: #ffe2a2;
      }

      .badge.pending::before {
        background: var(--amber);
      }

      .badge.ready {
        border-color: rgba(215, 192, 255, 0.34);
        color: var(--violet-bright);
      }

      .badge.ready::before {
        background: var(--violet);
        box-shadow: 0 0 14px rgba(169, 112, 255, 0.5);
      }

      .badge.posted {
        border-color: rgba(157, 232, 195, 0.3);
        color: #c5f5dc;
      }

      .badge.posted::before {
        background: var(--green);
      }

      .badge.failed {
        border-color: rgba(255, 146, 151, 0.42);
        color: #ffc1c4;
      }

      .badge.failed::before {
        background: var(--red);
      }

      .queue-head {
        margin-bottom: 12px;
        padding: 0 2px;
      }

      .queue {
        display: grid;
        gap: 12px;
      }

      .queue-card {
        display: grid;
        grid-template-columns: 152px 1fr;
        gap: 16px;
        padding: 12px;
        background:
          linear-gradient(180deg, rgba(255, 255, 255, 0.032), transparent),
          var(--surface-strong);
      }

      .queue-thumb {
        aspect-ratio: 4 / 5;
        min-height: 182px;
      }

      .queue-main {
        min-width: 0;
        padding: 4px 2px 2px 0;
      }

      .queue-top {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 14px;
      }

      .queue-title {
        min-width: 0;
      }

      .queue-title h3 {
        max-width: 660px;
        color: var(--ink);
        font-size: 15px;
        line-height: 1.3;
        overflow-wrap: anywhere;
      }

      .queue-index,
      .queue-time {
        color: var(--quiet);
        font-size: 12px;
      }

      .queue-index {
        margin-bottom: 3px;
        font-weight: 780;
      }

      .queue-time {
        margin-top: 5px;
      }

      .edit-grid {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(0, 1fr) 210px 96px;
        gap: 10px;
        align-items: end;
      }

      .edit-grid textarea {
        min-height: 78px;
      }

      .save-slot {
        display: flex;
        align-items: flex-end;
        height: 100%;
      }

      .save-slot .primary {
        width: 100%;
      }

      .public-url-field {
        grid-column: 1 / 4;
      }

      .ready-strip {
        margin-top: 12px;
        padding: 12px;
        border: 1px solid rgba(215, 192, 255, 0.2);
        border-radius: 8px;
        background: rgba(169, 112, 255, 0.075);
      }

      .ready-strip strong {
        display: block;
        margin-bottom: 8px;
        color: var(--violet-bright);
        font-size: 13px;
      }

      .caption-copy {
        min-height: 76px;
        color: var(--muted);
      }

      .copy-cache {
        position: absolute;
        width: 1px;
        height: 1px;
        opacity: 0;
        pointer-events: none;
      }

      .card-actions {
        margin-top: 12px;
        padding-top: 12px;
        border-top: 1px solid var(--line);
      }

      .empty {
        display: grid;
        min-height: 190px;
        place-items: center;
        border: 1px dashed var(--line-strong);
        border-radius: 8px;
        background: rgba(255, 255, 255, 0.025);
        color: var(--quiet);
      }

      @media (max-width: 980px) {
        .overview,
        .control-grid,
        .today-content,
        .queue-card,
        .edit-grid {
          grid-template-columns: 1fr;
        }

        .metrics {
          grid-template-columns: repeat(5, minmax(0, 1fr));
        }

        .metric:first-child {
          grid-column: auto;
        }

        .today-art {
          max-height: 430px;
        }

        .queue-thumb {
          max-height: 370px;
        }

        .public-url-field {
          grid-column: auto;
        }

        .save-slot .primary {
          width: auto;
        }
      }

      @media (max-width: 700px) {
        .shell {
          width: min(100% - 22px, 1180px);
          padding-top: 12px;
        }

        .top-status {
          top: 8px;
          align-items: flex-start;
          flex-direction: column;
        }

        .connection-pill {
          white-space: normal;
        }

        .status-actions {
          justify-content: flex-start;
          width: 100%;
        }

        .brand-logo {
          width: 42px;
          height: 42px;
        }

        .metrics,
        .form-grid {
          grid-template-columns: 1fr;
        }

        .today-info h2 {
          font-size: 28px;
        }

        .queue-top {
          align-items: flex-start;
          flex-direction: column;
        }

        .actions .button,
        .actions button,
        .card-actions .button,
        .card-actions button,
        .inline-action {
          width: 100%;
        }
      }
    </style>
  </head>
  <body>
    <main class="shell">
      <header class="top-status">
        <div class="brand">
          <img class="brand-logo" src="/uploads/chanter_logo_1024x1024.png" alt="CHANTER logo" />
          <span class="brand-text">
            <span class="brand-title"><%= appName %></span>
            <span class="brand-kicker">TikTok queue dashboard</span>
          </span>
        </div>
        <div class="status-actions">
          <div class="connection-pill <%= tiktokConfigured ? 'is-connected' : 'is-offline' %>"><%- tiktokConfigured ? 'TikTok Connected' : 'Manual Mode &middot; TikTok not connected' %></div>
          <% if (tiktokConfigured) { %>
            <a class="button secondary compact" href="/disconnect/tiktok">Disconnect</a>
          <% } else { %>
            <a class="button primary compact" href="/connect/tiktok">Connect TikTok</a>
          <% } %>
        </div>
      </header>

      <% if (notice) { %>
        <div class="notice"><%= notice %></div>
      <% } %>

      <section class="overview">
        <article class="today-card">
          <div class="section-head">
            <h1>Today's post</h1>
            <% if (todayPost) { %>
              <span class="badge <%= todayPost.status %>"><%= helpers.statusLabel(todayPost.status) %></span>
            <% } %>
          </div>

          <% if (todayPost) { %>
            <div class="today-content">
              <a class="today-art" href="<%= todayPost.imagePath %>" target="_blank" rel="noreferrer">
                <img src="<%= todayPost.imagePath %>" alt="<%= todayPost.originalName %>" />
              </a>
              <div class="today-info">
                <p class="muted"><%= helpers.formatTime(todayPost.scheduledAt) %></p>
                <h2><%= todayPost.originalName %></h2>
                <% if (helpers.fullCaption(todayPost)) { %>
                  <p class="caption-preview"><%= helpers.fullCaption(todayPost) %></p>
                <% } %>
                <textarea class="copy-cache" id="today-caption-<%= todayPost.id %>" readonly><%= helpers.fullCaption(todayPost) %></textarea>
                <div class="actions">
                  <a class="button secondary" href="<%= todayPost.imagePath %>" target="_blank" rel="noreferrer">Open image</a>
                  <button type="button" class="secondary copy-button" data-target="today-caption-<%= todayPost.id %>">Copy caption</button>
                  <% if (todayPost.status !== 'posted') { %>
                    <form class="inline-action" action="/posts/<%= todayPost.id %>/prepare" method="post">
                      <button type="submit" class="primary">Prepare now</button>
                    </form>
                    <form class="inline-action" action="/posts/<%= todayPost.id %>/posted" method="post">
                      <button type="submit" class="secondary">Mark posted</button>
                    </form>
                  <% } %>
                </div>
              </div>
            </div>
          <% } else { %>
            <div class="empty-today">
              <div class="empty-today-inner">
                <img class="empty-logo" src="/uploads/chanter_logo_1024x1024.png" alt="" />
                <h2>No post scheduled today</h2>
                <p>The queue is quiet for the day.</p>
              </div>
            </div>
          <% } %>
        </article>

        <aside class="metrics" aria-label="Queue counts">
          <div class="metric" data-tone="total"><strong><%= counts.total %></strong><span>Total</span></div>
          <div class="metric" data-tone="pending"><strong><%= counts.pending %></strong><span>Pending</span></div>
          <div class="metric" data-tone="ready"><strong><%= counts.ready %></strong><span>Ready</span></div>
          <div class="metric" data-tone="posted"><strong><%= counts.posted %></strong><span>Posted</span></div>
          <div class="metric" data-tone="failed"><strong><%= counts.failed %></strong><span>Failed</span></div>
        </aside>
      </section>

      <section class="control-grid">
        <div class="panel">
          <div class="panel-head">
            <h2>Upload</h2>
            <span class="muted">Batch</span>
          </div>
          <form action="/upload" method="post" enctype="multipart/form-data">
            <div class="form-grid">
              <label class="wide">
                Images
                <input type="file" name="images" accept="image/*" multiple required />
              </label>
              <label>
                Caption
                <textarea name="caption" placeholder="Caption"></textarea>
              </label>
              <label>
                Hashtags
                <textarea name="hashtags" placeholder="#chanter"></textarea>
              </label>
            </div>
            <div class="actions">
              <button type="submit" class="primary">Upload</button>
            </div>
          </form>
        </div>

        <div class="panel">
          <div class="panel-head">
            <h2>Schedule</h2>
            <span class="muted"><%= settings.dailyPostTime %></span>
          </div>
          <form action="/settings" method="post">
            <label>
              Daily time
              <input type="time" name="dailyPostTime" value="<%= settings.dailyPostTime %>" required />
            </label>
            <div class="actions">
              <button type="submit" class="primary">Save</button>
            </div>
          </form>
          <form action="/schedule" method="post">
            <div class="actions">
              <button type="submit" class="secondary">Rebuild queue</button>
            </div>
          </form>
        </div>
      </section>

      <div class="queue-head">
        <h2>Queue</h2>
        <span class="muted"><%= counts.pending %> pending</span>
      </div>

      <section class="queue">
        <% if (posts.length === 0) { %>
          <div class="empty">Queue empty</div>
        <% } %>

        <% posts.forEach(function(post, index) { %>
          <article class="queue-card">
            <a class="queue-thumb" href="<%= post.imagePath %>" target="_blank" rel="noreferrer">
              <img src="<%= post.imagePath %>" alt="<%= post.originalName %>" loading="lazy" />
            </a>

            <div class="queue-main">
              <header class="queue-top">
                <div class="queue-title">
                  <p class="queue-index">#<%= index + 1 %></p>
                  <h3><%= post.originalName %></h3>
                  <p class="queue-time"><%= helpers.formatDateTime(post.scheduledAt) %></p>
                </div>
                <span class="badge <%= post.status %>"><%= helpers.statusLabel(post.status) %></span>
              </header>

              <form class="edit-grid" action="/posts/<%= post.id %>" method="post">
                <label>
                  Caption
                  <textarea name="caption"><%= post.caption || '' %></textarea>
                </label>
                <label>
                  Hashtags
                  <textarea name="hashtags"><%= post.hashtags || '' %></textarea>
                </label>
                <label>
                  Date
                  <input type="datetime-local" name="scheduledAt" value="<%= helpers.dateTimeInput(post.scheduledAt) %>" />
                </label>
                <label class="public-url-field">
                  Public image URL
                  <input
                    type="url"
                    name="publicImageUrl"
                    value="<%= post.publicImageUrl || '' %>"
                    placeholder="https://chanterr.com/media/tiktok-posts/test-image.png"
                  />
                </label>
                <div class="save-slot">
                  <button type="submit" class="primary">Save</button>
                </div>
              </form>

              <% if (post.status === 'ready') { %>
                <div class="ready-strip">
                  <strong>Ready to post</strong>
                  <textarea class="caption-copy" id="caption-<%= post.id %>" readonly><%= helpers.fullCaption(post) %></textarea>
                  <div class="actions">
                    <a class="button secondary" href="<%= post.imagePath %>" target="_blank" rel="noreferrer">Open image</a>
                    <button type="button" class="secondary copy-button" data-target="caption-<%= post.id %>">Copy caption</button>
                  </div>
                </div>
              <% } %>

              <div class="card-actions">
                <form class="inline-action" action="/posts/<%= post.id %>/move" method="post">
                  <input type="hidden" name="direction" value="up" />
                  <button type="submit" class="secondary">Move up</button>
                </form>
                <form class="inline-action" action="/posts/<%= post.id %>/move" method="post">
                  <input type="hidden" name="direction" value="down" />
                  <button type="submit" class="secondary">Move down</button>
                </form>
                <% if (post.status !== 'posted') { %>
                  <form class="inline-action" action="/posts/<%= post.id %>/prepare" method="post">
                    <button type="submit" class="primary">Prepare now</button>
                  </form>
                  <form class="inline-action" action="/posts/<%= post.id %>/posted" method="post">
                    <button type="submit" class="secondary">Mark posted</button>
                  </form>
                <% } %>
                <% if (post.status !== 'pending') { %>
                  <form class="inline-action" action="/posts/<%= post.id %>/pending" method="post">
                    <button type="submit" class="secondary">Back to pending</button>
                  </form>
                <% } %>
                <form class="inline-action" action="/posts/<%= post.id %>/delete" method="post">
                  <button type="submit" class="danger">Delete</button>
                </form>
              </div>
            </div>
          </article>
        <% }); %>
      </section>
    </main>

    <script>
      document.querySelectorAll('.copy-button').forEach((button) => {
        button.addEventListener('click', async () => {
          const target = document.getElementById(button.dataset.target);
          if (!target) return;

          await navigator.clipboard.writeText(target.value);
          const originalText = button.textContent;
          button.textContent = 'Copied';
          window.setTimeout(() => {
            button.textContent = originalText;
          }, 1200);
        });
      });
    </script>
  </body>
</html>
