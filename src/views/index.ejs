<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= appName %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,700;0,9..40,900;1,9..40,300&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/autoposter-dashboard/assets/prompt-evolver-main.css" />
    <style>
      :root {
        --bg: #f7f5f0;
        --bg2: #ffffff;
        --surface: #ffffff;
        --surface2: rgba(23,24,29,0.04);
        --border: rgba(23,24,29,0.10);
        --border2: rgba(23,24,29,0.20);
        --accent: #17181d;
        --accent2: #6b6e78;
        --accent-glow: rgba(23, 24, 29, 0.08);
        --accent2-glow: rgba(23, 24, 29, 0.06);
        --text: #17181d;
        --text2: #4c4f58;
        --text3: #8a8d97;
        --danger: #b42318;
        --danger-bg: rgba(180,35,24,0.07);
        --warn: #b45309;
        --warn-bg: rgba(180,83,9,0.08);
        --ok: #15803d;
        --ok-bg: rgba(21,128,61,0.08);
        --purple: #6d4fd8;
        --purple-bg: rgba(109,79,216,0.08);
        --cyan: #0e7490;
        --cyan-bg: rgba(14,116,144,0.07);
        --r: 22px;
        --r-sm: 12px;
        --r-xs: 6px;
        --shadow: 0 18px 50px rgba(23,24,29,.07), 0 2px 8px rgba(23,24,29,.04);
      }
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html { background: var(--bg); }
      body {
        font-family: 'DM Sans', ui-sans-serif, system-ui, sans-serif;
        color: var(--text);
        background: var(--bg);
        line-height: 1.5;
        -webkit-font-smoothing: antialiased;
        min-height: 100vh;
      }
      body::before {
        content: "";
        position: fixed; inset: 0; z-index: 0; pointer-events: none;
        background: radial-gradient(ellipse 60% 42% at 50% -12%, rgba(23,24,29,.045) 0%, transparent 70%);
      }

      .app { position: relative; z-index: 1; max-width: 1240px; margin: 0 auto; padding: 34px 28px 96px; }

      /* ─── Topbar ─── */
      .topbar { margin-bottom: 34px; }
      .topbar-inner {
        display: flex; align-items: center; justify-content: space-between; gap: 24px;
        padding: 18px 22px;
        background: #ffffff;
        border: 1px solid var(--border); border-radius: var(--r);
        box-shadow: var(--shadow);
      }
      .brand-lockup { display: flex; align-items: center; gap: 22px; min-width: 0; }
      .brand { display: flex; align-items: center; gap: 12px; }
      .brand-mark {
        width: 46px; height: 46px; border-radius: 13px; object-fit: cover;
        background: #07060b;
        border: 1px solid rgba(255,255,255,.10);
        box-shadow: 0 10px 26px rgba(0,0,0,.5), inset 0 1px 0 rgba(255,255,255,.07);
      }
      .brand-title { font-size: 17px; font-weight: 800; letter-spacing: 0.045em; color: var(--text); }
      .brand-title small { font-weight: 500; color: var(--text2); letter-spacing: 0.02em; font-size: 15px; }
      .brand-sub { font-size: 10px; font-weight: 600; color: var(--text3); text-transform: uppercase; letter-spacing: 0.14em; }
      .brand-context { border-left: 1px solid var(--border); padding-left: 22px; min-width: 0; }
      .brand-context span { display: block; color: var(--text); font-size: 12px; font-weight: 700; }
      .brand-context p { margin-top: 2px; color: var(--text3); font-size: 11px; white-space: nowrap; }
      .topbar-actions { display: flex; align-items: center; justify-content: flex-end; gap: 9px; flex-wrap: wrap; }

      /* ─── Pills ─── */
      .pill {
        display: inline-flex; align-items: center; gap: 7px; min-height: 36px; padding: 6px 12px;
        border-radius: 999px; font-size: 12px; font-weight: 600; border: 1px solid var(--border);
        background: var(--surface2); color: var(--text2); white-space: nowrap;
      }
      .pill .dot { width: 7px; height: 7px; border: 2px solid rgba(23,24,29,.10); border-radius: 50%; background: currentColor; }
      .pill-ok   { border-color: rgba(21,128,61,.28); background: var(--ok-bg); color: var(--ok); }
      .pill-cyan { border-color: rgba(14,116,144,.28); background: var(--cyan-bg); color: var(--cyan); }
      .pill-warn { border-color: rgba(180,83,9,.28); background: var(--warn-bg); color: var(--warn); }
      .pill-err  { border-color: rgba(180,35,24,.28);  background: var(--danger-bg); color: var(--danger); }
      .pill-creator { padding: 4px 11px 4px 4px; gap: 7px; }
      .pill-creator img { width: 22px; height: 22px; border-radius: 50%; object-fit: cover; background: var(--surface2); }

      /* ─── Buttons ─── */
      .btn {
        display: inline-flex; align-items: center; justify-content: center; gap: 6px;
        height: 39px; padding: 0 16px; border-radius: var(--r-sm);
        font-size: 13px; font-weight: 650; letter-spacing: 0.01em; border: 1px solid transparent;
        cursor: pointer; text-decoration: none; transition: all 0.18s ease;
        background: none; color: inherit; font-family: inherit; white-space: nowrap;
      }
      .btn-primary   {
        background: linear-gradient(180deg, #23242b, #101116);
        color: #ffffff;
        box-shadow: 0 10px 24px rgba(23,24,29,.22), inset 0 1px 0 rgba(255,255,255,.08);
      }
      .btn-primary:hover { filter: brightness(1.12); transform: translateY(-1px); box-shadow: 0 14px 28px rgba(23,24,29,.28), inset 0 1px 0 rgba(255,255,255,.08); }
      .btn-ghost     { border-color: var(--border); color: var(--text2); }
      .btn-ghost:hover { border-color: var(--border2); background: var(--surface2); color: var(--text); }
      .btn-secondary { border-color: var(--border); color: var(--text2); background: transparent; }
      .btn-secondary:hover { border-color: var(--border2); background: var(--surface2); color: var(--text); }
      .btn-danger    { border-color: rgba(180,35,24,.25); color: var(--danger); background: transparent; }
      .btn-danger:hover { background: var(--danger-bg); border-color: rgba(180,35,24,.4); }
      .btn-cyan      { background: transparent; border-color: rgba(14,116,144,.3); color: var(--cyan); }
      .btn-cyan:hover{ background: var(--cyan-bg); }
      .btn[disabled]  { opacity: 0.45; cursor: not-allowed; pointer-events: none; }
      .btn-dashboard { border-color: var(--border2); background: rgba(23,24,29,.03); color: var(--text); }
      .btn-dashboard::after { content: "\2197"; color: var(--text3); font-size: 12px; }
      .btn-dashboard:hover { border-color: rgba(23,24,29,.32); background: rgba(23,24,29,.06); transform: translateY(-1px); }
      .btn-prompt-evolver { border-color: var(--border); background: rgba(23,24,29,.02); color: var(--text2); }
      .btn-prompt-evolver::after { content: "\2193"; color: var(--text3); font-size: 12px; }
      .btn-prompt-evolver:hover { border-color: var(--border2); background: rgba(23,24,29,.05); transform: translateY(-1px); }
      .btn-disconnect { color: #85899a; }
      .logout-form { display: inline-flex; }

      .account-context {
        display: grid; grid-template-columns: minmax(180px, .7fr) minmax(210px, .72fr) minmax(280px, 1fr);
        align-items: center; gap: 20px; margin: -14px 0 30px; padding: 16px 18px;
        border: 1px solid var(--border); border-radius: 16px; background: rgba(12,14,22,.68); backdrop-filter: blur(18px);
      }
      .account-context-copy { display: grid; min-width: 0; }
      .account-context-label { color: var(--text3); font-size: 9px; font-weight: 800; letter-spacing: .12em; text-transform: uppercase; }
      .account-context-copy strong { margin-top: 3px; overflow: hidden; color: var(--text); font-size: 14px; text-overflow: ellipsis; white-space: nowrap; }
      .account-context-copy small { margin-top: 2px; color: var(--text3); font-size: 10px; }
      .account-selector label { gap: 5px; }
      .account-selector select { min-height: 40px; }
      .account-connect-flow { display: grid; justify-items: end; gap: 6px; }
      .account-connect-flow small { max-width: 410px; color: var(--text3); font-size: 10px; line-height: 1.45; text-align: right; }

      /* ─── Notice ─── */
      .notice {
        margin-bottom: 22px; padding: 13px 17px; border-radius: var(--r-sm);
        border: 1px solid rgba(180,35,24,.22); background: var(--danger-bg);
        color: var(--text); font-size: 14px; font-weight: 500;
      }
      .instagram-status-banner {
        display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
        margin-bottom: 22px; padding: 12px 16px; border-radius: var(--r-sm);
        border: 1px solid rgba(180,83,9,.25); background: var(--warn-bg);
        color: var(--text2); font-size: 12px;
      }
      .instagram-status-banner strong { color: var(--warn); font-size: 13px; }
      .instagram-status-banner span + span::before { content: "\2022"; margin-right: 10px; color: var(--text3); }

      /* ─── Compliance Warning Banner ─── */
      .compliance-banner {
        margin-bottom: 22px; padding: 14px 18px;
        background: var(--warn-bg); border: 1px solid rgba(180,83,9,.22); border-radius: var(--r-sm);
        font-size: 13px; color: var(--warn); line-height: 1.6;
      }
      .compliance-banner strong { font-weight: 700; }
      .compliance-banner a { color: inherit; text-decoration: underline; }

      /* ─── Grid ─── */
      .dashboard-grid { display: grid; grid-template-columns: minmax(0, 1.32fr) minmax(320px, .68fr); gap: 22px; margin-bottom: 42px; }

      /* ─── Panel ─── */
      .panel {
        position: relative; overflow: hidden;
        background: #ffffff;
        border: 1px solid var(--border);
        border-radius: var(--r); padding: 28px; box-shadow: var(--shadow);
      }
      .panel::before { content: ""; position: absolute; inset: 0 0 auto; height: 1px; background: linear-gradient(90deg, transparent, rgba(23,24,29,.06), transparent); }
      .panel-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 18px; }
      .panel-head h2 { font-size: 20px; font-weight: 800; letter-spacing: -0.025em; }
      .panel-meta { font-size: 13px; font-weight: 600; color: var(--text3); font-variant-numeric: tabular-nums; }
      .panel-head-rich { align-items: flex-start; margin-bottom: 22px; }
      .panel-head-rich p { margin-top: 5px; max-width: 430px; color: var(--text3); font-size: 12px; line-height: 1.55; }
      .panel-kicker, .section-kicker { display: block; margin-bottom: 5px; color: var(--accent2); font-size: 9px; font-weight: 800; letter-spacing: .14em; text-transform: uppercase; }
      .panel-step { display: grid; width: 34px; height: 34px; place-items: center; border: 1px solid var(--border); border-radius: 10px; background: rgba(23,24,29,.03); color: var(--text3); font: 500 11px 'DM Mono', monospace; }

      /* ─── Forms ─── */
      .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
      .form-grid .wide { grid-column: 1 / -1; }
      label {
        display: grid; gap: 7px; font-size: 10px; font-weight: 700;
        text-transform: uppercase; letter-spacing: 0.05em; color: var(--text3);
      }
      .field-note {
        display: block; font-size: 11px; font-weight: 400; text-transform: none;
        color: var(--text3); letter-spacing: 0; line-height: 1.4;
      }
      input, select, textarea {
        width: 100%; background: #ffffff; border: 1px solid var(--border);
        border-radius: var(--r-sm); padding: 11px 13px; color: var(--text);
        font-size: 13px; font-family: inherit; outline: none; transition: border-color .18s, box-shadow .18s, background .18s;
      }
      input:hover, select:hover, textarea:hover { border-color: var(--border2); }
      input:focus, select:focus, textarea:focus { border-color: rgba(23,24,29,.45); background: #ffffff; box-shadow: 0 0 0 3px var(--accent-glow); }
      input::placeholder, textarea::placeholder { color: var(--text3); }
      input[type="file"] { padding: 12px; cursor: pointer; min-height: 58px; border-style: dashed; background: rgba(23,24,29,.02); }
      input[type="file"]::file-selector-button {
        margin-right: 12px; padding: 8px 13px; border-radius: 8px; border: 1px solid var(--border2);
        background: #f1efe9; color: var(--text); font-weight: 700; cursor: pointer;
      }
      input[type="checkbox"] {
        width: 15px; height: 15px; cursor: pointer; accent-color: var(--accent);
        flex-shrink: 0; border-radius: 4px;
      }
      textarea { min-height: 92px; resize: vertical; line-height: 1.55; }
      select {
        appearance: none;
        background-image: url("data:image/svg+xml,%3Csvg width='10' height='6' viewBox='0 0 10 6' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1l4 4 4-4' stroke='%23606070' stroke-width='1.5' fill='none'/%3E%3C/svg%3E");
        background-repeat: no-repeat; background-position: right 11px center; padding-right: 30px;
      }
      .actions { display: flex; gap: 9px; margin-top: 16px; flex-wrap: wrap; }
      .actions .btn { height: 38px; padding: 0 16px; }
      .upload-zone { display: block; border: 1px solid var(--border); border-radius: 14px; background: rgba(23,24,29,.02); padding: 16px; }
      .upload-zone .field-heading { display: block; margin-bottom: 3px; color: var(--text2); font-size: 11px; }
      .upload-zone .field-note { margin-bottom: 12px; }
      .url-field { margin-top: 2px; }
      .auto-caption-card {
        display: grid; gap: 8px; border: 1px solid var(--border); border-radius: 12px;
        background: rgba(23,24,29,.02); padding: 13px 14px;
      }
      .auto-caption-row { display: flex; align-items: center; justify-content: space-between; gap: 16px; cursor: pointer; }
      .auto-caption-copy { display: grid; gap: 3px; min-width: 0; }
      .auto-caption-copy strong { color: var(--text2); font-size: 12px; letter-spacing: .02em; }
      .auto-caption-copy span { color: var(--text3); font-size: 11px; font-weight: 400; line-height: 1.4; }
      .auto-caption-row input { width: 18px; height: 18px; }
      .auto-caption-status { min-height: 16px; color: var(--text3); font-size: 11px; line-height: 1.45; }
      .auto-caption-status[data-tone="working"] { color: var(--accent2); }
      .auto-caption-status[data-tone="success"] { color: var(--ok); }
      .auto-caption-status[data-tone="error"] { color: var(--danger); }
      .auto-music-divider { height: 1px; background: var(--border); margin: 2px 0; }
      .upload-actions { justify-content: flex-end; margin-top: 20px; }
      .btn-create { min-width: 190px; height: 44px !important; }
      .btn-create::after { content: "\2192"; font-size: 16px; transition: transform .18s; }
      .btn-create:hover::after { transform: translateX(2px); }
      .schedule-clock { display: grid; margin-bottom: 20px; border: 1px solid var(--border); border-radius: 15px; background: rgba(23,24,29,.02); padding: 17px; }
      .schedule-clock span { color: var(--text3); font-size: 9px; font-weight: 800; letter-spacing: .1em; text-transform: uppercase; }
      .schedule-clock strong { margin: 2px 0; color: var(--text); font: 500 30px 'DM Mono', monospace; letter-spacing: -.04em; }
      .schedule-clock small { color: var(--text3); font-size: 10px; }
      .schedule-settings .actions .btn { width: 100%; }
      .schedule-divider { height: 1px; margin: 22px 0 17px; background: var(--border); }
      .rebuild-form { display: flex; align-items: center; justify-content: space-between; gap: 16px; }
      .rebuild-form p { display: flex; align-items: flex-start; gap: 8px; color: var(--text3); font-size: 11px; line-height: 1.5; }
      .rebuild-form .actions { flex: 0 0 auto; margin: 0; }
      .status-dot { flex: 0 0 auto; width: 6px; height: 6px; margin-top: 5px; border-radius: 50%; background: var(--ok); }

      /* ─── Interaction Controls (TikTok Required UX) ─── */
      .interaction-controls { display: grid; gap: 8px; }
      .check-row {
        display: flex; align-items: center; gap: 10px; padding: 9px 12px;
        background: rgba(23,24,29,.03); border: 1px solid var(--border); border-radius: var(--r-sm);
        cursor: pointer; transition: border-color 0.15s;
      }
      .check-row:hover { border-color: var(--border2); }
      .check-row.disabled-row { opacity: 0.45; cursor: not-allowed; }
      .check-row label { font-size: 13px; font-weight: 500; color: var(--text2); text-transform: none; letter-spacing: 0; cursor: pointer; margin: 0; }
      .check-row.disabled-row label { cursor: not-allowed; }
      .check-hint { font-size: 11px; color: var(--text3); margin-left: auto; font-style: italic; }

      /* ─── Content Disclosure ─── */
      .disclosure-section {
        border: 1px solid var(--border); border-radius: var(--r-sm); overflow: hidden; margin-top: 12px;
      }
      .disclosure-header {
        display: flex; align-items: center; justify-content: space-between; padding: 11px 14px;
        background: var(--surface2); cursor: pointer;
      }
      .disclosure-header span { font-size: 12px; font-weight: 700; color: var(--text2); }
      .disclosure-body { padding: 12px 14px; display: grid; gap: 8px; }
      .disclosure-note { font-size: 11px; color: var(--text3); line-height: 1.5; }

      /* Toggle switch */
      .toggle-wrap { display: flex; align-items: center; gap: 10px; }
      .toggle { position: relative; width: 36px; height: 20px; flex-shrink: 0; }
      .toggle input { opacity: 0; width: 0; height: 0; }
      .toggle-slider {
        position: absolute; inset: 0; border-radius: 20px; background: var(--border2);
        cursor: pointer; transition: background 0.2s;
      }
      .toggle-slider::before {
        content: ""; position: absolute; width: 14px; height: 14px; border-radius: 50%;
        background: white; left: 3px; top: 3px; transition: transform 0.2s; box-shadow: 0 1px 4px rgba(0,0,0,.3);
      }
      .toggle input:checked + .toggle-slider { background: var(--accent); }
      .toggle input:checked + .toggle-slider::before { transform: translateX(16px); }

      /* ─── Music Disclosure (Required) ─── */
      .music-declaration {
        padding: 11px 14px; border-radius: var(--r-sm);
        border: 1px solid var(--border); background: rgba(23,24,29,.02);
        font-size: 12px; color: var(--text2); line-height: 1.6;
      }
      .music-declaration a { color: var(--cyan); text-decoration: underline; }
      .music-declaration strong { color: var(--text2); font-weight: 600; }

      /* ─── Queue ─── */
      .queue-section { margin-bottom: 34px; }
      .section-head { display: flex; align-items: flex-end; justify-content: space-between; gap: 20px; margin-bottom: 20px; }
      .section-head h2 { font-size: 24px; font-weight: 800; letter-spacing: -0.03em; }
      .section-head p { margin-top: 4px; color: var(--text3); font-size: 12px; }
      .count { font-size: 12px; font-weight: 700; color: var(--text3); }
      .count-prominent { border: 1px solid var(--border); border-radius: 999px; background: rgba(23,24,29,.03); padding: 6px 11px; color: var(--text2); }
      .queue-list { display: grid; gap: 18px; }

      /* ─── Queue Card ─── */
      .queue-card {
        display: grid; grid-template-columns: 150px 1fr; gap: 22px;
        background: #ffffff; border: 1px solid var(--border);
        border-radius: var(--r); padding: 20px;
        box-shadow: 0 10px 30px rgba(23,24,29,.05);
        transition: transform .18s, border-color .18s, box-shadow .18s;
      }
      .queue-card:hover { transform: translateY(-2px); border-color: var(--border2); box-shadow: 0 16px 40px rgba(23,24,29,.08); }
      .queue-thumb {
        position: relative; width: 150px; aspect-ratio: 4/5;
        border-radius: 14px; overflow: hidden; background: #edebe5;
        border: 1px solid var(--border); flex-shrink: 0;
      }
      .queue-thumb img, .queue-thumb video { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; display: block; }
      .queue-thumb .thumb-placeholder { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: contain; padding: 22px; opacity: 0; filter: saturate(0.5); }
      .queue-thumb.is-missing [data-preview-media] { display: none; }
      .queue-thumb.is-missing .thumb-placeholder { opacity: 0.3; }
      .media-chip {
        position: absolute; bottom: 7px; right: 7px; padding: 3px 8px; border-radius: 5px;
        background: rgba(23,24,29,.72); backdrop-filter: blur(8px); font-size: 9px; font-weight: 800;
        text-transform: uppercase; letter-spacing: 0.05em; color: #ffffff; border: 1px solid rgba(255,255,255,.2);
      }
      .queue-main { min-width: 0; display: flex; flex-direction: column; gap: 14px; }
      .queue-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 10px; }
      .queue-title h3 { font-size: 16px; font-weight: 750; color: var(--text); overflow-wrap: anywhere; line-height: 1.3; }
      .queue-meta { font-size: 12px; color: var(--text3); font-weight: 500; margin-top: 3px; }
      .caption-preview { font-size: 13px; color: var(--text2); line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }

      .result-message {
        font-size: 12px; line-height: 1.5; padding: 9px 12px; border-radius: var(--r-sm);
        background: rgba(23,24,29,.03); border: 1px solid var(--border); color: var(--text2);
      }
      .result-message.is-failed { border-color: rgba(180,35,24,.2); background: var(--danger-bg); color: var(--danger); }

      /* ─── Badges ─── */
      .badge {
        display: inline-flex; align-items: center; gap: 5px; padding: 4px 9px; border-radius: 999px;
        font-size: 10px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em;
        border: 1px solid var(--border); background: var(--surface2); color: var(--text3);
        white-space: nowrap; flex-shrink: 0;
      }
      .badge::before { content: ""; width: 5px; height: 5px; border-radius: 50%; background: currentColor; }
      .badge.pending, .badge.scheduled { border-color: rgba(180,83,9,.28); background: var(--warn-bg); color: var(--warn); }
      .badge.ready, .badge.verification { border-color: rgba(109,79,216,.28); background: var(--purple-bg); color: var(--purple); }
      .badge.posted, .badge.accepted { border-color: rgba(21,128,61,.28); background: var(--ok-bg); color: var(--ok); }
      .badge.publishing { border-color: rgba(14,116,144,.28); background: var(--cyan-bg); color: var(--cyan); }
      .badge.failed { border-color: rgba(180,35,24,.25); background: var(--danger-bg); color: var(--danger); }

      /* ─── Schedule Form ─── */
      .schedule-form { display: grid; gap: 14px; }
      .schedule-row { display: grid; grid-template-columns: minmax(190px, 1fr) minmax(150px, .52fr) auto; gap: 12px; align-items: end; }
      .card-actions { display: flex; gap: 8px; flex-wrap: wrap; }

      /* ─── Advanced Details ─── */
      .advanced { margin-top: 4px; }
      .advanced summary { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text3); cursor: pointer; user-select: none; }
      .advanced-body { margin-top: 11px; display: grid; gap: 11px; }
      .advanced pre {
        background: rgba(23,24,29,.035); border: 1px solid var(--border); border-radius: var(--r-sm);
        padding: 12px; font-size: 11px; line-height: 1.6; color: var(--text2);
        font-family: 'DM Mono', monospace; overflow: auto; max-height: 220px;
        white-space: pre-wrap; overflow-wrap: anywhere;
      }

      /* ─── Unaudited Notice ─── */
      .unaudited-note {
        padding: 11px 14px; border-radius: var(--r-sm);
        border: 1px solid rgba(180,83,9,.25); background: var(--warn-bg);
        font-size: 12px; color: var(--warn); line-height: 1.5;
      }
      .unaudited-note strong { font-weight: 700; }

      /* ─── Empty State ─── */
      .empty-state {
        display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 7px;
        padding: 68px 24px; border: 1px dashed rgba(23,24,29,.16); border-radius: var(--r);
        background: rgba(23,24,29,.015); color: var(--text3); text-align: center;
      }
      .empty-state p { margin-top: 4px; font-size: 16px; font-weight: 750; color: var(--text2); }
      .empty-state span { font-size: 12px; }
      .empty-state .empty-icon { display: grid; width: 42px; height: 42px; place-items: center; border: 1px solid var(--border2); border-radius: 13px; background: rgba(23,24,29,.03); color: var(--text2); font-size: 22px; font-weight: 300; }

      /* ─── History ─── */
      .history-panel {
        overflow: hidden; background: #ffffff; border: 1px solid var(--border); border-radius: var(--r); box-shadow: 0 10px 30px rgba(23,24,29,.05);
      }
      .history-panel > summary {
        display: flex; align-items: center; justify-content: space-between;
        padding: 20px 22px; cursor: pointer; font-size: 15px; font-weight: 800; list-style: none; transition: background .18s;
      }
      .history-panel > summary:hover { background: rgba(23,24,29,.02); }
      .history-panel > summary::-webkit-details-marker { display: none; }
      .history-title { display: flex; align-items: center; gap: 12px; }
      .history-title > span:last-child { display: grid; }
      .history-title small { color: var(--text3); font-size: 9px; font-weight: 800; letter-spacing: .12em; text-transform: uppercase; }
      .history-title strong { color: var(--text); font-size: 15px; }
      .history-icon { position: relative; width: 36px; height: 36px; border: 1px solid var(--border); border-radius: 11px; background: rgba(23,24,29,.03); }
      .history-icon::before, .history-icon::after { content: ""; position: absolute; left: 9px; right: 9px; height: 1px; background: var(--text3); }
      .history-icon::before { top: 13px; box-shadow: 0 5px 0 var(--text3); }
      .history-icon::after { top: 8px; left: 13px; right: 13px; }
      .history-summary-meta { display: flex; align-items: center; gap: 12px; }
      .history-summary-meta .count { border: 1px solid var(--border); border-radius: 999px; padding: 5px 9px; background: rgba(23,24,29,.03); }
      .history-chevron { width: 8px; height: 8px; border-right: 1px solid var(--text3); border-bottom: 1px solid var(--text3); transform: rotate(45deg); transition: transform .18s; }
      .history-panel[open] .history-chevron { transform: rotate(225deg); }
      .history-list { padding: 0 22px 22px; display: grid; gap: 11px; }
      .history-card {
        display: grid; grid-template-columns: 90px 1fr; gap: 14px; padding: 14px;
        border-radius: var(--r-sm); border: 1px solid var(--border); background: rgba(23,24,29,.02);
        transition: border-color 0.18s;
      }
      .history-card:hover { border-color: var(--border2); }
      .history-card .queue-thumb { width: 90px; aspect-ratio: 1; }
      .history-empty { padding: 36px; text-align: center; color: var(--text3); font-size: 13px; }

      /* Campaign Mode */
      .campaign-mode { margin-bottom: 42px; }
      .campaign-layout { display: grid; grid-template-columns: minmax(0, 1.3fr) minmax(300px, .7fr); gap: 20px; }
      .campaign-form { display: grid; gap: 16px; }
      .campaign-intake { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
      .campaign-video { grid-column: 1 / -1; }
      .campaign-account-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
      .campaign-account-card { display: grid; gap: 12px; padding: 15px; border: 1px solid var(--border); border-radius: 14px; background: rgba(23,24,29,.02); }
      .campaign-account-card h3 { font-size: 13px; color: var(--text2); }
      .campaign-account-card textarea { min-height: 76px; }
      .campaign-preview { display: grid; align-content: start; gap: 11px; padding: 15px; border: 1px solid var(--border); border-radius: 14px; background: rgba(23,24,29,.02); }
      .campaign-preview h3 { font-size: 13px; }
      .campaign-preview-note { color: var(--text3); font-size: 11px; line-height: 1.5; }
      .campaign-preview-card { display: grid; gap: 5px; padding: 12px; border: 1px solid var(--border); border-radius: 11px; background: #ffffff; }
      .campaign-preview-card strong { font-size: 12px; }
      .campaign-preview-card span { color: var(--text3); font: 500 10px 'DM Mono', monospace; }
      .campaign-preview-verdict { display: grid; gap: 6px; padding: 12px; border: 1px solid var(--border); border-radius: 11px; font-size: 12px; color: var(--text2); }
      .campaign-preview-verdict.is-safe { border-color: rgba(21,128,61,.32); background: var(--ok-bg); }
      .campaign-preview-verdict.is-blocked { border-color: rgba(180,35,24,.3); background: var(--danger-bg); }
      .campaign-preview-verdict ul { margin: 0; padding-left: 16px; display: grid; gap: 4px; color: var(--text3); }
      .scheduler-evidence { display: grid; gap: 8px; margin-top: 22px; padding: 14px; border: 1px solid var(--border); border-radius: 14px; background: rgba(23,24,29,.02); }
      .scheduler-evidence-head { display: flex; align-items: center; justify-content: space-between; gap: 12px; }
      .scheduler-evidence-head h3 { font-size: 13px; }
      .scheduler-evidence-line { color: var(--text3); font: 500 10px 'DM Mono', monospace; overflow-wrap: anywhere; }
      .scheduler-evidence ul { margin: 0; padding-left: 16px; display: grid; gap: 4px; color: var(--danger); font-size: 10px; line-height: 1.5; }
      .campaign-history { display: grid; gap: 12px; margin-top: 22px; padding-top: 20px; border-top: 1px solid var(--border); }
      .campaign-history-head { display: flex; align-items: center; justify-content: space-between; gap: 12px; }
      .campaign-history-head h3 { font-size: 15px; }
      .campaign-group { display: grid; gap: 10px; padding: 14px; border: 1px solid var(--border); border-radius: 14px; background: rgba(23,24,29,.02); }
      .campaign-group-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 14px; }
      .campaign-group-head strong { display: block; font-size: 13px; }
      .campaign-group-head small { color: var(--text3); font-size: 10px; }
      .campaign-status { padding: 4px 8px; border: 1px solid var(--border); border-radius: 999px; color: var(--text2); font-size: 9px; font-weight: 800; letter-spacing: .06em; text-transform: uppercase; }
      .campaign-job-list { display: grid; gap: 8px; }
      .campaign-job { display: grid; grid-template-columns: minmax(120px,.55fr) 1fr auto; align-items: center; gap: 12px; padding: 10px; border-radius: 10px; background: #ffffff; border: 1px solid var(--border); }
      .campaign-job strong { overflow: hidden; font-size: 11px; text-overflow: ellipsis; white-space: nowrap; }
      .campaign-job-copy { overflow: hidden; color: var(--text3); font-size: 10px; text-overflow: ellipsis; white-space: nowrap; }
      .campaign-job time { color: var(--text3); font: 500 9px 'DM Mono', monospace; white-space: nowrap; }
      .campaign-job-meta { grid-column: 1 / -1; color: var(--text3); font: 500 9px 'DM Mono', monospace; overflow-wrap: anywhere; }
      .campaign-job-error { grid-column: 1 / -1; padding: 6px 8px; border: 1px solid rgba(180,35,24,.2); border-radius: 8px; background: var(--danger-bg); color: var(--danger); font-size: 10px; line-height: 1.5; }
      .campaign-no-live-note { border: 1px dashed var(--border); border-radius: 8px; padding: 8px; }
      .campaign-copy-btn { justify-self: start; padding: 6px 10px; font-size: 10px; }
      .fine-print { display: grid; gap: 8px; }
      .fine-print summary { cursor: pointer; color: var(--text3); font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; user-select: none; }
      .fine-print[open] summary { color: var(--text2); }
      .campaign-oracle { display: grid; gap: 7px; padding: 13px 14px; border: 1px solid var(--border); border-radius: 12px; background: #ffffff; box-shadow: 0 4px 14px rgba(23,24,29,.04); }
      .campaign-oracle .campaign-status { border-color: rgba(23,24,29,.22); background: rgba(23,24,29,.04); color: var(--text); }
      .campaign-oracle-head { display: flex; align-items: center; justify-content: space-between; gap: 10px; }
      .campaign-oracle-head strong { font-size: 11px; color: var(--text2); }
      .campaign-oracle p { margin: 0; color: var(--text3); font-size: 11px; line-height: 1.5; }
      .campaign-oracle-blocked { color: var(--danger) !important; }
      .campaign-oracle ul { margin: 0; padding-left: 16px; display: grid; gap: 3px; color: var(--text3); font-size: 10px; line-height: 1.5; }
      .campaign-evidence { display: grid; gap: 8px; }
      .campaign-evidence summary { cursor: pointer; color: var(--text2); font-size: 11px; font-weight: 700; }
      .campaign-evidence-text { margin: 0; padding: 10px; border: 1px solid var(--border); border-radius: 10px; background: rgba(23,24,29,.035); color: var(--text2); font: 500 10px 'DM Mono', monospace; line-height: 1.6; white-space: pre-wrap; overflow-wrap: anywhere; }

      /* ─── Divider ─── */
      .divider { height: 1px; background: var(--border); margin: 12px 0; }

      /* ─── Section label ─── */
      .section-label {
        font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em;
        color: var(--text3); margin-bottom: 8px; display: block;
      }

      /* ─── Responsive ─── */
      @media (max-width: 860px) {
        .dashboard-grid { grid-template-columns: 1fr; }
        .campaign-layout { grid-template-columns: 1fr; }
        .queue-card { grid-template-columns: 1fr; }
        .queue-thumb { width: 100%; aspect-ratio: 16/9; }
        .schedule-row { grid-template-columns: 1fr; }
        .history-card { grid-template-columns: 1fr; }
        .history-card .queue-thumb { width: 100%; aspect-ratio: 16/9; }
        .brand-context { display: none; }
        .account-context { grid-template-columns: 1fr 1fr; }
        .account-connect-flow { grid-column: 1 / -1; justify-items: start; }
        .account-connect-flow small { text-align: left; }
      }
      @media (max-width: 640px) {
        .app { padding: 16px 14px 64px; }
        .topbar { margin-bottom: 24px; }
        .topbar-inner { flex-direction: column; align-items: stretch; padding: 16px; }
        .brand-lockup { justify-content: space-between; }
        .topbar-actions { width: 100%; justify-content: flex-start; }
        .topbar-actions .btn-prompt-evolver, .topbar-actions .btn-dashboard { order: 5; flex: 1 1 100%; }
        .account-context { grid-template-columns: 1fr; margin-top: -8px; padding: 15px; }
        .account-connect-flow { grid-column: auto; }
        .account-connect-flow .btn { width: 100%; }
        .panel { padding: 20px; }
        .panel-head-rich { gap: 12px; }
        .form-grid { grid-template-columns: 1fr; }
        .campaign-intake, .campaign-account-grid { grid-template-columns: 1fr; }
        .campaign-video { grid-column: auto; }
        .campaign-job { grid-template-columns: 1fr; gap: 4px; }
        .form-grid .wide { grid-column: auto; }
        .upload-actions { justify-content: stretch; }
        .btn-create { width: 100%; }
        .rebuild-form { align-items: stretch; flex-direction: column; }
        .rebuild-form .actions .btn { width: 100%; }
        .section-head { align-items: flex-start; }
        .section-head p { max-width: 240px; }
        .queue-top { flex-direction: column; }
        .actions .btn, .card-actions .btn, .schedule-row .btn { width: 100%; justify-content: center; }
        .queue-card { padding: 14px; gap: 17px; }
        .history-panel > summary { padding: 17px; }
        .history-summary-meta .count { display: none; }
        .history-list { padding: 0 14px 14px; }
      }

      /* ─── CHANTER manual readability + client luxury pass ─── */
      :root {
        --bg: #f8f6f1;
        --text: #111217;
        --text2: #2e3038;
        --text3: #686c76;
        --border: rgba(17,18,23,0.14);
        --border2: rgba(17,18,23,0.28);
        --shadow: 0 20px 56px rgba(17,18,23,.08), 0 2px 10px rgba(17,18,23,.045);
      }
      .app { max-width: 1180px; padding-top: 44px; }
