<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= appName %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,700;0,9..40,900;1,9..40,300&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/autoposter-dashboard/assets/prompt-evolver-main.css" />
    <style>
      /* CHANTER AutoPoster design tokens — black / charcoal / gray / white */
      :root {
        --bg: #09090b;
        --bg2: #0e0e11;
        --surface: rgba(23,23,27,0.85);
        --surface2: rgba(255,255,255,0.045);
        --border: rgba(255,255,255,0.08);
        --border2: rgba(255,255,255,0.16);
        --accent: #f5f5f4;
        --accent2: #d4d4d8;
        --accent-glow: rgba(255,255,255,0.07);
        --accent2-glow: rgba(255,255,255,0.05);
        --text: #f5f5f4;
        --text2: #a1a1aa;
        --text3: #71717a;
        --danger: #c08585;
        --danger-bg: rgba(192,133,133,0.09);
        --warn: #b8a077;
        --warn-bg: rgba(184,160,119,0.09);
        --ok: #86b092;
        --ok-bg: rgba(134,176,146,0.09);
        --purple: #a3a3b8;
        --purple-bg: rgba(163,163,184,0.09);
        --cyan: #d4d4d8;
        --cyan-bg: rgba(212,212,216,0.06);
        --r: 18px;
        --r-sm: 10px;
        --r-xs: 6px;
        --shadow: 0 18px 50px rgba(0,0,0,.35), 0 2px 8px rgba(0,0,0,.2);
      }
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html { background: var(--bg); }
      body {
        font-family: 'DM Sans', ui-sans-serif, system-ui, sans-serif;
        color: var(--text);
        background: linear-gradient(180deg, #0b0b0d 0%, var(--bg) 58%, #08080a 100%);
        line-height: 1.5;
        -webkit-font-smoothing: antialiased;
        min-height: 100vh;
      }
      body::before {
        content: "";
        position: fixed; inset: 0; z-index: 0; pointer-events: none;
        background:
          radial-gradient(ellipse 68% 42% at 50% -14%, rgba(255,255,255,0.035) 0%, transparent 70%),
          linear-gradient(rgba(255,255,255,.01) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255,255,255,.01) 1px, transparent 1px);
        background-size: auto, 64px 64px, 64px 64px;
      }

      .app { position: relative; z-index: 1; max-width: 1240px; margin: 0 auto; padding: 34px 28px 96px; }

      /* ─── Topbar ─── */
      .topbar { margin-bottom: 34px; }
      .topbar-inner {
        display: flex; align-items: center; justify-content: space-between; gap: 24px;
        padding: 18px 20px;
        background: linear-gradient(135deg, rgba(26,26,30,.92), rgba(14,14,17,.88));
        border: 1px solid var(--border); border-radius: var(--r);
        box-shadow: var(--shadow); backdrop-filter: blur(24px);
      }
      .brand-lockup { display: flex; align-items: center; gap: 22px; min-width: 0; }
      .brand { display: flex; align-items: center; gap: 12px; }
      .brand-mark {
        width: 44px; height: 44px; border-radius: 12px;
        background: var(--accent);
        box-shadow: 0 6px 20px rgba(0,0,0,.35), inset 0 1px 0 rgba(255,255,255,.6);
        display: grid; place-items: center;
        font-weight: 900; font-size: 18px; color: #0a0a0b; letter-spacing: -0.03em;
      }
      .brand-title { font-size: 17px; font-weight: 900; letter-spacing: 0.05em; color: var(--text); }
      .brand-sub { font-size: 10px; font-weight: 700; color: #8e93a5; text-transform: uppercase; letter-spacing: 0.12em; }
      .brand-context { border-left: 1px solid var(--border); padding-left: 22px; min-width: 0; }
      .brand-context span { display: block; color: var(--text); font-size: 12px; font-weight: 700; }
      .brand-context p { margin-top: 2px; color: var(--text3); font-size: 11px; white-space: nowrap; }
      .topbar-actions { display: flex; align-items: center; justify-content: flex-end; gap: 9px; flex-wrap: wrap; }

      /* ─── Pills ─── */
      .pill {
        display: inline-flex; align-items: center; gap: 7px; min-height: 36px; padding: 6px 12px;
        border-radius: 999px; font-size: 12px; font-weight: 600; border: 1px solid var(--border);
        background: var(--surface2); color: var(--text2); white-space: nowrap;
      }
      .pill .dot { width: 7px; height: 7px; border: 2px solid rgba(255,255,255,.14); border-radius: 50%; background: currentColor; }
      .pill-ok   { border-color: rgba(134,176,146,.28); background: var(--ok-bg); color: var(--ok); }
      .pill-cyan { border-color: rgba(212,212,216,.22); background: var(--cyan-bg); color: var(--cyan); }
      .pill-warn { border-color: rgba(184,160,119,.28); background: var(--warn-bg); color: var(--warn); }
      .pill-err  { border-color: rgba(192,133,133,.28); background: var(--danger-bg); color: var(--danger); }
      .pill-creator { padding: 4px 11px 4px 4px; gap: 7px; }
      .pill-creator img { width: 22px; height: 22px; border-radius: 50%; object-fit: cover; background: var(--surface2); }

      /* ─── Buttons ─── */
      .btn {
        display: inline-flex; align-items: center; justify-content: center; gap: 6px;
        height: 38px; padding: 0 15px; border-radius: var(--r-sm);
        font-size: 13px; font-weight: 700; border: 1px solid transparent;
        cursor: pointer; text-decoration: none; transition: all 0.18s ease;
        background: none; color: inherit; font-family: inherit; white-space: nowrap;
      }
      .btn-primary   { background: var(--accent); color: #0a0a0b; box-shadow: 0 2px 12px rgba(0,0,0,.3); }
      .btn-primary:hover { background: #ffffff; transform: translateY(-1px); box-shadow: 0 4px 16px rgba(0,0,0,.35); }
      .btn-ghost     { border-color: var(--border); color: var(--text2); }
      .btn-ghost:hover { border-color: var(--border2); background: var(--surface2); color: var(--text); }
      .btn-secondary { border-color: var(--border2); color: var(--text); background: transparent; }
      .btn-secondary:hover { border-color: rgba(255,255,255,.28); background: var(--surface2); }
      .btn-danger    { border-color: rgba(192,133,133,.24); color: var(--danger); background: transparent; }
      .btn-danger:hover { background: var(--danger-bg); border-color: rgba(192,133,133,.4); }
      .btn-cyan      { background: transparent; border-color: var(--border2); color: var(--text); }
      .btn-cyan:hover{ background: var(--surface2); }
      .btn[disabled]  { opacity: 0.45; cursor: not-allowed; pointer-events: none; }
      .btn-dashboard { border-color: rgba(255,255,255,.14); background: rgba(255,255,255,.08); color: var(--text); }
      .btn-dashboard::after { content: "\2197"; color: var(--text3); font-size: 12px; }
      .btn-dashboard:hover { border-color: rgba(255,255,255,.24); background: rgba(255,255,255,.12); transform: translateY(-1px); }
      .btn-prompt-evolver { border-color: var(--border); background: var(--surface2); color: var(--text2); }
      .btn-prompt-evolver::after { content: "\2193"; color: var(--text3); font-size: 12px; }
      .btn-prompt-evolver:hover { border-color: var(--border2); background: rgba(255,255,255,.08); color: var(--text); transform: translateY(-1px); }
      .btn-disconnect { color: #85899a; }
      .logout-form { display: inline-flex; }

      .account-context {
        display: grid; grid-template-columns: minmax(180px, .7fr) minmax(210px, .72fr) minmax(280px, 1fr);
        align-items: center; gap: 20px; margin: -14px 0 30px; padding: 16px 18px;
        border: 1px solid var(--border); border-radius: 16px; background: rgba(15,15,18,.68); backdrop-filter: blur(18px);
      }
      .account-context-copy { display: grid; min-width: 0; }
      .account-context-label { color: var(--text3); font-size: 9px; font-weight: 800; letter-spacing: .12em; text-transform: uppercase; }
      .account-context-copy strong { margin-top: 3px; overflow: hidden; color: var(--text); font-size: 14px; text-overflow: ellipsis; white-space: nowrap; }
      .account-context-copy small { margin-top: 2px; color: var(--text3); font-size: 10px; }
      .account-selector label { gap: 5px; }
      .account-selector select { min-height: 40px; }
      .account-connect-flow { display: grid; justify-items: end; gap: 6px; }
      .account-connect-flow small { max-width: 410px; color: var(--text3); font-size: 10px; line-height: 1.45; text-align: right; }

      /* ─── Notice ─── */
      .notice {
        margin-bottom: 22px; padding: 13px 17px; border-radius: var(--r-sm);
        border: 1px solid var(--border2); background: var(--surface2);
        color: var(--text); font-size: 14px; font-weight: 500;
      }
      .instagram-status-banner {
        display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
        margin-bottom: 22px; padding: 12px 16px; border-radius: var(--r-sm);
        border: 1px solid rgba(184,160,119,.24); background: var(--warn-bg);
        color: var(--text2); font-size: 12px;
      }
      .instagram-status-banner strong { color: var(--warn); font-size: 13px; }
      .instagram-status-banner span + span::before { content: "\2022"; margin-right: 10px; color: var(--text3); }

      /* ─── Compliance Warning Banner ─── */
      .compliance-banner {
        margin-bottom: 22px; padding: 14px 18px;
        background: var(--warn-bg); border: 1px solid rgba(184,160,119,.22); border-radius: var(--r-sm);
        font-size: 13px; color: var(--warn); line-height: 1.6;
      }
      .compliance-banner strong { font-weight: 700; }
      .compliance-banner a { color: inherit; text-decoration: underline; }

      /* ─── Preflight ─── */
      .preflight-panel { margin-bottom: 42px; }
      .preflight-list { display: grid; gap: 8px; list-style: none; }
      .preflight-list li {
        display: flex; align-items: center; gap: 11px; padding: 10px 13px;
        border: 1px solid var(--border); border-radius: var(--r-sm); background: rgba(0,0,0,.18);
        color: var(--text2); font-size: 13px;
      }
      .preflight-list li .preflight-state { margin-left: auto; font-size: 10px; font-weight: 800; letter-spacing: .06em; text-transform: uppercase; color: var(--text3); white-space: nowrap; }
      .preflight-list li::before { content: ""; flex: 0 0 auto; width: 7px; height: 7px; border-radius: 50%; background: var(--text3); }
      .preflight-list li[data-state="pass"]::before { background: var(--ok); }
      .preflight-list li[data-state="pass"] .preflight-state { color: var(--ok); }
      .preflight-list li[data-state="blocked"]::before { background: var(--danger); }
      .preflight-list li[data-state="blocked"] .preflight-state { color: var(--danger); }
      .preflight-channels { display: grid; gap: 6px; margin-top: 10px; list-style: none; }
      .preflight-channels li {
        display: flex; align-items: center; gap: 10px; padding: 8px 13px;
        border: 1px solid var(--border); border-radius: var(--r-sm); background: rgba(0,0,0,.12);
        color: var(--text2); font-size: 12px; font-weight: 600;
      }
      .preflight-channels li .preflight-state { margin-left: auto; font-size: 10px; font-weight: 800; letter-spacing: .06em; text-transform: uppercase; color: var(--text3); white-space: nowrap; }
      .preflight-channels li[data-state="ready"] .preflight-state { color: var(--ok); }
      .preflight-channels li[data-state="blocked"] .preflight-state { color: var(--danger); }
      .preflight-channels li[data-state="idle"] { opacity: .55; }
      .preflight-verdict {
        display: flex; align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap;
        margin-top: 16px; padding: 13px 16px;
        border: 1px solid var(--border); border-radius: var(--r-sm); background: var(--surface2);
        color: var(--text2); font-size: 13px; font-weight: 600;
      }
      .preflight-verdict[data-tone="ready"] { border-color: rgba(134,176,146,.26); background: var(--ok-bg); color: var(--ok); }
      .preflight-verdict[data-tone="blocked"] { border-color: rgba(192,133,133,.24); background: var(--danger-bg); color: var(--danger); }
      .preflight-verdict .actions { margin: 0; }

      /* ─── Grid ─── */
      .dashboard-grid { display: grid; grid-template-columns: minmax(0, 1.32fr) minmax(320px, .68fr); gap: 22px; margin-bottom: 42px; }

      /* ─── Panel ─── */
      .panel {
        position: relative; overflow: hidden;
        background: linear-gradient(145deg, rgba(25,25,29,.92), rgba(14,14,17,.88));
        border: 1px solid var(--border);
        border-radius: var(--r); padding: 26px; backdrop-filter: blur(24px); box-shadow: var(--shadow);
      }
      .panel::before { content: ""; position: absolute; inset: 0 0 auto; height: 1px; background: linear-gradient(90deg, transparent, rgba(255,255,255,.18), transparent); }
      .panel-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 18px; }
      .panel-head h2 { font-size: 20px; font-weight: 800; letter-spacing: -0.025em; }
      .panel-meta { font-size: 13px; font-weight: 600; color: var(--text3); font-variant-numeric: tabular-nums; }
      .panel-head-rich { align-items: flex-start; margin-bottom: 22px; }
      .panel-head-rich p { margin-top: 5px; max-width: 430px; color: var(--text3); font-size: 12px; line-height: 1.55; }
      .panel-kicker, .section-kicker { display: block; margin-bottom: 5px; color: var(--text3); font-size: 9px; font-weight: 800; letter-spacing: .14em; text-transform: uppercase; }
      .panel-step { display: grid; width: 34px; height: 34px; place-items: center; border: 1px solid var(--border); border-radius: 10px; background: rgba(255,255,255,.035); color: var(--text3); font: 500 11px 'DM Mono', monospace; }

      /* ─── Forms ─── */
      .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
      .form-grid .wide { grid-column: 1 / -1; }
      label {
        display: grid; gap: 7px; font-size: 10px; font-weight: 700;
        text-transform: uppercase; letter-spacing: 0.05em; color: var(--text3);
      }
      .field-note {
        display: block; font-size: 11px; font-weight: 400; text-transform: none;
        color: var(--text3); letter-spacing: 0; line-height: 1.4;
      }
      input, select, textarea {
        width: 100%; background: rgba(4,5,9,.52); border: 1px solid var(--border);
        border-radius: var(--r-sm); padding: 11px 13px; color: var(--text);
        font-size: 13px; font-family: inherit; outline: none; transition: border-color .18s, box-shadow .18s, background .18s;
      }
      input:hover, select:hover, textarea:hover { border-color: rgba(255,255,255,.14); }
      input:focus, select:focus, textarea:focus { border-color: rgba(255,255,255,.42); background: rgba(4,5,9,.72); box-shadow: 0 0 0 3px var(--accent-glow); }
      input::placeholder, textarea::placeholder { color: var(--text3); }
      input[type="file"] { padding: 12px; cursor: pointer; min-height: 58px; border-style: dashed; background: rgba(255,255,255,.025); }
      input[type="file"]::file-selector-button {
        margin-right: 12px; padding: 8px 13px; border-radius: 8px; border: 1px solid var(--border2);
        background: rgba(255,255,255,.08); color: var(--text); font-weight: 700; cursor: pointer;
      }
      input[type="checkbox"] {
        width: 15px; height: 15px; cursor: pointer; accent-color: #e4e4e7;
        flex-shrink: 0; border-radius: 4px;
      }
      textarea { min-height: 92px; resize: vertical; line-height: 1.55; }
      select {
        appearance: none;
        background-image: url("data:image/svg+xml,%3Csvg width='10' height='6' viewBox='0 0 10 6' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1l4 4 4-4' stroke='%23606070' stroke-width='1.5' fill='none'/%3E%3C/svg%3E");
        background-repeat: no-repeat; background-position: right 11px center; padding-right: 30px;
      }
      .actions { display: flex; gap: 9px; margin-top: 16px; flex-wrap: wrap; }
      .actions .btn { height: 38px; padding: 0 16px; }
      .upload-zone { display: block; border: 1px solid rgba(255,255,255,.09); border-radius: 14px; background: rgba(255,255,255,.02); padding: 16px; }

      /* ─── Target Publishing Channels ─── */
      .channel-picker { display: grid; gap: 10px; border: 1px solid var(--border); border-radius: 14px; background: rgba(255,255,255,.02); padding: 16px; }
      .channel-picker-head { display: flex; align-items: center; justify-content: space-between; gap: 12px; }
      .channel-picker-head .field-heading { color: var(--text2); font-size: 11px; }
      .channel-select-all {
        border: 1px solid var(--border); border-radius: 8px; background: transparent;
        color: var(--text3); padding: 5px 9px; font: 700 10px inherit; letter-spacing: .04em;
        text-transform: uppercase; cursor: pointer; transition: border-color .16s, color .16s;
      }
      .channel-select-all:hover { border-color: var(--border2); color: var(--text); }
      .channel-options { display: grid; gap: 8px; }
      .channel-option {
        display: flex; align-items: center; gap: 11px; padding: 10px 13px;
        border: 1px solid var(--border); border-radius: var(--r-sm); background: rgba(0,0,0,.18);
        cursor: pointer; text-transform: none; letter-spacing: 0; transition: border-color .16s;
      }
      .channel-option:hover { border-color: var(--border2); }
      .channel-option input { width: 15px; height: 15px; }
      .channel-option-copy { display: grid; gap: 2px; min-width: 0; }
      .channel-option-copy strong { color: var(--text); font-size: 13px; font-weight: 700; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
      .channel-option-copy small { color: var(--text3); font-size: 10px; font-weight: 600; letter-spacing: .04em; text-transform: uppercase; }
      .channel-option.is-active-channel .channel-option-copy small { color: var(--ok); }
      .channel-option.is-disconnected { opacity: .55; cursor: not-allowed; }
      .channel-option.is-disconnected .channel-option-copy small { color: var(--warn); }
      .channel-plan { min-height: 16px; color: var(--text3); font-size: 11px; font-weight: 500; line-height: 1.45; }
      .channel-plan[data-tone="ready"] { color: var(--text2); }

      /* ─── Max Scheduler: Release Plan ─── */
      .schedule-plan { display: grid; gap: 10px; border: 1px solid var(--border); border-radius: 14px; background: rgba(255,255,255,.02); padding: 16px; }
      .schedule-plan-inputs { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
      .schedule-plan-inputs label { display: grid; gap: 5px; font-size: 11px; color: var(--text2); font-weight: 600; }
      .schedule-plan-inputs small { color: var(--text3); font-weight: 500; }
      .schedule-plan-list { display: grid; gap: 6px; margin-top: 4px; list-style: none; }
      .schedule-plan-list li {
        display: flex; align-items: center; gap: 10px; padding: 8px 12px;
        border: 1px solid var(--border); border-radius: var(--r-sm); background: rgba(0,0,0,.18);
        font-size: 12px; color: var(--text2);
      }
      .schedule-plan-list li.schedule-plan-summary { border-style: dashed; color: var(--text3); }
      .schedule-plan-list li[data-state="blocked"] { border-color: rgba(192,133,133,.3); color: var(--danger); }
      .schedule-plan-list li strong { color: var(--text); font-size: 12px; min-width: 110px; }
      .upload-zone .field-heading { display: block; margin-bottom: 3px; color: var(--text2); font-size: 11px; }
      .upload-zone .field-note { margin-bottom: 12px; }
      .url-field { margin-top: 2px; }
      .auto-caption-card {
        display: grid; gap: 8px; border: 1px solid var(--border); border-radius: 12px;
        background: rgba(255,255,255,.03); padding: 13px 14px;
      }
      .auto-caption-row { display: flex; align-items: center; justify-content: space-between; gap: 16px; cursor: pointer; }
      .auto-caption-copy { display: grid; gap: 3px; min-width: 0; }
      .auto-caption-copy strong { color: var(--text2); font-size: 12px; letter-spacing: .02em; }
      .auto-caption-copy span { color: var(--text3); font-size: 11px; font-weight: 400; line-height: 1.4; }
      .auto-caption-row input { width: 18px; height: 18px; }
      .auto-caption-status { min-height: 16px; color: var(--text3); font-size: 11px; line-height: 1.45; }
      .auto-caption-status[data-tone="working"] { color: var(--accent2); }
      .auto-caption-status[data-tone="success"] { color: var(--ok); }
      .auto-caption-status[data-tone="error"] { color: var(--danger); }
      .auto-music-divider { height: 1px; background: var(--border); margin: 2px 0; }
      .upload-actions { justify-content: flex-end; margin-top: 20px; }
      .submit-feedback {
        display: grid; gap: 9px; margin-top: 20px; padding: 13px 14px;
        border: 1px solid var(--border); border-radius: 12px; background: rgba(255,255,255,.03);
      }
      .submit-feedback[hidden] { display: none; }
      .submit-feedback[data-tone="success"] { border-color: rgba(134,176,146,.28); background: var(--ok-bg); }
      .submit-feedback[data-tone="error"] { border-color: rgba(192,133,133,.28); background: var(--danger-bg); }
      .upload-progress { position: relative; height: 6px; border-radius: 999px; background: rgba(255,255,255,.07); overflow: hidden; }
      .upload-progress-fill {
        position: absolute; inset: 0 auto 0 0; width: 0%;
        border-radius: inherit; background: var(--accent); transition: width .2s ease;
      }
      .submit-status { color: var(--text2); font-size: 12px; line-height: 1.5; }
      .submit-feedback[data-tone="success"] .submit-status { color: var(--ok); }
      .submit-feedback[data-tone="error"] .submit-status { color: var(--danger); }
      .btn-create { min-width: 190px; height: 44px !important; }
      .btn-create::after { content: "\2192"; font-size: 16px; transition: transform .18s; }
      .btn-create:hover::after { transform: translateX(2px); }
      .schedule-clock { display: grid; margin-bottom: 20px; border: 1px solid var(--border); border-radius: 15px; background: rgba(255,255,255,.03); padding: 17px; }
      .schedule-clock span { color: var(--text3); font-size: 9px; font-weight: 800; letter-spacing: .1em; text-transform: uppercase; }
      .schedule-clock strong { margin: 2px 0; color: var(--text); font: 500 30px 'DM Mono', monospace; letter-spacing: -.04em; }
      .schedule-clock small { color: #7d8293; font-size: 10px; }
      .schedule-settings .actions .btn { width: 100%; }
      .schedule-divider { height: 1px; margin: 22px 0 17px; background: var(--border); }
      .rebuild-form { display: flex; align-items: center; justify-content: space-between; gap: 16px; }
      .rebuild-form p { display: flex; align-items: flex-start; gap: 8px; color: var(--text3); font-size: 11px; line-height: 1.5; }
      .rebuild-form .actions { flex: 0 0 auto; margin: 0; }
      .status-dot { flex: 0 0 auto; width: 6px; height: 6px; margin-top: 5px; border-radius: 50%; background: var(--text2); }

      /* ─── Interaction Controls (TikTok Required UX) ─── */
      .interaction-controls { display: grid; gap: 8px; }
      .check-row {
        display: flex; align-items: center; gap: 10px; padding: 9px 12px;
        background: rgba(0,0,0,.2); border: 1px solid var(--border); border-radius: var(--r-sm);
        cursor: pointer; transition: border-color 0.15s;
      }
      .check-row:hover { border-color: var(--border2); }
      .check-row.disabled-row { opacity: 0.45; cursor: not-allowed; }
      .check-row label { font-size: 13px; font-weight: 500; color: var(--text2); text-transform: none; letter-spacing: 0; cursor: pointer; margin: 0; }
      .check-row.disabled-row label { cursor: not-allowed; }
      .check-hint { font-size: 11px; color: var(--text3); margin-left: auto; font-style: italic; }

      /* ─── Content Disclosure ─── */
      .disclosure-section {
        border: 1px solid var(--border); border-radius: var(--r-sm); overflow: hidden; margin-top: 12px;
      }
      .disclosure-header {
        display: flex; align-items: center; justify-content: space-between; padding: 11px 14px;
        background: var(--surface2); cursor: pointer;
      }
      .disclosure-header span { font-size: 12px; font-weight: 700; color: var(--text2); }
      .disclosure-body { padding: 12px 14px; display: grid; gap: 8px; }
      .disclosure-note { font-size: 11px; color: var(--text3); line-height: 1.5; }

      /* Toggle switch */
      .toggle-wrap { display: flex; align-items: center; gap: 10px; }
      .toggle { position: relative; width: 36px; height: 20px; flex-shrink: 0; }
      .toggle input { opacity: 0; width: 0; height: 0; }
      .toggle-slider {
        position: absolute; inset: 0; border-radius: 20px; background: var(--border2);
        cursor: pointer; transition: background 0.2s;
      }
      .toggle-slider::before {
        content: ""; position: absolute; width: 14px; height: 14px; border-radius: 50%;
        background: white; left: 3px; top: 3px; transition: transform 0.2s; box-shadow: 0 1px 4px rgba(0,0,0,.3);
      }
      .toggle input:checked + .toggle-slider { background: var(--accent); }
      .toggle input:checked + .toggle-slider::before { transform: translateX(16px); background: #0a0a0b; }

      /* ─── Music Disclosure (Required) ─── */
      .music-declaration {
        padding: 11px 14px; border-radius: var(--r-sm);
        border: 1px solid var(--border); background: var(--surface2);
        font-size: 12px; color: var(--text3); line-height: 1.6;
      }
      .music-declaration a { color: var(--text2); text-decoration: underline; }
      .music-declaration strong { color: var(--text2); font-weight: 600; }

      /* ─── Queue ─── */
      .queue-section { margin-bottom: 34px; }
      .section-head { display: flex; align-items: flex-end; justify-content: space-between; gap: 20px; margin-bottom: 20px; }
      .section-head h2 { font-size: 24px; font-weight: 800; letter-spacing: -0.03em; }
      .section-head p { margin-top: 4px; color: var(--text3); font-size: 12px; }
      .count { font-size: 12px; font-weight: 700; color: var(--text3); }
      .count-prominent { border: 1px solid var(--border); border-radius: 999px; background: rgba(255,255,255,.035); padding: 6px 11px; color: var(--text2); }
      .queue-list { display: grid; gap: 18px; }

      /* ─── Mark / Delete Marked toolbar ─── */
      .mark-toolbar {
        display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
        margin-bottom: 16px; padding: 10px 14px;
        border: 1px solid rgba(192,133,133,.24); border-radius: var(--r-sm); background: var(--danger-bg);
      }
      .mark-toolbar[hidden] { display: none; }
      .mark-count { color: var(--text); font-size: 12px; font-weight: 700; }
      .mark-status { color: var(--text2); font-size: 12px; }
      .btn-mark[aria-pressed="true"] { border-color: rgba(192,133,133,.4); background: var(--danger-bg); color: var(--danger); }
      .queue-card.is-marked { border-color: rgba(192,133,133,.45); }

      /* ─── Release Queue view mode ─── */
      .queue-view-toggle { display: flex; gap: 8px; margin-bottom: 10px; }
      .queue-view-toggle .btn { height: 32px; padding: 0 13px; font-size: 11px; transition: background-color .12s ease, border-color .12s ease, color .12s ease; }
      [data-queue-view-region][aria-busy="true"] { opacity: .6; pointer-events: none; transition: opacity .12s ease; }
      .queue-view-note {
        margin-bottom: 16px; padding: 10px 14px; border-radius: var(--r-sm);
        border: 1px solid var(--border); background: rgba(255,255,255,.02);
        color: var(--text3); font-size: 12px;
      }
      .campaign-summary-strip { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 12px; margin-bottom: 20px; }
      .campaign-summary-card {
        display: grid; gap: 6px; border: 1px solid var(--border); border-radius: var(--r-sm);
        background: rgba(255,255,255,.02); padding: 12px 14px;
      }
      .campaign-summary-card header { display: flex; align-items: baseline; justify-content: space-between; gap: 10px; }
      .campaign-summary-card header strong { font-size: 12px; color: var(--text); }
      .campaign-summary-card header span { font-size: 10px; color: var(--text3); font-weight: 600; }
      .campaign-summary-card[data-state="attention"] { border-color: rgba(192,133,133,.3); }
      .campaign-summary-range { font-size: 11px; color: var(--text2); }
      .campaign-summary-jobs { list-style: none; display: grid; gap: 3px; }
      .campaign-summary-jobs li { font-size: 11px; color: var(--text3); }

      /* ─── Queue Card ─── */
      .queue-card {
        display: grid; grid-template-columns: 150px 1fr; gap: 22px;
        background: linear-gradient(145deg, rgba(24,24,28,.9), rgba(14,14,17,.86)); border: 1px solid var(--border);
        border-radius: var(--r); padding: 20px; backdrop-filter: blur(22px);
        box-shadow: 0 14px 42px rgba(0,0,0,.16);
        transition: transform .18s, border-color .18s, box-shadow .18s;
      }
      .queue-card:hover { transform: translateY(-2px); border-color: var(--border2); box-shadow: 0 22px 54px rgba(0,0,0,.23); }
      .queue-thumb {
        position: relative; width: 150px; aspect-ratio: 4/5;
        border-radius: 14px; overflow: hidden; background: #090912;
        border: 1px solid var(--border); flex-shrink: 0;
      }
      .queue-thumb img, .queue-thumb video { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; display: block; }
      .queue-thumb .thumb-placeholder { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: contain; padding: 22px; opacity: 0; filter: saturate(0.5); }
      .queue-thumb.is-missing [data-preview-media] { display: none; }
      .queue-thumb.is-missing .thumb-placeholder { opacity: 0.3; }
      .media-chip {
        position: absolute; bottom: 7px; right: 7px; padding: 3px 8px; border-radius: 5px;
        background: rgba(0,0,0,.65); backdrop-filter: blur(8px); font-size: 9px; font-weight: 800;
        text-transform: uppercase; letter-spacing: 0.05em; color: var(--text2); border: 1px solid var(--border);
      }
      .queue-main { min-width: 0; display: flex; flex-direction: column; gap: 14px; }
      .queue-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 10px; }
      .queue-title h3 { font-size: 16px; font-weight: 750; color: var(--text); overflow-wrap: anywhere; line-height: 1.3; }
      .queue-meta { font-size: 12px; color: var(--text3); font-weight: 500; margin-top: 3px; }
      .caption-preview { font-size: 13px; color: var(--text2); line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }

      .result-message {
        font-size: 12px; line-height: 1.5; padding: 9px 12px; border-radius: var(--r-sm);
        background: rgba(0,0,0,.2); border: 1px solid var(--border); color: var(--text2);
      }
      .result-message.is-failed { border-color: rgba(192,133,133,.22); background: var(--danger-bg); color: var(--danger); }

      /* ─── Badges ─── */
      .badge {
        display: inline-flex; align-items: center; gap: 5px; padding: 4px 9px; border-radius: 999px;
        font-size: 10px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em;
        border: 1px solid var(--border); background: var(--surface2); color: var(--text3);
        white-space: nowrap; flex-shrink: 0;
      }
      .badge::before { content: ""; width: 5px; height: 5px; border-radius: 50%; background: currentColor; }
      .badge.pending, .badge.scheduled { border-color: rgba(184,160,119,.26); background: var(--warn-bg); color: var(--warn); }
      .badge.ready, .badge.verification { border-color: rgba(163,163,184,.26); background: var(--purple-bg); color: var(--purple); }
      .badge.posted, .badge.accepted { border-color: rgba(134,176,146,.26); background: var(--ok-bg); color: var(--ok); }
      .badge.publishing { border-color: rgba(212,212,216,.24); background: var(--cyan-bg); color: var(--cyan); }
      .badge.failed { border-color: rgba(192,133,133,.24); background: var(--danger-bg); color: var(--danger); }
      /* Approval gate chips — unapproved must be impossible to miss */
      .badge.approval-required { border-color: rgba(192,133,133,.38); background: var(--danger-bg); color: var(--danger); }
      .badge.approval-ok { border-color: rgba(134,176,146,.26); background: var(--ok-bg); color: var(--ok); }
      .queue-badges { display: flex; gap: 6px; flex-wrap: wrap; justify-content: flex-end; flex-shrink: 0; }

      /* ─── Evidence log ─── */
      .evidence-list { list-style: none; display: grid; gap: 5px; }
      .evidence-list li { font-size: 11px; color: var(--text3); line-height: 1.5; }
      .evidence-list li strong { color: var(--text2); font-weight: 700; font-size: 10px; text-transform: uppercase; letter-spacing: .04em; }

      /* ─── Schedule Form ─── */
      .schedule-form { display: grid; gap: 14px; }
      .schedule-row { display: grid; grid-template-columns: minmax(190px, 1fr) minmax(150px, .52fr) auto; gap: 12px; align-items: end; }
      .card-actions { display: flex; gap: 8px; flex-wrap: wrap; }

      /* ─── Advanced Details ─── */
      .advanced { margin-top: 4px; }
      .advanced summary { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text3); cursor: pointer; user-select: none; }
      .advanced-body { margin-top: 11px; display: grid; gap: 11px; }
      .advanced pre {
        background: rgba(0,0,0,.3); border: 1px solid var(--border); border-radius: var(--r-sm);
        padding: 12px; font-size: 11px; line-height: 1.6; color: var(--text2);
        font-family: 'DM Mono', monospace; overflow: auto; max-height: 220px;
        white-space: pre-wrap; overflow-wrap: anywhere;
      }

      /* ─── Unaudited Notice ─── */
      .unaudited-note {
        padding: 11px 14px; border-radius: var(--r-sm);
        border: 1px solid rgba(184,160,119,.24); background: var(--warn-bg);
        font-size: 12px; color: var(--warn); line-height: 1.5;
      }
      .unaudited-note strong { font-weight: 700; }

      /* ─── Empty State ─── */
      .empty-state {
        display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 7px;
        padding: 68px 24px; border: 1px dashed rgba(255,255,255,.12); border-radius: var(--r);
        background: linear-gradient(145deg, rgba(255,255,255,.025), rgba(255,255,255,.012)); color: var(--text3); text-align: center;
      }
      .empty-state p { margin-top: 4px; font-size: 16px; font-weight: 750; color: var(--text2); }
      .empty-state span { font-size: 12px; }
      .empty-state .empty-icon { display: grid; width: 42px; height: 42px; place-items: center; border: 1px solid var(--border2); border-radius: 13px; background: var(--surface2); color: var(--text2); font-size: 22px; font-weight: 300; }

      /* ─── History ─── */
      .history-panel {
        overflow: hidden; background: linear-gradient(145deg, rgba(24,24,28,.84), rgba(14,14,17,.8)); border: 1px solid var(--border); border-radius: var(--r); backdrop-filter: blur(22px); box-shadow: 0 14px 42px rgba(0,0,0,.14);
      }
      .history-panel > summary {
        display: flex; align-items: center; justify-content: space-between;
        padding: 20px 22px; cursor: pointer; font-size: 15px; font-weight: 800; list-style: none; transition: background .18s;
      }
      .history-panel > summary:hover { background: rgba(255,255,255,.025); }
      .history-panel > summary::-webkit-details-marker { display: none; }
      .history-title { display: flex; align-items: center; gap: 12px; }
      .history-title > span:last-child { display: grid; }
      .history-title small { color: var(--text3); font-size: 9px; font-weight: 800; letter-spacing: .12em; text-transform: uppercase; }
      .history-title strong { color: var(--text); font-size: 15px; }
      .history-icon { position: relative; width: 36px; height: 36px; border: 1px solid var(--border); border-radius: 11px; background: rgba(255,255,255,.035); }
      .history-icon::before, .history-icon::after { content: ""; position: absolute; left: 9px; right: 9px; height: 1px; background: var(--text3); }
      .history-icon::before { top: 13px; box-shadow: 0 5px 0 var(--text3); }
      .history-icon::after { top: 8px; left: 13px; right: 13px; }
      .history-summary-meta { display: flex; align-items: center; gap: 12px; }
      .history-summary-meta .count { border: 1px solid var(--border); border-radius: 999px; padding: 5px 9px; background: rgba(255,255,255,.03); }
      .history-chevron { width: 8px; height: 8px; border-right: 1px solid var(--text3); border-bottom: 1px solid var(--text3); transform: rotate(45deg); transition: transform .18s; }
      .history-panel[open] .history-chevron { transform: rotate(225deg); }
      .history-list { padding: 0 22px 22px; display: grid; gap: 11px; }
      .creative-engine-panel { margin-top: 24px; }
      .creative-engine-body { padding: 0 22px 22px; border-top: 1px solid var(--border); }
      .creative-engine-body .prompt-evolver { margin: 22px 0 0; }
      .history-card {
        display: grid; grid-template-columns: 90px 1fr; gap: 14px; padding: 14px;
        border-radius: var(--r-sm); border: 1px solid var(--border); background: rgba(0,0,0,.18);
        transition: border-color 0.18s;
      }
      .history-card:hover { border-color: var(--border2); }
      .history-card .queue-thumb { width: 90px; aspect-ratio: 1; }
      .history-empty { padding: 36px; text-align: center; color: var(--text3); font-size: 13px; }

      /* ─── Divider ─── */
      .divider { height: 1px; background: var(--border); margin: 12px 0; }

      /* ─── Section label ─── */
      .section-label {
        font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em;
        color: var(--text3); margin-bottom: 8px; display: block;
      }

      /* ─── Responsive ─── */
      @media (max-width: 860px) {
        .dashboard-grid { grid-template-columns: 1fr; }
        .queue-card { grid-template-columns: 1fr; }
        .queue-thumb { width: 100%; aspect-ratio: 16/9; }
        .schedule-row { grid-template-columns: 1fr; }
        .history-card { grid-template-columns: 1fr; }
        .history-card .queue-thumb { width: 100%; aspect-ratio: 16/9; }
        .brand-context { display: none; }
        .account-context { grid-template-columns: 1fr 1fr; }
        .account-connect-flow { grid-column: 1 / -1; justify-items: start; }
        .account-connect-flow small { text-align: left; }
      }
      @media (max-width: 640px) {
        .app { padding: 16px 14px 64px; }
        .topbar { margin-bottom: 24px; }
        .topbar-inner { flex-direction: column; align-items: stretch; padding: 16px; }
        .brand-lockup { justify-content: space-between; }
        .topbar-actions { width: 100%; justify-content: flex-start; }
        .topbar-actions .btn-prompt-evolver, .topbar-actions .btn-dashboard { order: 5; flex: 1 1 100%; }
        .account-context { grid-template-columns: 1fr; margin-top: -8px; padding: 15px; }
        .account-connect-flow { grid-column: auto; }
        .account-connect-flow .btn { width: 100%; }
        .panel { padding: 20px; }
        .panel-head-rich { gap: 12px; }
        .form-grid { grid-template-columns: 1fr; }
        .form-grid .wide { grid-column: auto; }
        .schedule-plan-inputs { grid-template-columns: 1fr; }
        .upload-actions { justify-content: stretch; }
        .btn-create { width: 100%; }
        .rebuild-form { align-items: stretch; flex-direction: column; }
        .rebuild-form .actions .btn { width: 100%; }
        .section-head { align-items: flex-start; }
        .section-head p { max-width: 240px; }
        .queue-top { flex-direction: column; }
        .actions .btn, .card-actions .btn, .schedule-row .btn { width: 100%; justify-content: center; }
        .queue-card { padding: 14px; gap: 17px; }
        .history-panel > summary { padding: 17px; }
        .history-summary-meta .count { display: none; }
        .history-list { padding: 0 14px 14px; }
        .creative-engine-body { padding: 0 14px 14px; }
      }
    </style>
  </head>
  <body>
    <%
      const statusOf = (post) => String((post && post.status) || 'pending').toLowerCase();
      const activePosts = posts.filter((post) => statusOf(post) !== 'posted');
      const historyPosts = posts.filter((post) => statusOf(post) === 'posted');
      const privacyOptions = Array.isArray(creatorInfo && creatorInfo.privacy_level_options) && creatorInfo.privacy_level_options.length > 0
        ? creatorInfo.privacy_level_options
        : ['SELF_ONLY'];
      // Client-facing status vocabulary: Ready, Scheduled, Posting, Needs
      // attention, Posted. Keeps result.tone (drives badge color) untouched.
      const displayResultLabel = (result, post) => {
        const tone = String((result && result.tone) || '').toLowerCase();
        if (tone === 'failed' || tone === 'verification') return 'Needs attention';
        if (tone === 'accepted') return 'Posted';
        if (tone === 'publishing') return 'Posting';
        return (post && post.scheduledAt) ? 'Scheduled' : 'Ready';
      };
      const statusWord = (status) => {
        const value = String(status || 'pending').toLowerCase();
        if (value === 'posted') return 'Posted';
        if (value === 'processing') return 'Posting';
        if (value === 'failed' || value === 'ready') return 'Needs attention';
        if (value === 'scheduled') return 'Scheduled';
        return 'Ready';
      };
      const captionPreview = (post) => helpers.fullCaption(post) || 'No caption';
      const selectedPrivacy = (post) => {
        const value = String((post && post.privacyLevel) || 'SELF_ONLY').trim() || 'SELF_ONLY';
        return privacyOptions.includes(value) ? value : privacyOptions[0];
      };
      const isPhotoPost = (post) => helpers.mediaType(post) === 'photo';
    %>

    <div class="app">
      <!-- ─── Topbar ─── -->
      <header class="topbar">
        <div class="topbar-inner">
          <div class="brand-lockup">
            <div class="brand">
              <div class="brand-mark">C</div>
              <div class="brand-text">
                <div class="brand-title">CHANTER</div>
                <div class="brand-sub">AutoPoster</div>
              </div>
            </div>
            <div class="brand-context">
              <span>Command Center</span>
              <p>Prepare, release, and review TikTok campaigns</p>
            </div>
          </div>
          <div class="topbar-actions">
            <% if (tiktokConfigured) { %>
              <div class="pill pill-ok"><span class="dot"></span>Channel Connected</div>
              <% if (creatorInfo) { %>
                <div class="pill pill-creator">
                  <img src="<%= creatorInfo.creator_avatar_url || '/assets/chanter-logo.png' %>" alt="" />
                  <span><%= creatorInfo.creator_username ? `@${creatorInfo.creator_username}` : (creatorInfo.creator_nickname || 'Creator') %></span>
                </div>
              <% } %>
            <% } else { %>
              <div class="pill pill-warn"><span class="dot"></span>Channel Required</div>
              <a class="btn btn-primary" href="/connect/tiktok">Connect Channel</a>
            <% } %>
            <a class="btn btn-prompt-evolver" href="#creative-tools" data-creative-tools-link>Creative Tools</a>
            <a class="btn btn-dashboard" href="/private/autoposter/dashboard">Command Center</a>
            <% if (tiktokConfigured) { %>
              <a class="btn btn-ghost btn-disconnect" href="/disconnect/tiktok">Remove Channel</a>
            <% } %>
            <form class="logout-form" action="/logout" method="post"><button class="btn btn-ghost" type="submit">End Session</button></form>

            <% if (enableInstagram) { %>
              <%
                const igPillClass = instagramStatus.state === 'ready' ? 'pill-cyan'
                  : instagramStatus.state === 'token_expired' ? 'pill-err'
                  : instagramStatus.connected ? 'pill-ok' : 'pill-warn';
              %>
              <div class="pill <%= igPillClass %>"><span class="dot"></span>Instagram <%= instagramStatus.label %></div>
              <% if (instagramStatus.connected) { %>
                <a class="btn btn-ghost" href="/disconnect/instagram">Disconnect IG</a>
              <% } else { %>
                <a class="btn btn-secondary" href="/auth/instagram/start">Connect Instagram</a>
              <% } %>
            <% } %>
          </div>
        </div>
      </header>

      <% if (tiktokAccounts.length > 0) { %>
        <section class="account-context" aria-label="Publishing channel">
          <div class="account-context-copy">
            <span class="account-context-label">Publishing Channel</span>
            <strong><%= (creatorInfo && creatorInfo.creator_username) ? `@${creatorInfo.creator_username}` : (activeTikTokAccount && activeTikTokAccount.username) ? `@${activeTikTokAccount.username}` : (activeTikTokAccount && activeTikTokAccount.displayName) || 'TikTok channel' %></strong>
            <small><%= activeTikTokAccount && activeTikTokAccount.connected ? 'Connected' : 'Disconnected — reconnect to post from this channel' %></small>
            <% if (channelReadiness) { %>
              <small data-channel-readiness>
                Provider: <%= channelReadiness.provider.displayName %> (<%= channelReadiness.provider.implementationStatus %>)
                · <%= channelReadiness.connectionLabel %>
                · <%= channelReadiness.publishingLabel %><%= channelReadiness.lastVerifiedAt ? ` · Verified ${helpers.formatDateTime(channelReadiness.lastVerifiedAt)}` : '' %>
              </small>
            <% } %>
          </div>
          <form class="account-selector" action="/private/autoposter/account" method="post">
            <label>
              Switch channel
              <select name="accountId" onchange="this.form.submit()">
                <% tiktokAccounts.forEach(function(account) { %>
                  <option value="<%= account.accountId %>" <%= activeTikTokAccount && activeTikTokAccount.accountId === account.accountId ? 'selected' : '' %>>
                    <%= account.username ? `@${account.username}` : (account.displayName || `TikTok ${account.accountId.slice(0, 8)}`) %><%= account.connected ? '' : ' (disconnected)' %>
                  </option>
                <% }); %>
              </select>
            </label>
          </form>
          <div class="account-connect-flow">
            <a class="btn btn-secondary" href="/connect/tiktok?new=1">Connect Another Channel</a>
            <small>Use a private browser window to connect a different TikTok account.</small>
          </div>
          <% if (activeTikTokAccount) { %>
            <div class="account-connect-flow">
              <form action="/private/autoposter/account/<%= activeTikTokAccount.accountId %>/client-access" method="post" style="display:inline;">
                <button class="btn btn-secondary" type="submit"><%= activeTikTokAccount.clientAccessEnabled ? 'Rotate Client Access Code' : 'Generate Client Access Code' %></button>
              </form>
              <% if (activeTikTokAccount.clientAccessEnabled) { %>
                <form action="/private/autoposter/account/<%= activeTikTokAccount.accountId %>/client-access/revoke" method="post" style="display:inline;">
                  <button class="btn btn-ghost" type="submit">Revoke Client Access</button>
                </form>
              <% } %>
              <small>Client portal isolated at /client/autoposter — only this channel's own account and queue.</small>
            </div>
          <% } %>
        </section>
      <% } %>

      <% if (notice) { %><div class="notice"><%= notice %></div><% } %>

      <% if (instagramHealth && !instagramHealth.configured) { %>
        <div class="instagram-status-banner" role="status" aria-label="Instagram configuration status">
          <strong>Instagram: Not configured</strong>
          <span>Dry-run mode active</span>
          <span>Add Meta API keys to enable Instagram publishing</span>
        </div>
      <% } %>

      <%
        const isUnauditedApp = !tiktokConfigured;
        const showUnauditedWarning = tiktokConfigured && creatorInfo && privacyOptions.length > 0 && !privacyOptions.includes('PUBLIC_TO_EVERYONE');
      %>
      <% if (showUnauditedWarning) { %>
        <div class="unaudited-note">
          <strong>Awaiting TikTok review:</strong> posts are private (Only Me) and limited to 5 viewers a day until review is complete. <a href="https://developers.tiktok.com/doc/content-sharing-guidelines/" target="_blank" rel="noreferrer" style="color:inherit;text-decoration:underline;">Learn more</a>.
        </div>
      <% } %>

      <!-- ─── Dashboard Grid ─── -->
      <div class="dashboard-grid" aria-label="Poster controls">
        <section class="panel panel-upload">
          <div class="panel-head panel-head-rich">
            <div>
              <span class="panel-kicker">New post</span>
              <h2>Media</h2>
              <p>Add a video and write the caption. TikTok posting is video-only.</p>
            </div>
            <span class="panel-step">01</span>
          </div>
          <form class="upload-form" action="/upload" method="post" enctype="multipart/form-data" data-upload-form>
            <div class="form-grid">
              <label class="wide upload-zone">
                <span class="field-heading">Video</span>
                <span class="field-note">MP4, MOV, or WebM video. You can add more than one. Images can't be scheduled.</span>
                <input type="file" name="images" accept="video/mp4,video/quicktime,video/webm" multiple data-media-upload data-reset-after-submit />
              </label>
              <% if (tiktokAccounts.length > 0) { %>
                <div class="wide channel-picker" data-channel-picker>
                  <div class="channel-picker-head">
                    <span class="field-heading">Target Publishing Channels</span>
                    <button type="button" class="channel-select-all" data-select-all-channels>Select all connected</button>
                  </div>
                  <span class="field-note">Posts to every channel you select. Disconnected channels can't be scheduled.</span>
                  <div class="channel-options">
                    <% tiktokAccounts.forEach(function(channel) { %>
                      <%
                        const channelHandle = channel.username ? `@${channel.username}` : (channel.displayName || `TikTok ${String(channel.accountId || '').slice(0, 8)}`);
                        const isActiveChannel = activeTikTokAccount && activeTikTokAccount.accountId === channel.accountId;
                      %>
                      <label class="channel-option <%= channel.connected ? '' : 'is-disconnected' %> <%= isActiveChannel && channel.connected ? 'is-active-channel' : '' %>">
                        <input
                          type="checkbox"
                          name="targetChannels"
                          value="<%= channel.accountId %>"
                          data-channel-option
                          data-channel-handle="<%= channelHandle %>"
                          data-channel-connected="<%= channel.connected ? 'true' : 'false' %>"
                          <%= channel.connected ? '' : 'disabled' %>
                          <%= isActiveChannel && channel.connected ? 'checked' : '' %>
                        />
                        <span class="channel-option-copy">
                          <strong><%= channelHandle %></strong>
                          <small><%= channel.connected ? (isActiveChannel ? 'Active channel' : 'Connected') : 'Reconnect Required' %></small>
                        </span>
                      </label>
                    <% }); %>
                  </div>
                  <p class="channel-plan" data-channel-plan aria-live="polite"></p>
                </div>

                <div class="wide schedule-plan" data-schedule-plan>
                  <div class="channel-picker-head">
                    <span class="field-heading">Custom start time</span>
                  </div>
                  <span class="field-note">Optional. Set an exact start time — each channel posts a few minutes after the last. Leave blank to use the daily posting time instead.</span>
                  <div class="schedule-plan-inputs">
                    <label>
                      Start date
                      <input type="date" name="startDate" data-schedule-start-date data-reset-after-submit />
                    </label>
                    <label>
                      Start time
                      <input type="time" name="startTime" data-schedule-start-time data-reset-after-submit />
                      <small>Your local time (<span data-schedule-tz>—</span>).</small>
                    </label>
                    <label>
                      Minutes between channels
                      <input type="number" name="offsetMinutes" min="0" step="1" value="<%= defaultOffsetMinutes %>" data-schedule-offset />
                    </label>
                  </div>
                  <input type="hidden" name="timezoneOffsetMinutes" data-timezone-offset />
                  <ul class="schedule-plan-list" data-schedule-plan-list aria-live="polite"></ul>
                </div>
              <% } %>
              <div class="wide auto-caption-card">
                <label class="auto-caption-row">
                  <span class="auto-caption-copy">
                    <strong>Auto Caption</strong>
                    <span>Writes a caption for you from the video.</span>
                  </span>
                  <input
                    type="checkbox"
                    name="autoCaption"
                    value="1"
                    data-auto-caption-toggle
                    <%= !autoCaptionConfigured ? 'disabled' : '' %>
                  />
                </label>
                <p class="auto-caption-status" data-auto-caption-status aria-live="polite">
                  <%= autoCaptionConfigured ? 'Turn on Auto Caption, then choose a video.' : 'Auto Caption isn\'t set up yet.' %>
                </p>
                <div class="auto-music-divider" aria-hidden="true"></div>
                <label class="auto-caption-row">
                  <span class="auto-caption-copy">
                    <strong>Auto Music</strong>
                    <span>Adds background music to your video.</span>
                  </span>
                  <input
                    type="checkbox"
                    name="autoMusic"
                    value="1"
                    data-auto-music-toggle
                    <%= !autoMusicConfigured ? 'disabled' : '' %>
                  />
                </label>
                <p class="auto-caption-status" data-auto-music-status aria-live="polite">
                  <%= autoMusicConfigured ? 'Turn on Auto Music, then choose a video.' : 'Auto Music isn\'t set up yet.' %>
                </p>
                <input type="hidden" name="autoMusicToken" value="" data-auto-music-token data-reset-after-submit />
              </div>
              <label class="wide url-field">
                Public Media URL
                <span class="field-note">Optional — use if your video is already hosted online. Must point to an MP4, MOV, or WebM file.</span>
                <input type="url" name="publicMediaUrl" placeholder="https://example.com/media.mp4" data-public-media-url data-reset-after-submit />
              </label>
              <label>
                Caption
                <textarea name="caption" placeholder="Write a caption…" data-caption-input data-reset-after-submit></textarea>
              </label>
              <label>
                Hashtags
                <textarea name="hashtags" placeholder="#chanter #viral" data-hashtags-input></textarea>
              </label>
            </div>
            <div class="submit-feedback" data-submit-feedback aria-live="polite" hidden>
              <div class="upload-progress" data-upload-progress hidden>
                <div class="upload-progress-fill" data-upload-progress-fill></div>
              </div>
              <p class="submit-status" data-submit-status></p>
            </div>
            <div class="actions upload-actions"><button type="submit" class="btn btn-primary btn-create" <%= !tiktokConfigured ? 'disabled' : '' %>>Prepare Campaign</button></div>
          </form>
        </section>

        <section class="panel panel-schedule">
          <div class="panel-head panel-head-rich">
            <div>
              <span class="panel-kicker">Daily schedule</span>
              <h2>Posting Time</h2>
              <p>Choose when queued posts go out each day.</p>
            </div>
            <span class="panel-step">02</span>
          </div>
          <div class="schedule-clock">
            <span>Daily posting time</span>
            <strong><%= settings.dailyPostTime %></strong>
            <small>Your app's timezone</small>
          </div>
          <form class="schedule-settings" action="/settings" method="post">
            <label>
              Change posting time
              <input type="time" name="dailyPostTime" value="<%= settings.dailyPostTime %>" required />
            </label>
            <div class="actions"><button type="submit" class="btn btn-primary">Save Time</button></div>
          </form>
          <div class="schedule-divider"></div>
          <form class="rebuild-form" action="/schedule" method="post">
            <p><span class="status-dot"></span>Applies this time to everything already in the queue.</p>
            <div class="actions">
              <button type="submit" class="btn btn-secondary" <%= !tiktokConfigured ? 'disabled' : '' %>>Reschedule Queue</button>
            </div>
          </form>
        </section>
      </div>

      <!-- ─── Preflight Check ─── -->
      <section
        class="panel preflight-panel"
        aria-label="Preflight check"
        data-preflight
        data-channel-connected="<%= tiktokConfigured ? 'true' : 'false' %>"
        data-release-window="<%= settings.dailyPostTime || '' %>"
      >
        <div class="panel-head panel-head-rich">
          <div>
            <span class="panel-kicker">Preflight check</span>
            <h2>Preflight</h2>
            <p>Make sure everything is ready before you post.</p>
          </div>
          <span class="panel-step">03</span>
        </div>
        <ul class="preflight-list">
          <li data-check="channel">Channel selected<span class="preflight-state" data-state-label>Checking</span></li>
          <li data-check="auth">Channel connected<span class="preflight-state" data-state-label>Checking</span></li>
          <li data-check="asset">Media added<span class="preflight-state" data-state-label>Checking</span></li>
          <li data-check="caption">Caption written<span class="preflight-state" data-state-label>Checking</span></li>
          <li data-check="window">Posting time set<span class="preflight-state" data-state-label>Checking</span></li>
        </ul>
        <ul class="preflight-channels" data-preflight-channels aria-label="Per-channel preflight"></ul>
        <div class="preflight-verdict" data-preflight-verdict>
          <span data-preflight-message>Check readiness before you post.</span>
          <div class="actions"><button type="button" class="btn btn-secondary" data-run-preflight>Run Preflight</button></div>
        </div>
      </section>

      <!-- ─── Release Queue ─── -->
      <div data-queue-view-region>
      <section class="queue-section" aria-label="Release queue">
        <div class="section-head">
          <div>
            <span class="section-kicker">Queue</span>
            <h2>Release Queue</h2>
            <p>Everything waiting to post.</p>
          </div>
          <span class="count count-prominent" data-active-count><%= activePosts.length %> active</span>
        </div>

        <% if (activePosts.length > 0) { %>
          <div class="mark-toolbar" data-mark-toolbar hidden>
            <span class="mark-count" data-mark-count>0 marked</span>
            <button type="button" class="btn btn-danger" data-delete-marked disabled>Delete Marked</button>
            <button type="button" class="btn btn-ghost" data-clear-marks disabled>Clear Marks</button>
            <span class="mark-status" data-mark-status aria-live="polite"></span>
          </div>
        <% } %>

        <% if (tiktokAccounts.length > 0) { %>
          <div class="queue-view-toggle" data-queue-view-toggle role="group" aria-label="Release queue view">
            <a class="btn <%= queueView === 'all' ? 'btn-primary' : 'btn-secondary' %>" href="?queueView=all" data-queue-view-link="all" aria-pressed="<%= queueView === 'all' ? 'true' : 'false' %>">All Channels</a>
            <a class="btn <%= queueView === 'active' ? 'btn-primary' : 'btn-secondary' %>" href="?queueView=active" data-queue-view-link="active" aria-pressed="<%= queueView === 'active' ? 'true' : 'false' %>">Active Channel</a>
          </div>
          <% if (queueView === 'active') { %>
            <p class="queue-view-note" data-queue-view-note>Showing jobs for active channel only. Switch to All Channels to view all campaign jobs.</p>
          <% } %>
        <% } %>

        <% if (queueView === 'all' && campaignSummaries.length > 0) { %>
          <div class="campaign-summary-strip" aria-label="Parent campaign summary">
            <% campaignSummaries.forEach(function(campaign) { %>
              <article class="campaign-summary-card" data-state="<%= campaign.aggregateState %>">
                <header>
                  <strong>Campaign <%= campaign.campaignId.slice(0, 8) %></strong>
                  <span><%= campaign.channelCount %> <%= campaign.channelCount === 1 ? 'channel' : 'channels' %> &middot; <%= campaign.jobCount %> <%= campaign.jobCount === 1 ? 'job' : 'jobs' %></span>
                </header>
                <% if (campaign.scheduledRange.start) { %>
                  <p class="campaign-summary-range">
                    <%= helpers.formatDateTime(campaign.scheduledRange.start) %><% if (campaign.scheduledRange.end && campaign.scheduledRange.end !== campaign.scheduledRange.start) { %> &rarr; <%= helpers.formatDateTime(campaign.scheduledRange.end) %><% } %>
                  </p>
                <% } %>
                <ul class="campaign-summary-jobs">
                  <% campaign.jobs.forEach(function(job) { %>
                    <li><%= job.username ? `@${job.username}` : 'Channel unassigned' %> &middot; <%= statusWord(job.status) %><%= job.approved === false && job.status !== 'posted' ? ' · Awaiting approval' : '' %></li>
                  <% }); %>
                </ul>
              </article>
            <% }); %>
          </div>
        <% } %>

        <% if (activePosts.length === 0) { %>
          <div class="empty-state">
            <span class="empty-icon" aria-hidden="true">+</span>
            <p>Nothing queued yet</p>
            <span>Add a video above to create your next post.</span>
          </div>
        <% } %>

        <div class="queue-list">
          <% activePosts.forEach(function(post) { %>
            <% const mediaPath = helpers.mediaPath(post); %>
            <% const mediaType = helpers.mediaType(post); %>
            <% const isPhoto = mediaType === 'photo'; %>
            <% const result = helpers.postResult(post); %>
            <% const igResult = enableInstagram ? helpers.instagramPostResult(post) : null; %>
            <%
              // Resolve interaction ability from creatorInfo
              const commentDisabled = creatorInfo && creatorInfo.comment_disabled;
              const duetDisabled = isPhoto || (creatorInfo && creatorInfo.duet_disabled);
              const stitchDisabled = isPhoto || (creatorInfo && creatorInfo.stitch_disabled);
            %>
            <article class="queue-card" data-post-card data-post-id="<%= post.id %>">
              <!-- Thumbnail -->
              <% if (mediaPath) { %>
                <a class="queue-thumb" href="<%= mediaPath %>" target="_blank" rel="noreferrer">
                  <img class="thumb-placeholder" src="/assets/chanter-logo.png" alt="" />
                  <% if (mediaType === 'video') { %>
                    <video src="<%= mediaPath %>" muted playsinline preload="metadata" data-preview-media></video>
                  <% } else { %>
                    <img src="<%= mediaPath %>" alt="<%= post.originalName %>" loading="lazy" data-preview-media />
                  <% } %>
                  <span class="media-chip"><%= helpers.mediaLabel(post) %></span>
                </a>
              <% } else { %>
                <div class="queue-thumb is-missing">
                  <img class="thumb-placeholder" src="/assets/chanter-logo.png" alt="" />
                  <span class="media-chip"><%= helpers.mediaLabel(post) %></span>
                </div>
              <% } %>

              <div class="queue-main">
                <!-- Header row -->
                <div class="queue-top">
                  <div class="queue-title">
                    <h3><%= post.originalName %></h3>
                    <p class="queue-meta"><%= helpers.formatDateTime(post.scheduledAt) %> &middot; <%= post.username ? `@${post.username}` : 'Channel unassigned' %><%= post.campaignId ? ` · Campaign ${post.campaignId.slice(0, 8)}` : '' %> &middot; Job <%= post.id.slice(0, 8) %></p>
                  </div>
                  <div class="queue-badges">
                    <span class="badge <%= post.approved ? 'approval-ok' : 'approval-required' %>" data-approval-badge><%= post.approved ? 'Approved' : 'Approval required' %></span>
                    <span class="badge <%= result.tone %>" data-result-badge><%= displayResultLabel(result, post) %></span>
                  </div>
                </div>

                <p class="caption-preview"><%= captionPreview(post) %></p>

                <% if (!post.approved) { %>
                  <p class="result-message">Draft — awaiting approval. This post is blocked from publishing (scheduled and manual) until you approve it.</p>
                <% } %>
                <% if (post.duplicateWarning) { %>
                  <p class="result-message is-failed"><%= post.duplicateWarning %></p>
                <% } %>

                <% if (result.message && result.tone === 'failed') { %>
                  <p class="result-message is-failed"><%= result.message %></p>
                <% } else if (result.message && result.tone !== 'scheduled' && result.tone !== 'accepted') { %>
                  <p class="result-message"><%= result.message %></p>
                <% } %>
                <% if (enableInstagram && igResult.hasAttempt) { %>
                  <p class="result-message <%= igResult.tone === 'failed' ? 'is-failed' : '' %>">Instagram: <%= igResult.message %></p>
                <% } %>

                <!-- Edit form -->
                <form
                  class="schedule-form"
                  action="/posts/<%= post.id %>"
                  method="post"
                  data-edit-form
                  data-media-type="<%= mediaType %>"
                  data-has-local-media="<%= helpers.hasLocalMedia(post) ? 'true' : 'false' %>"
                >
                  <input type="hidden" name="timezoneOffsetMinutes" data-timezone-offset />

                  <!-- ① Caption (required by TikTok as the post title) -->
                  <label>
                    Caption
                    <span class="field-note">Shown on your TikTok post.</span>
                    <input type="text" name="caption" value="<%= post.caption || '' %>" placeholder="Add a caption…" maxlength="150" required />
                  </label>

                  <!-- ② Hashtags -->
                  <label>
                    Hashtags
                    <input type="text" name="hashtags" value="<%= post.hashtags || '' %>" placeholder="#chanter #viral" />
                  </label>

                  <!-- ③ Posting time + Privacy row -->
                  <div class="schedule-row">
                    <label>
                      <span class="field-note">Posting time (your local timezone).</span>
                      <input type="datetime-local" name="scheduledAt" value="<%= helpers.dateTimeInput(post.scheduledAt) %>" />
                    </label>
                    <label>
                      Privacy
                      <%# TikTok requires options from privacy_level_options; no default pre-selected behaviour; user must choose %>
                      <select name="privacyLevel" required>
                        <% privacyOptions.forEach(function(option) { %>
                          <option value="<%= option %>" <%= selectedPrivacy(post) === option ? 'selected' : '' %>>
                            <%= option.replace(/_/g,' ') %>
                          </option>
                        <% }); %>
                      </select>
                    </label>
                    <button type="submit" class="btn btn-primary">Save Campaign</button>
                  </div>

                  <!-- ④ Interaction Ability (TikTok Required UX #2c) -->
                  <% if (tiktokConfigured) { %>
                    <span class="section-label">Interactions</span>
                    <div class="interaction-controls">
                      <%# Allow Comment — always shown %>
                      <div class="check-row <%= commentDisabled ? 'disabled-row' : '' %>">
                        <input
                          type="checkbox" id="allow_comment_<%= post.id %>" name="allowComment" value="1"
                          <%= !commentDisabled ? 'checked' : '' %>
                          <%= commentDisabled ? 'disabled' : '' %>
                        />
                        <label for="allow_comment_<%= post.id %>">Allow Comment</label>
                        <% if (commentDisabled) { %><span class="check-hint">Disabled by your account settings</span><% } %>
                      </div>

                      <%# Duet — not shown for photo posts per TikTok guidelines %>
                      <div class="check-row <%= duetDisabled ? 'disabled-row' : '' %>">
                        <input
                          type="checkbox" id="allow_duet_<%= post.id %>" name="allowDuet" value="1"
                          <%= (!duetDisabled) ? 'checked' : '' %>
                          <%= duetDisabled ? 'disabled' : '' %>
                        />
                        <label for="allow_duet_<%= post.id %>">Allow Duet</label>
                        <% if (isPhoto) { %><span class="check-hint">Not available for photos</span><% } else if (duetDisabled) { %><span class="check-hint">Disabled by account settings</span><% } %>
                      </div>

                      <%# Stitch — not shown for photo posts %>
                      <div class="check-row <%= stitchDisabled ? 'disabled-row' : '' %>">
                        <input
                          type="checkbox" id="allow_stitch_<%= post.id %>" name="allowStitch" value="1"
                          <%= (!stitchDisabled) ? 'checked' : '' %>
                          <%= stitchDisabled ? 'disabled' : '' %>
                        />
                        <label for="allow_stitch_<%= post.id %>">Allow Stitch</label>
                        <% if (isPhoto) { %><span class="check-hint">Not available for photos</span><% } else if (stitchDisabled) { %><span class="check-hint">Disabled by account settings</span><% } %>
                      </div>
                    </div>
                  <% } %>

                  <!-- ⑤ Content Disclosure Setting (TikTok Required UX #3a) -->
                  <% if (tiktokConfigured) { %>
                    <div class="disclosure-section" data-disclosure-section>
                      <div class="disclosure-header">
                        <span>Content Disclosure</span>
                        <div class="toggle-wrap">
                          <label class="toggle">
                            <input type="checkbox" name="contentDisclosure" id="cd_<%= post.id %>" value="1" data-disclosure-toggle />
                            <span class="toggle-slider"></span>
                          </label>
                          <span style="font-size:11px;color:var(--text3);">Off by default</span>
                        </div>
                      </div>
                      <div class="disclosure-body" data-disclosure-body style="display:none;">
                        <p class="disclosure-note">
                          Turn this on if the post promotes a brand or product. TikTok will label it as promotional.
                        </p>
                        <div class="check-row">
                          <input type="checkbox" id="yourBrand_<%= post.id %>" name="yourBrand" value="1" />
                          <label for="yourBrand_<%= post.id %>">Your own brand or business</label>
                        </div>
                        <div class="check-row">
                          <input type="checkbox" id="brandedContent_<%= post.id %>" name="brandedContent" value="1" />
                          <label for="brandedContent_<%= post.id %>">Someone else's brand or product</label>
                        </div>
                      </div>
                    </div>
                  <% } %>

                  <!-- Advanced -->
                  <details class="advanced">
                    <summary>Advanced</summary>
                    <div class="advanced-body">
                      <label>
                        Public Media URL
                        <input
                          type="url" name="publicMediaUrl" value="<%= post.publicMediaUrl || post.publicImageUrl || '' %>"
                          placeholder="<%= mediaType === 'video' ? 'https://example.com/video.mp4' : 'https://example.com/image.png' %>"
                          data-public-media-url
                        />
                      </label>
                      <% if (enableInstagram) { %>
                        <label>
                          Instagram media URL
                          <input
                            type="url" name="instagramMediaUrl" value="<%= post.instagramMediaUrl || '' %>"
                            placeholder="<%= mediaType === 'video' ? 'https://example.com/reel.mp4' : 'https://example.com/image.jpg' %>"
                          />
                        </label>
                      <% } %>
                      <% if (result.hasDebug) { %><pre><%= result.debugJson %></pre><% } %>
                      <% if (enableInstagram && igResult.hasDebug) { %><pre><%= igResult.debugJson %></pre><% } %>
                      <% if (Array.isArray(post.history) && post.history.length > 0) { %>
                        <div>
                          <span class="section-label">Evidence log</span>
                          <ul class="evidence-list">
                            <% post.history.slice(-12).reverse().forEach(function(entry) { %>
                              <li><strong><%= String(entry.event || '').replace(/_/g, ' ') %></strong> &middot; <%= entry.at ? helpers.formatDateTime(entry.at) : 'No time' %><%= entry.detail ? ` — ${entry.detail}` : '' %></li>
                            <% }); %>
                          </ul>
                        </div>
                      <% } %>
                    </div>
                  </details>
                </form>

                <!-- ⑥ Music Usage Confirmation + Post Actions -->
                <% if (tiktokConfigured) { %>
                  <div class="music-declaration">
                    By posting, you agree to TikTok's <a href="https://www.tiktok.com/legal/page/global/music-usage-confirmation/en" target="_blank" rel="noreferrer">Music Usage Confirmation</a>.
                  </div>
                <% } %>

                <div class="card-actions">
                  <% if (!post.approved) { %>
                    <form class="inline-action" action="/posts/<%= post.id %>/approve" method="post">
                      <button type="submit" class="btn btn-primary">Approve</button>
                    </form>
                  <% } else { %>
                    <form class="inline-action" action="/posts/<%= post.id %>/unapprove" method="post">
                      <button type="submit" class="btn btn-ghost">Revoke Approval</button>
                    </form>
                  <% } %>
                  <form class="inline-action" action="/posts/<%= post.id %>/prepare" method="post" data-publish-form onsubmit="return confirm('Post now? This skips the scheduled time.');">
                    <input type="hidden" name="force" value="1" />
                    <% if (post.approved) { %>
                      <button type="submit" class="btn btn-secondary">Publish Now</button>
                    <% } else { %>
                      <button type="submit" class="btn btn-secondary" disabled title="Approve this post first — drafts cannot publish.">Publish Now</button>
                    <% } %>
                  </form>
                  <% if (enableInstagram && instagramStatus.readyToPublish) { %>
                    <form class="inline-action" action="/api/instagram/publish" method="post" data-instagram-publish-form>
                      <input type="hidden" name="postId" value="<%= post.id %>" />
                      <input type="hidden" name="dryRun" value="1" />
                      <button type="submit" class="btn btn-cyan">Instagram Publish Test</button>
                    </form>
                  <% } %>
                  <form class="inline-action" action="/posts/<%= post.id %>/delete" method="post" data-delete-form>
                    <button type="submit" class="btn btn-danger">Delete</button>
                  </form>
                  <button type="button" class="btn btn-ghost btn-mark" data-mark-toggle aria-pressed="false">Mark</button>
                </div>
              </div>
            </article>
          <% }); %>
        </div>
      </section>

      <!-- ─── Publishing Log ─── -->
      <details class="history-panel">
        <summary>
          <span class="history-title">
            <span class="history-icon" aria-hidden="true"></span>
            <span><small>Archive</small><strong>Publishing Log</strong></span>
          </span>
          <span class="history-summary-meta"><span class="count"><%= historyPosts.length %> published</span><span class="history-chevron" aria-hidden="true"></span></span>
        </summary>
        <div class="history-list">
          <% if (historyPosts.length === 0) { %>
            <div class="history-empty">Nothing posted yet</div>
          <% } %>
          <% historyPosts.forEach(function(post) { %>
            <% const mediaPath = helpers.mediaPath(post); %>
            <% const mediaType = helpers.mediaType(post); %>
            <% const result = helpers.postResult(post); %>
            <article class="history-card">
              <% if (mediaPath) { %>
                <a class="queue-thumb" href="<%= mediaPath %>" target="_blank" rel="noreferrer">
                  <img class="thumb-placeholder" src="/assets/chanter-logo.png" alt="" />
                  <% if (mediaType === 'video') { %>
                    <video src="<%= mediaPath %>" muted playsinline preload="metadata" data-preview-media></video>
                  <% } else { %>
                    <img src="<%= mediaPath %>" alt="<%= post.originalName %>" loading="lazy" data-preview-media />
                  <% } %>
                  <span class="media-chip"><%= helpers.mediaLabel(post) %></span>
                </a>
              <% } else { %>
                <div class="queue-thumb is-missing">
                  <img class="thumb-placeholder" src="/assets/chanter-logo.png" alt="" />
                  <span class="media-chip"><%= helpers.mediaLabel(post) %></span>
                </div>
              <% } %>
              <div class="queue-main">
                <div class="queue-top">
                  <div class="queue-title">
                    <h3><%= post.originalName %></h3>
                    <p class="queue-meta"><%= helpers.formatDateTime(post.postedAt || post.scheduledAt) %> &middot; <%= post.username ? `@${post.username}` : 'Channel unassigned' %><%= post.campaignId ? ` · Campaign ${post.campaignId.slice(0, 8)}` : '' %></p>
                  </div>
                  <span class="badge <%= result.tone %>"><%= displayResultLabel(result, post) %></span>
                </div>
                <p class="caption-preview"><%= captionPreview(post) %></p>
                <div class="card-actions">
                  <form class="inline-action" action="/posts/<%= post.id %>/delete" method="post" data-delete-form>
                    <button type="submit" class="btn btn-danger">Remove</button>
                  </form>
                </div>
                <% if (result.hasDebug) { %>
                  <details class="advanced"><summary>Details</summary><div class="advanced-body"><pre><%= result.debugJson %></pre></div></details>
                <% } %>
              </div>
            </article>
          <% }); %>
        </div>
      </details>
      </div>

      <details id="creative-tools" class="history-panel creative-engine-panel">
        <summary>
          <span class="history-title">
            <span class="history-icon" aria-hidden="true"></span>
            <span><small>Optional tool</small><strong>Creative Engine</strong></span>
          </span>
          <span class="history-summary-meta"><span class="count">Open when needed</span><span class="history-chevron" aria-hidden="true"></span></span>
        </summary>
        <div class="creative-engine-body">
          <div id="prompt-evolver-root"></div>
          <noscript>
            <div class="panel" style="margin-top:22px;">
              <div class="panel-head panel-head-rich">
                <div>
                  <span class="panel-kicker">Prompt Evolver</span>
                  <h2>Creative Engine</h2>
                  <p>Enable JavaScript to generate prompt variants.</p>
                </div>
              </div>
            </div>
          </noscript>
        </div>
      </details>
    </div>

    <script type="module" src="/autoposter-dashboard/assets/prompt-evolver-main.js"></script>
    <script>
      // Per-card / per-form behaviors, scoped to a root element so they can
      // be re-run after the Release Queue view toggle swaps in fresh
      // content without a full page reload (see the toggle IIFE near the
      // bottom of this script). Called once with `document` on initial
      // load, exactly as before.
      function hydrateQueueRegion(root) {
        root.querySelectorAll('[data-timezone-offset]').forEach(el => {
          el.value = String(new Date().getTimezoneOffset());
        });

        // Edit form: public media URL validation
        root.querySelectorAll('[data-edit-form]').forEach(form => {
          const input = form.querySelector('[data-public-media-url]');
          if (!input) return;
          const validate = () => {
            const mediaType = form.dataset.mediaType;
            const hasLocal = form.dataset.hasLocalMedia === 'true';
            const hasUrl = input.value.trim().length > 0;
            const missing = mediaType === 'photo' && !hasLocal && !hasUrl;
            input.setCustomValidity(missing ? 'Add a Public Media URL for photo posts.' : '');
            return !missing;
          };
          input.addEventListener('input', validate);
          form.addEventListener('submit', e => { if (!validate()) { e.preventDefault(); input.reportValidity(); } });
        });

        // Publish form: optimistic badge
        root.querySelectorAll('[data-publish-form]').forEach(form => {
          form.addEventListener('submit', () => {
            const card = form.closest('[data-post-card]');
            const badge = card ? card.querySelector('[data-result-badge]') : null;
            const btn = form.querySelector('button');
            if (btn) { btn.disabled = true; btn.textContent = 'Posting…'; }
            if (badge) { badge.className = 'badge publishing'; badge.textContent = 'Posting'; }
          });
        });

        <% if (enableInstagram) { %>
          // Instagram test form
          root.querySelectorAll('[data-instagram-publish-form]').forEach(form => {
            form.addEventListener('submit', () => {
              const btn = form.querySelector('button');
              if (btn) { btn.disabled = true; btn.textContent = 'Testing…'; }
            });
          });
        <% } %>

        // Missing media thumbnails
        root.querySelectorAll('[data-preview-media]').forEach(media => {
          const mark = () => { const t = media.closest('.queue-thumb'); if (t) t.classList.add('is-missing'); };
          media.addEventListener('error', mark);
          if (media.tagName === 'IMG' && media.complete && media.naturalWidth === 0) mark();
        });

        // Content Disclosure toggle shows/hides body
        root.querySelectorAll('[data-disclosure-toggle]').forEach(toggle => {
          const section = toggle.closest('[data-disclosure-section]');
          if (!section) return;
          const body = section.querySelector('[data-disclosure-body]');
          if (!body) return;
          toggle.addEventListener('change', () => {
            body.style.display = toggle.checked ? '' : 'none';
          });
        });

        // Single delete: block duplicate submissions. The server response
        // (redirect + notice) is the only source of truth for the result.
        root.querySelectorAll('[data-delete-form]').forEach(form => {
          form.addEventListener('submit', (event) => {
            if (event.defaultPrevented) return;
            if (form.dataset.submitting === 'true') { event.preventDefault(); return; }
            form.dataset.submitting = 'true';
            const btn = form.querySelector('button[type="submit"]');
            if (btn) { btn.disabled = true; btn.textContent = 'Deleting…'; }
          });
        });

        // Mark / Delete Marked — selection lives only in this page's DOM
        // (no persistent "marked" state). Only ids the server confirms as
        // deleted are removed; failures stay visible and stay marked.
        const markToolbar = root.querySelector('[data-mark-toolbar]');
        if (markToolbar) {
          const countLabel = markToolbar.querySelector('[data-mark-count]');
          const statusLabel = markToolbar.querySelector('[data-mark-status]');
          const deleteButton = markToolbar.querySelector('[data-delete-marked]');
          const clearButton = markToolbar.querySelector('[data-clear-marks]');
          const markedCards = () => Array.from(root.querySelectorAll('[data-post-card].is-marked'));
          let deleting = false;

          const setStatus = (message) => { if (statusLabel) statusLabel.textContent = message || ''; };
          const setCardMark = (card, marked) => {
            card.classList.toggle('is-marked', marked);
            const toggle = card.querySelector('[data-mark-toggle]');
            if (toggle) {
              toggle.setAttribute('aria-pressed', String(marked));
              toggle.textContent = marked ? 'Marked' : 'Mark';
            }
          };
          const refresh = () => {
            const count = markedCards().length;
            if (countLabel) countLabel.textContent = `${count} marked`;
            deleteButton.textContent = count > 0 ? `Delete Marked (${count})` : 'Delete Marked';
            deleteButton.disabled = deleting || count === 0;
            clearButton.disabled = deleting || count === 0;
            markToolbar.hidden = count === 0 && !(statusLabel && statusLabel.textContent);
          };
          const refreshActiveCount = () => {
            const activeCount = root.querySelectorAll('[data-post-card]').length;
            const countEl = root.querySelector('[data-active-count]');
            if (countEl) countEl.textContent = `${activeCount} active`;
          };

          root.querySelectorAll('[data-mark-toggle]').forEach((button) => {
            button.addEventListener('click', () => {
              const card = button.closest('[data-post-card]');
              if (!card || deleting) return;
              setCardMark(card, !card.classList.contains('is-marked'));
              setStatus('');
              refresh();
            });
          });

          clearButton.addEventListener('click', () => {
            if (deleting) return;
            markedCards().forEach((card) => setCardMark(card, false));
            setStatus('');
            refresh();
          });

          deleteButton.addEventListener('click', async () => {
            const cards = markedCards();
            if (deleting || cards.length === 0) return;
            const confirmed = window.confirm(
              `Delete ${cards.length} marked ${cards.length === 1 ? 'post' : 'posts'}? This permanently removes ${cards.length === 1 ? 'it' : 'them'} from the queue.`
            );
            if (!confirmed) return;
            deleting = true;
            setStatus('Deleting…');
            refresh();
            const ids = cards.map((card) => card.dataset.postId).filter(Boolean);
            try {
              const response = await fetch('/api/posts/delete-marked', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
                body: JSON.stringify({ ids })
              });
              const payload = await response.json().catch(() => null);
              if (!payload) throw new Error('unreadable response');
              const deletedIds = new Set(Array.isArray(payload.deleted) ? payload.deleted : []);
              cards.forEach((card) => { if (deletedIds.has(card.dataset.postId)) card.remove(); });
              refreshActiveCount();
              const failedCount = Array.isArray(payload.failed) ? payload.failed.length : 0;
              if (deletedIds.size === 0) {
                setStatus(payload.reason || 'Nothing was deleted. The marked posts are unchanged — try again.');
              } else if (failedCount > 0) {
                setStatus(`Deleted ${deletedIds.size} of ${ids.length}. ${failedCount} could not be deleted and ${failedCount === 1 ? 'is' : 'are'} still marked below.`);
              } else {
                setStatus(`Deleted ${deletedIds.size} ${deletedIds.size === 1 ? 'post' : 'posts'}.`);
              }
            } catch (error) {
              setStatus('Delete failed — the request did not complete. The marked posts are unchanged.');
            } finally {
              deleting = false;
              refresh();
            }
          });

          refresh();
        }
      }

      hydrateQueueRegion(document);

      // File kind helper
      function getFileKind(file) {
        const t = String(file.type || '').toLowerCase();
        const n = String(file.name || '').toLowerCase();
        if (t.startsWith('image/')) return 'photo';
        if (t.startsWith('video/')) return 'video';
        if (/\.(png|jpe?g|webp|gif)$/i.test(n)) return 'photo';
        if (/\.(mp4|mov|webm)$/i.test(n)) return 'video';
        return '';
      }

      // Video-only URL check — mirrors the server's mediaPolicy rule.
      function isVideoUrl(value) {
        try {
          const pathname = new URL(String(value || '')).pathname.toLowerCase();
          return ['.mp4', '.mov', '.webm'].some(ext => pathname.endsWith(ext));
        } catch (error) {
          return false;
        }
      }

      // Upload form validation
      document.querySelectorAll('[data-upload-form]').forEach(form => {
        const input = form.querySelector('[data-media-upload]');
        const publicUrlInput = form.querySelector('[data-public-media-url]');
        const autoCaptionToggle = form.querySelector('[data-auto-caption-toggle]');
        const autoCaptionStatus = form.querySelector('[data-auto-caption-status]');
        const autoMusicToggle = form.querySelector('[data-auto-music-toggle]');
        const autoMusicStatus = form.querySelector('[data-auto-music-status]');
        const autoMusicTokenInput = form.querySelector('[data-auto-music-token]');
        const captionInput = form.querySelector('[data-caption-input]');
        const hashtagsInput = form.querySelector('[data-hashtags-input]');
        const submitButton = form.querySelector('[type="submit"]');
        if (!input || !publicUrlInput) return;
        const submitInitiallyDisabled = Boolean(submitButton && submitButton.disabled);
        const autoCaptionInitiallyDisabled = Boolean(autoCaptionToggle && autoCaptionToggle.disabled);
        const autoMusicInitiallyDisabled = Boolean(autoMusicToggle && autoMusicToggle.disabled);
        let analysisToken = 0;
        let analyzedKey = '';
        let failedKey = '';
        let pendingAnalysis = null;
        let musicStatusTimer = null;

        const channelBoxes = Array.from(form.querySelectorAll('[data-channel-option]'));
        const channelValidityTarget = channelBoxes.find(box => !box.disabled) || null;

        const validate = () => {
          const files = Array.from(input.files || []);
          const publicUrl = publicUrlInput.value.trim();
          let msg = '';
          let urlMsg = '';
          let channelMsg = '';
          if (files.length === 0 && !publicUrl) msg = 'Choose a video file or enter a Public Media URL.';
          else if (files.some(f => getFileKind(f) !== 'video')) msg = 'TikTok posting is video-only. Choose MP4, MOV, or WebM video files.';
          if (publicUrl && !publicUrl.toLowerCase().startsWith('https://')) urlMsg = 'Public Media URL must use HTTPS.';
          else if (publicUrl && !isVideoUrl(publicUrl)) urlMsg = 'Public Media URL must point directly to an MP4, MOV, or WebM video file.';
          if (channelBoxes.length > 0 && !channelBoxes.some(box => box.checked && !box.disabled)) {
            channelMsg = 'Select at least one publishing channel.';
          }
          input.setCustomValidity(msg);
          publicUrlInput.setCustomValidity(urlMsg);
          if (channelValidityTarget) channelValidityTarget.setCustomValidity(channelMsg);
          return !msg && !urlMsg && !channelMsg;
        };

        const selectedVideos = () => Array.from(input.files || []).filter(file => getFileKind(file) === 'video');
        const videoKey = file => file ? [file.name, file.size, file.lastModified].join(':') : '';
        const wantsAnalysis = () => Boolean(
          (autoCaptionToggle && autoCaptionToggle.checked) ||
          (autoMusicToggle && autoMusicToggle.checked)
        );
        const analysisKey = file => [
          videoKey(file),
          `caption:${autoCaptionToggle && autoCaptionToggle.checked ? 1 : 0}`,
          `music:${autoMusicToggle && autoMusicToggle.checked ? 1 : 0}`
        ].join('|');
        const setAutoCaptionStatus = (message, tone = '') => {
          if (!autoCaptionStatus) return;
          autoCaptionStatus.textContent = message;
          autoCaptionStatus.dataset.tone = tone;
        };
        const setAutoMusicStatus = (message, tone = '') => {
          if (!autoMusicStatus) return;
          autoMusicStatus.textContent = message;
          autoMusicStatus.dataset.tone = tone;
        };
        const clearAutoMusicToken = () => {
          if (autoMusicTokenInput) autoMusicTokenInput.value = '';
        };
        const clearMusicStatusTimer = () => {
          if (musicStatusTimer) window.clearTimeout(musicStatusTimer);
          musicStatusTimer = null;
        };
        const setAnalyzing = (analyzing, token) => {
          if (token !== analysisToken) return;
          if (submitButton) submitButton.disabled = submitInitiallyDisabled || analyzing;
          if (autoCaptionToggle) autoCaptionToggle.disabled = autoCaptionInitiallyDisabled || analyzing;
          if (autoMusicToggle) autoMusicToggle.disabled = autoMusicInitiallyDisabled || analyzing;
        };

        const analyzeSelectedVideo = async () => {
          if (!wantsAnalysis()) return { ok: true, skipped: true };
          const videos = selectedVideos();
          const video = videos[0];
          if (!video) {
            if (autoCaptionToggle && autoCaptionToggle.checked) {
              setAutoCaptionStatus('Auto Caption runs on uploaded videos. Manual caption mode is still available.', '');
            }
            if (autoMusicToggle && autoMusicToggle.checked) {
              setAutoMusicStatus('Auto Music runs on uploaded videos. The original file will be used.', '');
            }
            return { ok: true, skipped: true };
          }

          const key = analysisKey(video);
          if (analyzedKey === key) return { ok: true, cached: true };
          if (pendingAnalysis && pendingAnalysis.key === key) return pendingAnalysis.promise;

          const token = ++analysisToken;
          analyzedKey = '';
          failedKey = '';
          setAnalyzing(true, token);
          if (autoCaptionToggle && autoCaptionToggle.checked) {
            setAutoCaptionStatus('Analyzing five frames and checking the audio track\u2026', 'working');
          }
          if (autoMusicToggle && autoMusicToggle.checked) {
            clearAutoMusicToken();
            setAutoMusicStatus('Selecting music\u2026', 'working');
            clearMusicStatusTimer();
            musicStatusTimer = window.setTimeout(() => {
              if (token === analysisToken) setAutoMusicStatus('Mixing background music\u2026', 'working');
            }, 800);
          }

          const promise = (async () => {
            try {
              const body = new FormData();
              body.append('video', video, video.name);
              body.append('caption', captionInput ? captionInput.value : '');
              body.append('hashtags', hashtagsInput ? hashtagsInput.value : '');
              body.append('autoMusic', autoMusicToggle && autoMusicToggle.checked ? '1' : '0');
              const response = await fetch('/api/auto-caption', {
                method: 'POST',
                headers: { Accept: 'application/json' },
                body
              });
              const payload = await response.json().catch(() => ({}));
              if (!response.ok || !payload.ok) {
                throw new Error(payload.reason || 'Auto Caption analysis failed.');
              }
              if (token !== analysisToken || !wantsAnalysis()) return { ok: false, stale: true };

              if (autoCaptionToggle && autoCaptionToggle.checked) {
                if (captionInput) {
                  captionInput.value = payload.caption || '';
                  captionInput.setCustomValidity('');
                }
                if (hashtagsInput) hashtagsInput.value = payload.hashtags || '';
                const audioNote = payload.analysis && payload.analysis.transcriptUsed
                  ? 'frames and transcript'
                  : 'video frames';
                const batchNote = videos.length > 1 ? ' The copy applies to every selected file.' : '';
                setAutoCaptionStatus(`Caption generated from ${audioNote}. Edit it before scheduling.${batchNote}`, 'success');
              }

              if (autoMusicToggle && autoMusicToggle.checked) {
                if (payload.music && payload.music.prepared && payload.music.token) {
                  if (autoMusicTokenInput) autoMusicTokenInput.value = payload.music.token;
                  const batchNote = videos.length > 1 ? ' Music applies to the first selected video.' : '';
                  setAutoMusicStatus(`Final video ready.${batchNote}`, 'success');
                } else {
                  clearAutoMusicToken();
                  setAutoMusicStatus('Music mixing failed. The original video will be used.', 'error');
                }
              }

              analyzedKey = key;
              return { ok: true };
            } catch (error) {
              if (token !== analysisToken) return { ok: false, stale: true };
              failedKey = key;
              if (autoCaptionToggle && autoCaptionToggle.checked) {
                setAutoCaptionStatus(error.message || 'Auto Caption failed. Keep or write a manual caption.', 'error');
              }
              if (autoMusicToggle && autoMusicToggle.checked) {
                clearAutoMusicToken();
                setAutoMusicStatus('Music mixing failed. The original video will be used.', 'error');
              }
              return { ok: false, error };
            } finally {
              if (token === analysisToken) {
                clearMusicStatusTimer();
                pendingAnalysis = null;
                setAnalyzing(false, token);
              }
            }
          })();

          pendingAnalysis = { key, promise };
          return promise;
        };

        input.addEventListener('change', () => {
          validate();
          analysisToken += 1;
          analyzedKey = '';
          failedKey = '';
          pendingAnalysis = null;
          clearMusicStatusTimer();
          clearAutoMusicToken();
          setAnalyzing(false, analysisToken);
          if (wantsAnalysis()) analyzeSelectedVideo();
        });
        publicUrlInput.addEventListener('input', validate);
        channelBoxes.forEach(box => box.addEventListener('change', validate));
        if (captionInput) {
          captionInput.addEventListener('input', () => captionInput.setCustomValidity(''));
        }
        if (autoCaptionToggle) {
          autoCaptionToggle.addEventListener('change', () => {
            analysisToken += 1;
            pendingAnalysis = null;
            if (autoCaptionToggle.checked) {
              analyzedKey = '';
              failedKey = '';
              analyzeSelectedVideo();
            } else {
              setAnalyzing(false, analysisToken);
              setAutoCaptionStatus('Auto Caption is off. Your current caption will be used unchanged.', '');
              analyzedKey = '';
              failedKey = '';
              if (wantsAnalysis()) analyzeSelectedVideo();
            }
          });
        }
        if (autoMusicToggle) {
          autoMusicToggle.addEventListener('change', () => {
            analysisToken += 1;
            pendingAnalysis = null;
            clearMusicStatusTimer();
            clearAutoMusicToken();
            analyzedKey = '';
            failedKey = '';
            if (autoMusicToggle.checked) {
              analyzeSelectedVideo();
            } else {
              setAnalyzing(false, analysisToken);
              setAutoMusicStatus('Auto Music is off. The original uploaded video will be used.', '');
              if (wantsAnalysis()) analyzeSelectedVideo();
            }
          });
        }

        form.addEventListener('submit', async e => {
          if (!validate()) {
            e.preventDefault();
            if (input.validationMessage) input.reportValidity();
            else publicUrlInput.reportValidity();
            return;
          }

          if (!wantsAnalysis()) return;
          const video = selectedVideos()[0];
          if (!video) return;
          const key = analysisKey(video);
          if (analyzedKey === key) return;

          if (failedKey === key) {
            if (!autoCaptionToggle || !autoCaptionToggle.checked || (captionInput && captionInput.value.trim())) return;
            e.preventDefault();
            if (captionInput) {
              captionInput.setCustomValidity('Auto Caption failed. Write a caption before scheduling.');
              captionInput.reportValidity();
              captionInput.focus();
            }
            return;
          }

          e.preventDefault();
          const result = await analyzeSelectedVideo();
          if (result.ok || !autoCaptionToggle || !autoCaptionToggle.checked || (captionInput && captionInput.value.trim())) {
            form.requestSubmit(submitButton || undefined);
          } else if (captionInput) {
            captionInput.setCustomValidity('Auto Caption failed. Write a caption before scheduling.');
            captionInput.reportValidity();
            captionInput.focus();
          }
        });
      });

      // Fast Schedule intake — submits the campaign over XHR so the page
      // keeps reusable settings (channels, offset, hashtags) while
      // showing real upload progress and an inline result instead of a full
      // page reload. Registered after the validation/auto-caption submit
      // listener above, so analysis still runs first; when that listener
      // prevents the event to run analysis, this one stays out of the way
      // and picks up the requestSubmit() it issues afterwards. The native
      // form post to /upload remains the no-JS fallback (the server keeps
      // redirect behavior for plain HTML posts).
      document.querySelectorAll('[data-upload-form]').forEach(form => {
        const feedback = form.querySelector('[data-submit-feedback]');
        const progress = form.querySelector('[data-upload-progress]');
        const progressFill = form.querySelector('[data-upload-progress-fill]');
        const status = form.querySelector('[data-submit-status]');
        const submitButton = form.querySelector('[type="submit"]');
        const mediaInput = form.querySelector('[data-media-upload]');
        const resetAfterSubmit = Array.from(form.querySelectorAll('[data-reset-after-submit]'));
        if (!feedback || !progress || !progressFill || !status || !submitButton || !mediaInput) return;
        const submitLabel = submitButton.textContent;
        let submitting = false;

        const setFeedback = (tone, message, showProgress) => {
          feedback.hidden = false;
          feedback.dataset.tone = tone;
          status.textContent = message;
          progress.hidden = !showProgress;
        };
        const setProgress = (percent) => {
          progressFill.style.width = `${Math.max(0, Math.min(100, percent))}%`;
        };
        const finishSubmit = () => {
          submitting = false;
          submitButton.disabled = false;
          submitButton.textContent = submitLabel;
        };
        const resetPerPostFields = () => {
          // Clear only state owned by the post that was just scheduled.
          // Channel selection, offset, hashtags, and optional Auto toggles
          // are reusable session defaults and intentionally remain selected.
          // Exact media references, caption, and start time can never flow
          // into the next post without a fresh user choice.
          resetAfterSubmit.forEach((field) => {
            field.value = '';
            field.dispatchEvent(new Event(field === mediaInput ? 'change' : 'input', { bubbles: true }));
          });
          setProgress(0);
          mediaInput.focus({ preventScroll: true });
        };

        form.addEventListener('submit', (event) => {
          if (event.defaultPrevented) return;
          event.preventDefault();
          if (submitting) return;
          submitting = true;
          submitButton.disabled = true;
          submitButton.textContent = 'Scheduling…';
          setFeedback('working', 'Uploading campaign media…', true);
          setProgress(0);

          const xhr = new XMLHttpRequest();
          xhr.open('POST', form.action);
          xhr.setRequestHeader('Accept', 'application/json');
          xhr.upload.addEventListener('progress', (progressEvent) => {
            if (!progressEvent.lengthComputable) return;
            const percent = Math.round((progressEvent.loaded / progressEvent.total) * 100);
            setProgress(percent);
            status.textContent = percent >= 100
              ? 'Preparing the campaign…'
              : `Uploading campaign media… ${percent}%`;
          });
          xhr.addEventListener('load', () => {
            finishSubmit();
            let payload = null;
            try { payload = JSON.parse(xhr.responseText); } catch (parseError) { payload = null; }
            if (payload && payload.ok) {
              setFeedback('success', `${payload.notice || 'Campaign scheduled.'} Ready for the next video.`, false);
              resetPerPostFields();
              document.dispatchEvent(new CustomEvent('chanter:queue-refresh'));
              return;
            }
            if (payload) {
              if (payload.resultUnknown) {
                setFeedback('error', payload.notice || 'The scheduling result is unknown. Check the Release Queue before retrying.', false);
                document.dispatchEvent(new CustomEvent('chanter:queue-refresh'));
                return;
              }
              setFeedback('error', payload.notice || 'The campaign could not be scheduled. Your entries are unchanged.', false);
              return;
            }
            // Non-JSON response — most likely an expired session redirected
            // to the login page. Follow it; the normal flow takes over.
            if (xhr.responseURL && !xhr.responseURL.includes('/upload')) {
              window.location.href = xhr.responseURL;
              return;
            }
            setFeedback('error', 'The campaign could not be confirmed. Check the Release Queue below before retrying.', false);
            document.dispatchEvent(new CustomEvent('chanter:queue-refresh'));
          });
          xhr.addEventListener('error', () => {
            finishSubmit();
            setFeedback('error', 'Connection interrupted — the scheduling result is unknown. Check the Release Queue before retrying; your entries are unchanged.', false);
            document.dispatchEvent(new CustomEvent('chanter:queue-refresh'));
          });
          xhr.send(new FormData(form));
        });
      });

      // Preflight check — client-side readiness review of the intake form.
      // Validates every selected target channel. Uses only server-rendered
      // booleans and public channel handles; no tokens or secrets are exposed.
      (() => {
        const panel = document.querySelector('[data-preflight]');
        if (!panel) return;
        const uploadForm = document.querySelector('[data-upload-form]');
        const mediaInput = uploadForm ? uploadForm.querySelector('[data-media-upload]') : null;
        const publicUrlInput = uploadForm ? uploadForm.querySelector('[data-public-media-url]') : null;
        const captionInput = uploadForm ? uploadForm.querySelector('[data-caption-input]') : null;
        const channelOptions = uploadForm ? Array.from(uploadForm.querySelectorAll('[data-channel-option]')) : [];
        const selectAllButton = uploadForm ? uploadForm.querySelector('[data-select-all-channels]') : null;
        const planLine = uploadForm ? uploadForm.querySelector('[data-channel-plan]') : null;
        const channelList = panel.querySelector('[data-preflight-channels]');
        const verdict = panel.querySelector('[data-preflight-verdict]');
        const message = panel.querySelector('[data-preflight-message]');
        // Fallback for pages rendered without a channel picker (no accounts).
        const legacyChannelConnected = panel.dataset.channelConnected === 'true';
        const releaseWindow = String(panel.dataset.releaseWindow || '').trim();

        const selectedChannels = () => channelOptions.filter((option) => option.checked && !option.disabled);
        const isConnected = (option) => option.dataset.channelConnected === 'true';

        const setCheck = (name, pass, passLabel, blockedLabel) => {
          const item = panel.querySelector(`[data-check="${name}"]`);
          if (!item) return;
          item.dataset.state = pass ? 'pass' : 'blocked';
          const label = item.querySelector('[data-state-label]');
          if (label) label.textContent = pass ? passLabel : blockedLabel;
        };

        const sourceCount = () => {
          const fileCount = mediaInput && mediaInput.files ? mediaInput.files.length : 0;
          if (fileCount > 0) return fileCount;
          return publicUrlInput && publicUrlInput.value.trim() ? 1 : 0;
        };

        const renderPlan = () => {
          if (!planLine) return;
          const channels = selectedChannels().length;
          const sources = sourceCount();
          planLine.dataset.tone = '';
          if (channels === 0) {
            planLine.textContent = 'Select at least one publishing channel to plan this campaign.';
            return;
          }
          if (sources === 0) {
            planLine.textContent = `${channels} ${channels === 1 ? 'channel' : 'channels'} selected — add a video to plan this post.`;
            return;
          }
          planLine.dataset.tone = 'ready';
          const jobs = channels * sources;
          planLine.textContent = `This campaign will create ${jobs} release ${jobs === 1 ? 'job' : 'jobs'} across ${channels} selected ${channels === 1 ? 'channel' : 'channels'}.`;
        };

        const renderChannelList = (campaignBlockedLabel) => {
          if (!channelList) return;
          channelList.textContent = '';
          channelOptions.forEach((option) => {
            const item = document.createElement('li');
            const state = document.createElement('span');
            state.className = 'preflight-state';
            if (!isConnected(option)) {
              item.dataset.state = 'blocked';
              state.textContent = 'Reconnect Required';
            } else if (!option.checked) {
              item.dataset.state = 'idle';
              state.textContent = 'Not selected';
            } else if (campaignBlockedLabel) {
              item.dataset.state = 'blocked';
              state.textContent = campaignBlockedLabel;
            } else {
              item.dataset.state = 'ready';
              state.textContent = 'Ready';
            }
            item.append(document.createTextNode(option.dataset.channelHandle || option.value), state);
            channelList.appendChild(item);
          });
        };

        const runPreflight = () => {
          const hasPicker = channelOptions.length > 0;
          const targets = selectedChannels();
          const hasTargets = hasPicker ? targets.length > 0 : legacyChannelConnected;
          const allAuthorized = hasPicker
            ? hasTargets && targets.every(isConnected)
            : legacyChannelConnected;
          const hasAsset = sourceCount() > 0;
          const hasCaption = Boolean(captionInput && captionInput.value.trim());
          const hasWindow = /^(?:[01]\d|2[0-3]):[0-5]\d$/.test(releaseWindow);

          setCheck('channel', hasTargets, hasPicker && targets.length > 0 ? `${targets.length} selected` : 'Selected', 'Channel Required');
          setCheck('auth', allAuthorized, 'Connected', hasTargets ? 'Reconnect Required' : 'Channel Required');
          setCheck('asset', hasAsset, 'Added', 'Asset Required');
          setCheck('caption', hasCaption, 'Written', 'Caption Required');
          setCheck('window', hasWindow, 'Set', 'Time Required');

          const blockedReason = !hasTargets ? 'Channel Required — select at least one publishing channel.'
            : !allAuthorized ? 'Reconnect Required — a selected channel is no longer authorized.'
            : !hasAsset ? 'Asset Required — add a video or a public video URL.'
            : !hasCaption ? 'Caption Required — write a caption or enable Auto Caption.'
            : !hasWindow ? 'Posting Time Required — set a daily posting time.'
            : '';
          const shortReason = !hasAsset ? 'Asset Required'
            : !hasCaption ? 'Caption Required'
            : !hasWindow ? 'Time Required'
            : '';

          renderChannelList(shortReason);
          renderPlan();

          if (verdict) verdict.dataset.tone = blockedReason ? 'blocked' : 'ready';
          if (message) {
            if (blockedReason) {
              message.textContent = `Needs attention — ${blockedReason}`;
            } else if (hasPicker) {
              message.textContent = `Ready to post — ${targets.length} ${targets.length === 1 ? 'channel' : 'channels'} will receive this post.`;
            } else {
              message.textContent = 'Ready to post.';
            }
          }
        };

        const runButton = panel.querySelector('[data-run-preflight]');
        if (runButton) runButton.addEventListener('click', runPreflight);
        if (selectAllButton) {
          selectAllButton.addEventListener('click', () => {
            channelOptions.forEach((option) => {
              if (option.disabled) return;
              option.checked = true;
              // Notify the form-validation listeners registered elsewhere.
              option.dispatchEvent(new Event('change', { bubbles: true }));
            });
            runPreflight();
          });
        }
        channelOptions.forEach((option) => option.addEventListener('change', runPreflight));
        [mediaInput, publicUrlInput, captionInput].forEach((input) => {
          if (!input) return;
          input.addEventListener('input', runPreflight);
          input.addEventListener('change', runPreflight);
        });
        runPreflight();
      })();

      // Max Scheduler — Release Plan preview. Pure client-side math that
      // mirrors src/maxScheduler.js's computeMaxSchedulePlan(): base time
      // plus index * offset minutes, in the browser's own local time. No
      // network round-trip; the server recomputes the identical plan
      // authoritatively from the same submitted fields at /upload.
      (() => {
        const form = document.querySelector('[data-upload-form]');
        const panel = form ? form.querySelector('[data-schedule-plan]') : null;
        if (!form || !panel) return;
        const dateInput = panel.querySelector('[data-schedule-start-date]');
        const timeInput = panel.querySelector('[data-schedule-start-time]');
        const offsetInput = panel.querySelector('[data-schedule-offset]');
        const list = panel.querySelector('[data-schedule-plan-list]');
        const tzLabel = panel.querySelector('[data-schedule-tz]');
        const channelOptions = Array.from(form.querySelectorAll('[data-channel-option]'));

        if (tzLabel) {
          try { tzLabel.textContent = Intl.DateTimeFormat().resolvedOptions().timeZone; }
          catch (error) { tzLabel.textContent = 'local time'; }
        }

        const addRow = (text, state) => {
          const item = document.createElement('li');
          if (state) item.dataset.state = state;
          item.textContent = text;
          list.appendChild(item);
        };

        const render = () => {
          if (!list) return;
          list.textContent = '';
          const dateValue = dateInput ? dateInput.value : '';
          const timeValue = timeInput ? timeInput.value : '';
          const offsetMinutes = offsetInput ? Number(offsetInput.value) : NaN;
          const selected = channelOptions.filter((option) => option.checked && !option.disabled);

          if (!dateValue || !timeValue) {
            addRow('Set a start date and time to preview the plan, or leave blank to use the daily posting time.');
            return;
          }
          if (selected.length === 0) {
            addRow('Select at least one publishing channel to preview the plan.', 'blocked');
            return;
          }
          if (!Number.isFinite(offsetMinutes) || offsetMinutes < 0) {
            addRow('Offset must be zero or a positive number of minutes.', 'blocked');
            return;
          }

          const base = new Date(`${dateValue}T${timeValue}`);
          if (Number.isNaN(base.getTime())) {
            addRow('The start date/time could not be parsed.', 'blocked');
            return;
          }

          const jobs = selected.length;
          addRow(`This campaign will create ${jobs} release ${jobs === 1 ? 'job' : 'jobs'} across ${jobs} selected ${jobs === 1 ? 'channel' : 'channels'}.`, '');
          list.lastElementChild.classList.add('schedule-plan-summary');

          selected.forEach((option, index) => {
            const at = new Date(base.getTime() + index * offsetMinutes * 60000);
            const connected = option.dataset.channelConnected === 'true';
            const handle = option.dataset.channelHandle || option.value;
            const offsetLabel = index === 0 ? 'Start time' : `+${index * offsetMinutes}m`;
            const item = document.createElement('li');
            item.dataset.state = connected ? 'ready' : 'blocked';
            const label = document.createElement('strong');
            label.textContent = handle;
            const detail = document.createElement('span');
            detail.textContent = `${at.toLocaleString()} · ${offsetLabel}${connected ? '' : ' · Reconnect Required'}`;
            item.append(label, detail);
            list.appendChild(item);
          });
        };

        [dateInput, timeInput, offsetInput].forEach((input) => {
          if (!input) return;
          input.addEventListener('input', render);
          input.addEventListener('change', render);
        });
        channelOptions.forEach((option) => option.addEventListener('change', render));
        render();
      })();

      // Release Queue view toggle — instant feedback, no full page reload.
      // The toggle stays a real link (?queueView=all|active): with JS
      // disabled, or if the background fetch below ever fails, it falls
      // back to a normal navigation and the server renders the requested
      // view exactly as before. With JS available, clicking it updates the
      // pressed button and the explanatory copy immediately (no network
      // wait), pushes the new URL, then swaps in the freshly fetched
      // queue/history content in the background.
      (() => {
        // Deliberately not the exact server copy: the real explanatory
        // sentence only ever comes from the server-rendered (or freshly
        // fetched) markup, so a no-JS page load and a fetch failure both
        // still show the authoritative text with no client-side copy to
        // keep in sync. This is just the instant, in-between placeholder
        // while that real content loads (typically well under a second).
        const SWITCHING_NOTE = 'Switching view…';

        const setOptimisticState = (region, view) => {
          region.querySelectorAll('[data-queue-view-link]').forEach((link) => {
            const isSelected = link.dataset.queueViewLink === view;
            link.classList.toggle('btn-primary', isSelected);
            link.classList.toggle('btn-secondary', !isSelected);
            link.setAttribute('aria-pressed', String(isSelected));
          });
          let note = region.querySelector('[data-queue-view-note]');
          if (view === 'active') {
            if (!note) {
              const toggle = region.querySelector('[data-queue-view-toggle]');
              if (toggle) {
                note = document.createElement('p');
                note.className = 'queue-view-note';
                note.setAttribute('data-queue-view-note', '');
                toggle.insertAdjacentElement('afterend', note);
              }
            }
            if (note) note.textContent = SWITCHING_NOTE;
          } else if (note) {
            note.remove();
          }
        };

        const bindToggleLinks = (region) => {
          region.querySelectorAll('[data-queue-view-link]').forEach((link) => {
            link.addEventListener('click', (event) => {
              if (event.defaultPrevented || event.button !== 0 || event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) return;
              event.preventDefault();
              const view = link.dataset.queueViewLink;
              const url = new URL(link.getAttribute('href'), window.location.href);
              setOptimisticState(region, view);
              history.pushState({ queueView: view }, '', url);
              loadQueueView(url);
            });
          });
        };

        let queueRequestVersion = 0;
        const loadQueueView = async (url, { navigateOnFailure = true } = {}) => {
          const requestVersion = ++queueRequestVersion;
          const currentRegion = document.querySelector('[data-queue-view-region]');
          if (!currentRegion) {
            if (navigateOnFailure) window.location.href = url;
            return;
          }
          currentRegion.setAttribute('aria-busy', 'true');
          try {
            const response = await fetch(url, { headers: { Accept: 'text/html' } });
            if (!response.ok) throw new Error(`Release Queue request failed: ${response.status}`);
            const html = await response.text();
            const nextRegion = new DOMParser().parseFromString(html, 'text/html').querySelector('[data-queue-view-region]');
            if (!nextRegion) throw new Error('Release Queue region missing from response');
            if (requestVersion !== queueRequestVersion) return;
            const liveRegion = document.querySelector('[data-queue-view-region]');
            if (!liveRegion) throw new Error('Release Queue region missing from current page');
            liveRegion.replaceWith(nextRegion);
            bindToggleLinks(nextRegion);
            hydrateQueueRegion(nextRegion);
          } catch (error) {
            if (requestVersion === queueRequestVersion && navigateOnFailure) window.location.href = url;
          } finally {
            if (requestVersion === queueRequestVersion) {
              document.querySelector('[data-queue-view-region]')?.removeAttribute('aria-busy');
            }
          }
        };

        const initialRegion = document.querySelector('[data-queue-view-region]');
        if (initialRegion) bindToggleLinks(initialRegion);

        window.addEventListener('popstate', () => {
          loadQueueView(window.location.href);
        });

        // Fast Schedule intake asks for a background queue refresh after a
        // campaign is created, reusing the same fetch-and-swap path as the
        // view toggle so new jobs appear without a page reload.
        document.addEventListener('chanter:queue-refresh', () => {
          loadQueueView(window.location.href, { navigateOnFailure: false });
        });
      })();

      // Creative tools stay collapsed and outside the posting flow until the
      // operator explicitly opens them from the secondary topbar action.
      document.querySelectorAll('[data-creative-tools-link]').forEach((link) => {
        link.addEventListener('click', () => {
          const panel = document.getElementById('creative-tools');
          if (panel) panel.open = true;
        });
      });
    </script>
  </body>
</html>
