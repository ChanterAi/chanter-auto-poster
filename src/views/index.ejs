      }
      label {
        gap: 5px;
        font-size: 12px;
        letter-spacing: .035em;
      }
      .form-grid,
      .campaign-form,
      .campaign-intake,
      .campaign-account-grid { gap: 12px; }
      input, select, textarea {
        min-height: 44px;
        font-size: 15px;
        padding: 11px 13px;
        border-radius: 12px;
      }
      textarea { min-height: 92px; }
      input[type="file"] { min-height: 54px; padding: 10px; }
      .upload-zone { padding: 14px; }
      .upload-zone .field-heading { font-size: 13px; }
      .auto-caption-card { padding: 12px 14px; gap: 6px; }
      .auto-caption-copy strong { font-size: 14px; }
      .auto-caption-copy span,
      .auto-caption-status { font-size: 13px; line-height: 1.35; }

      .campaign-mode { margin-bottom: 24px; }
      .campaign-layout {
        grid-template-columns: minmax(0, 1.45fr) minmax(380px, .75fr);
        gap: 18px;
      }
      .campaign-intake { grid-template-columns: minmax(0, 1.25fr) minmax(260px,.75fr); }
      .campaign-account-grid { grid-template-columns: 1fr 1fr; }
      .campaign-account-card,
      .campaign-preview,
      .scheduler-evidence,
      .campaign-group {
        padding: 16px;
        border-radius: 16px;
      }
      .campaign-account-card h3,
      .campaign-preview h3,
      .scheduler-evidence-head h3,
      .campaign-history-head h3 { font-size: 17px; }
      .scheduler-evidence { margin-top: 16px; }
      .campaign-history { margin-top: 16px; padding-top: 16px; }
      .campaign-job { padding: 12px; }

      .dashboard-grid {
        grid-template-columns: minmax(0, 1.45fr) minmax(380px, .75fr);
        gap: 18px;
        margin-bottom: 26px;
      }
      .panel-upload,
      .panel-schedule { min-height: auto; }
      .schedule-clock { padding: 14px; margin-bottom: 14px; }
      .schedule-clock strong { font-size: 28px; }
      .actions { margin-top: 12px; }
      .upload-actions { margin-top: 16px; }
      .btn-create { min-width: 200px; height: 48px !important; }

      .queue-section { margin-bottom: 22px; }
      .section-head { margin-bottom: 14px; }
      .section-head h2 { font-size: 30px; }
      .empty-state { padding: 48px 24px; }
      .history-panel > summary { padding: 16px 20px; }

      @media (min-width: 1500px) {
        .app { width: min(1540px, calc(100vw - 72px)); }
        .campaign-layout,
        .dashboard-grid { grid-template-columns: minmax(0, 1.55fr) minmax(420px, .7fr); }
      }
      @media (max-width: 1080px) {
        .app { width: min(100% - 32px, 1080px); padding-top: 18px; }
        .campaign-layout,
        .dashboard-grid,
        .account-context { grid-template-columns: 1fr; }
        .account-connect-flow { justify-items: start; }
        .account-connect-flow small { text-align: left; }
      }
      @media (max-width: 640px) {
        .app { width: auto; padding: 14px 12px 56px; }
        .client-hero { min-height: auto; padding: 24px 20px; }
        .client-hero h1 { font-size: 38px; }
        .client-hero p { font-size: 15px; }
        .panel { padding: 18px; }
      }

      /* ─── Client Mode collapsed sections ─── */
      .collapse-block {
        margin-top: 16px;
        border: 1px solid var(--border);
        border-radius: 16px;
        background: rgba(23,24,29,.02);
        overflow: hidden;
      }
      .collapse-block > summary {
        display: flex; align-items: center; justify-content: space-between; gap: 12px;
        padding: 14px 18px; cursor: pointer; list-style: none; user-select: none;
        font-size: 12px; font-weight: 800; letter-spacing: .07em; text-transform: uppercase; color: var(--text3);
      }
      .collapse-block > summary::-webkit-details-marker { display: none; }
      .collapse-block > summary:hover { color: var(--text2); background: rgba(23,24,29,.02); }
      .collapse-block-body { padding: 0 18px 18px; display: grid; gap: 14px; }
      .collapse-block .scheduler-evidence { margin-top: 0; }
      .collapse-block .campaign-history { margin-top: 0; padding-top: 0; border-top: 0; }
      .collapse-block .instagram-status-banner,
      .collapse-block .unaudited-note { margin-bottom: 0; }
      .page-admin-details { margin: 18px 0 0; }
      .advanced-options {
        border: 1px solid var(--border);
        border-radius: 14px;
        background: rgba(23,24,29,.02);
      }
      .advanced-options > summary {
        padding: 12px 14px; cursor: pointer; list-style: none; user-select: none;
        font-size: 12px; font-weight: 800; letter-spacing: .06em; text-transform: uppercase; color: var(--text3);
      }
      .advanced-options > summary::-webkit-details-marker { display: none; }
      .advanced-options > summary:hover { color: var(--text2); }
      .advanced-options-body { display: grid; gap: 12px; padding: 0 14px 14px; }
      .advanced-options .auto-caption-card { border: 0; background: transparent; padding: 0; }
    </style>
  </head>
  <body>
    <%
      const statusOf = (post) => String((post && post.status) || 'pending').toLowerCase();
      const activePosts = posts.filter((post) => statusOf(post) !== 'posted');
      const historyPosts = posts.filter((post) => statusOf(post) === 'posted');
      const privacyOptions = Array.isArray(creatorInfo && creatorInfo.privacy_level_options) && creatorInfo.privacy_level_options.length > 0
        ? creatorInfo.privacy_level_options
        : ['SELF_ONLY'];
      const displayResultLabel = (result) => {
        const tone = String((result && result.tone) || '').toLowerCase();
        const label = String((result && result.stateLabel) || '').toLowerCase();
        if (tone === 'failed' || label.includes('failed')) return 'Failed';
        if (tone === 'verification' || label.includes('verification')) return 'Needs verification';
        if (tone === 'accepted' || label.includes('posted') || label.includes('accepted')) return 'Posted / API accepted';
        if (tone === 'publishing' || label.includes('publishing')) return 'Publishing';
        return 'Scheduled';
      };
      const captionPreview = (post) => helpers.fullCaption(post) || 'No caption';
      const selectedPrivacy = (post) => {
        const value = String((post && post.privacyLevel) || 'SELF_ONLY').trim() || 'SELF_ONLY';
        return privacyOptions.includes(value) ? value : privacyOptions[0];
      };
      const isPhotoPost = (post) => helpers.mediaType(post) === 'photo';
    %>

    <div class="app">
      <!-- ─── Topbar ─── -->
      <header class="topbar">
        <div class="topbar-inner">
          <div class="brand-lockup">
            <div class="brand">
              <img class="brand-mark" src="/assets/chanter-logo.png" alt="CHANTER monogram" width="46" height="46" />
              <div class="brand-text">
                <div class="brand-title">CHANTER <small>AutoPoster</small></div>
                <div class="brand-sub">AI-assisted publishing</div>
              </div>
            </div>
            <div class="brand-context">
              <span>Publishing operations</span>
              <p>Schedule and monitor TikTok content</p>
            </div>
          </div>
          <div class="topbar-actions">
            <% if (tiktokConfigured) { %>
              <div class="pill pill-ok"><span class="dot"></span>TikTok Connected</div>
              <% if (creatorInfo) { %>
                <div class="pill pill-creator">
                  <img src="<%= creatorInfo.creator_avatar_url || '/assets/chanter-logo.png' %>" alt="" />
                  <span><%= creatorInfo.creator_username ? `@${creatorInfo.creator_username}` : (creatorInfo.creator_nickname || 'Creator') %></span>
                </div>
              <% } %>
            <% } else { %>
              <div class="pill pill-warn"><span class="dot"></span>Manual Mode</div>
              <a class="btn btn-primary" href="/connect/tiktok">Connect TikTok</a>
            <% } %>
            <a class="btn btn-prompt-evolver" href="#creative-lab">Creative Lab</a>
            <a class="btn btn-dashboard" href="/private/autoposter/dashboard">Open Dashboard</a>
            <% if (tiktokConfigured) { %>
              <a class="btn btn-ghost btn-disconnect" href="/disconnect/tiktok">Disconnect</a>
            <% } %>
            <form class="logout-form" action="/logout" method="post"><button class="btn btn-ghost" type="submit">Log out</button></form>

            <% if (enableInstagram) { %>
              <%
                const igPillClass = instagramStatus.state === 'ready' ? 'pill-cyan'
                  : instagramStatus.state === 'token_expired' ? 'pill-err'
                  : instagramStatus.connected ? 'pill-ok' : 'pill-warn';
              %>
              <div class="pill <%= igPillClass %>"><span class="dot"></span>Instagram <%= instagramStatus.label %></div>
              <% if (instagramStatus.connected) { %>
                <a class="btn btn-ghost" href="/disconnect/instagram">Disconnect IG</a>
              <% } else { %>
                <a class="btn btn-secondary" href="/auth/instagram/start">Connect Instagram</a>
              <% } %>
            <% } %>
          </div>
        </div>
      </header>

      <% if (tiktokAccounts.length > 0) { %>
        <section class="account-context" aria-label="Active TikTok account">
          <div class="account-context-copy">
            <span class="account-context-label">Active TikTok account</span>
            <strong><%= activeTikTokAccount && activeTikTokAccount.username ? `@${activeTikTokAccount.username}` : (activeTikTokAccount && activeTikTokAccount.displayName) || 'TikTok account' %></strong>
            <small><%= activeTikTokAccount && activeTikTokAccount.connected ? 'Connected' : 'Disconnected — reconnect to publish' %></small>
          </div>
          <form class="account-selector" action="/private/autoposter/account" method="post">
            <label>
              Switch account
              <select name="accountId" onchange="this.form.submit()">
                <% tiktokAccounts.forEach(function(account) { %>
                  <option value="<%= account.accountId %>" <%= activeTikTokAccount && activeTikTokAccount.accountId === account.accountId ? 'selected' : '' %>>
                    <%= account.username ? `@${account.username}` : (account.displayName || `TikTok ${account.accountId.slice(0, 8)}`) %><%= account.connected ? '' : ' (disconnected)' %>
                  </option>
                <% }); %>
              </select>
            </label>
          </form>
          <div class="account-connect-flow">
            <a class="btn btn-primary" href="/connect/tiktok?new=1">Add TikTok account</a>
            <small>To connect a different TikTok account, log out of TikTok first or use another browser.</small>
          </div>
        </section>
      <% } %>

      <% if (notice) { %><div class="notice"><%= notice %></div><% } %>

      <section class="client-hero" aria-label="AutoPoster overview">
        <div class="client-hero-copy">
          <span class="hero-kicker">CHANTER AutoPoster</span>
          <h1>Publish your next TikTok post.</h1>
          <p>Upload media, add your caption, pick a time. Done.</p>
        </div>
        <div class="client-hero-actions">
          <a class="btn btn-primary" href="#create-post">Create post</a>
          <a class="btn btn-secondary" href="#campaign-mode-heading">Campaigns</a>
        </div>
      </section>

      <!-- ─── Create Post ─── -->
      <div class="dashboard-grid" aria-label="Create post">
        <section class="panel panel-upload" id="create-post">
          <div class="panel-head panel-head-rich">
            <div>
              <span class="panel-kicker">New post</span>
              <h2>Create Post</h2>
              <p>Upload media, add your copy, then schedule.</p>
            </div>
            <span class="panel-step">01</span>
          </div>
          <form class="upload-form" action="/upload" method="post" enctype="multipart/form-data" data-upload-form>
            <div class="form-grid">
              <label class="wide upload-zone">
                <span class="field-heading">Media</span>
                <span class="field-note">Images or MP4, MOV, WebM videos.</span>
                <input type="file" name="images" accept="image/*,video/mp4,video/quicktime,video/webm,video/*" multiple data-media-upload />
              </label>
              <label>
                Caption
                <textarea name="caption" placeholder="Write a caption…" data-caption-input></textarea>
              </label>
              <label>
                Hashtags
                <textarea name="hashtags" placeholder="#chanter #viral" data-hashtags-input></textarea>
              </label>
              <details class="wide advanced-options">
                <summary>Advanced options</summary>
                <div class="advanced-options-body">
                  <div class="auto-caption-card">
                    <label class="auto-caption-row">
                      <span class="auto-caption-copy">
                        <strong>Auto Caption</strong>
                        <span>Generate a caption from the selected video.</span>
                      </span>
                      <input
                        type="checkbox"
                        name="autoCaption"
                        value="1"
                        data-auto-caption-toggle
                        <%= !autoCaptionConfigured ? 'disabled' : '' %>
                      />
                    </label>
                    <p class="auto-caption-status" data-auto-caption-status aria-live="polite">
                      <%= autoCaptionConfigured ? 'Turn on Auto Caption, then choose a video.' : 'Auto Caption is unavailable until an AI provider key is configured.' %>
                    </p>
                    <div class="auto-music-divider" aria-hidden="true"></div>
                    <label class="auto-caption-row">
                      <span class="auto-caption-copy">
                        <strong>Auto Music</strong>
                        <span>Add background music to the selected video.</span>
                      </span>
                      <input
                        type="checkbox"
                        name="autoMusic"
                        value="1"
                        data-auto-music-toggle
                        <%= !autoMusicConfigured ? 'disabled' : '' %>
                      />
                    </label>
                    <p class="auto-caption-status" data-auto-music-status aria-live="polite">
                      <%= autoMusicConfigured ? 'Turn on Auto Music, then choose a video.' : 'Auto Music is unavailable until the local music library is configured.' %>
                    </p>
                    <input type="hidden" name="autoMusicToken" value="" data-auto-music-token />
                  </div>
                  <label class="url-field">
                    Public Media URL
                    <span class="field-note">Optional HTTPS link if the file is already hosted.</span>
                    <input type="url" name="publicMediaUrl" placeholder="https://example.com/media.jpg" data-public-media-url />
                  </label>
                </div>
              </details>
            </div>
            <div class="actions upload-actions"><button type="submit" class="btn btn-primary btn-create" <%= !tiktokConfigured ? 'disabled' : '' %>>Create &amp; Schedule</button></div>
          </form>
        </section>

        <section class="panel panel-schedule">
          <div class="panel-head panel-head-rich">
            <div>
              <span class="panel-kicker">Timing</span>
              <h2>Post Schedule</h2>
              <p>Daily posting time for queued posts.</p>
            </div>
            <span class="panel-step">02</span>
          </div>
          <div class="schedule-clock">
            <span>Current daily time</span>
            <strong><%= settings.dailyPostTime %></strong>
            <small>App timezone</small>
          </div>
          <form class="schedule-settings" action="/settings" method="post">
            <label>
              Update daily time
              <input type="time" name="dailyPostTime" value="<%= settings.dailyPostTime %>" required />
            </label>
            <div class="actions"><button type="submit" class="btn btn-primary">Save time</button></div>
          </form>
          <div class="schedule-divider"></div>
          <form class="rebuild-form" action="/schedule" method="post">
            <p><span class="status-dot"></span>Applies the daily time to pending posts.</p>
            <div class="actions">
              <button type="submit" class="btn btn-secondary" <%= !tiktokConfigured ? 'disabled' : '' %>>Rebuild queue</button>
            </div>
          </form>
        </section>
      </div>

      <!-- ─── Active Queue ─── -->
      <section class="queue-section" aria-label="Queue">
        <div class="section-head">
          <div>
            <span class="section-kicker">Status</span>
            <h2>Scheduled posts</h2>
            <p>Latest status for each post.</p>
          </div>
          <span class="count count-prominent"><%= activePosts.length %> active</span>
        </div>

        <% if (activePosts.length === 0) { %>
          <div class="empty-state">
            <span class="empty-icon" aria-hidden="true">+</span>
            <p>No posts scheduled yet</p>
            <span>Use Create Post above to schedule your first post.</span>
          </div>
        <% } %>

        <div class="queue-list">
          <% activePosts.forEach(function(post) { %>
            <% const mediaPath = helpers.mediaPath(post); %>
            <% const mediaType = helpers.mediaType(post); %>
            <% const isPhoto = mediaType === 'photo'; %>
            <% const result = helpers.postResult(post); %>
            <% const igResult = enableInstagram ? helpers.instagramPostResult(post) : null; %>
            <%
              // Resolve interaction ability from creatorInfo
              const commentDisabled = creatorInfo && creatorInfo.comment_disabled;
              const duetDisabled = isPhoto || (creatorInfo && creatorInfo.duet_disabled);
              const stitchDisabled = isPhoto || (creatorInfo && creatorInfo.stitch_disabled);
            %>
            <article class="queue-card" data-post-card>
              <!-- Thumbnail -->
              <% if (mediaPath) { %>
                <a class="queue-thumb" href="<%= mediaPath %>" target="_blank" rel="noreferrer">
                  <img class="thumb-placeholder" src="/assets/chanter-logo.png" alt="" />
                  <% if (mediaType === 'video') { %>
                    <video src="<%= mediaPath %>" muted playsinline preload="metadata" data-preview-media></video>
                  <% } else { %>
                    <img src="<%= mediaPath %>" alt="<%= post.originalName %>" loading="lazy" data-preview-media />
                  <% } %>
                  <span class="media-chip"><%= helpers.mediaLabel(post) %></span>
                </a>
              <% } else { %>
                <div class="queue-thumb is-missing">
                  <img class="thumb-placeholder" src="/assets/chanter-logo.png" alt="" />
                  <span class="media-chip"><%= helpers.mediaLabel(post) %></span>
                </div>
              <% } %>

              <div class="queue-main">
                <!-- Header row -->
                <div class="queue-top">
                  <div class="queue-title">
                    <h3><%= post.originalName %></h3>
                    <p class="queue-meta"><%= helpers.formatDateTime(post.scheduledAt) %></p>
                  </div>
                  <span class="badge <%= result.tone %>" data-result-badge><%= displayResultLabel(result) %></span>
                </div>

                <p class="caption-preview"><%= captionPreview(post) %></p>

                <% if (result.message && result.tone === 'failed') { %>
                  <p class="result-message is-failed"><%= result.message %></p>
                <% } else if (result.message && result.tone !== 'scheduled' && result.tone !== 'accepted') { %>
                  <p class="result-message"><%= result.message %></p>
                <% } %>
                <% if (enableInstagram && igResult.hasAttempt) { %>
                  <p class="result-message <%= igResult.tone === 'failed' ? 'is-failed' : '' %>">Instagram: <%= igResult.message %></p>
                <% } %>

                <!-- Edit form -->
                <form
                  class="schedule-form"
                  action="/posts/<%= post.id %>"
                  method="post"
                  data-edit-form
                  data-media-type="<%= mediaType %>"
                  data-has-local-media="<%= helpers.hasLocalMedia(post) ? 'true' : 'false' %>"
                >
                  <input type="hidden" name="timezoneOffsetMinutes" data-timezone-offset />

                  <!-- ① Title (required by TikTok) -->
                  <label>
                    Title
                    <span class="field-note">Shown on TikTok.</span>
                    <input type="text" name="caption" value="<%= post.caption || '' %>" placeholder="Add a title…" maxlength="150" required />
                  </label>

                  <!-- ② Caption / Hashtags -->
                  <label>
                    Hashtags
                    <input type="text" name="hashtags" value="<%= post.hashtags || '' %>" placeholder="#chanter #viral" />
                  </label>

                  <!-- ③ Schedule + Privacy row -->
                  <div class="schedule-row">
                    <label>
                      Schedule time
                      <input type="datetime-local" name="scheduledAt" value="<%= helpers.dateTimeInput(post.scheduledAt) %>" />
                    </label>
                    <label>
                      Privacy
                      <%# TikTok requires options from privacy_level_options; no default pre-selected behaviour; user must choose %>
                      <select name="privacyLevel" required>
                        <% privacyOptions.forEach(function(option) { %>
                          <option value="<%= option %>" <%= selectedPrivacy(post) === option ? 'selected' : '' %>>
                            <%= option.replace(/_/g,' ') %>
                          </option>
                        <% }); %>
                      </select>
                    </label>
                    <button type="submit" class="btn btn-primary">Save</button>
                  </div>

                  <!-- ④ Interaction Ability (TikTok Required UX #2c) -->
                  <% if (tiktokConfigured) { %>
                    <span class="section-label">Interaction ability</span>
                    <div class="interaction-controls">
                      <%# Allow Comment — always shown %>
                      <div class="check-row <%= commentDisabled ? 'disabled-row' : '' %>">
                        <input
                          type="checkbox" id="allow_comment_<%= post.id %>" name="allowComment" value="1"
                          <%= !commentDisabled ? 'checked' : '' %>
                          <%= commentDisabled ? 'disabled' : '' %>
                        />
                        <label for="allow_comment_<%= post.id %>">Allow Comment</label>
                        <% if (commentDisabled) { %><span class="check-hint">Disabled by your account settings</span><% } %>
                      </div>

                      <%# Duet — not shown for photo posts per TikTok guidelines %>
                      <div class="check-row <%= duetDisabled ? 'disabled-row' : '' %>">
                        <input
                          type="checkbox" id="allow_duet_<%= post.id %>" name="allowDuet" value="1"
                          <%= (!duetDisabled) ? 'checked' : '' %>
                          <%= duetDisabled ? 'disabled' : '' %>
                        />
                        <label for="allow_duet_<%= post.id %>">Allow Duet</label>
                        <% if (isPhoto) { %><span class="check-hint">Not available for photos</span><% } else if (duetDisabled) { %><span class="check-hint">Disabled by account settings</span><% } %>
                      </div>

                      <%# Stitch — not shown for photo posts %>
                      <div class="check-row <%= stitchDisabled ? 'disabled-row' : '' %>">
                        <input
                          type="checkbox" id="allow_stitch_<%= post.id %>" name="allowStitch" value="1"
                          <%= (!stitchDisabled) ? 'checked' : '' %>
                          <%= stitchDisabled ? 'disabled' : '' %>
                        />
                        <label for="allow_stitch_<%= post.id %>">Allow Stitch</label>
                        <% if (isPhoto) { %><span class="check-hint">Not available for photos</span><% } else if (stitchDisabled) { %><span class="check-hint">Disabled by account settings</span><% } %>
                      </div>
                    </div>
                  <% } %>

                  <!-- ⑤ Content Disclosure Setting (TikTok Required UX #3a) -->
                  <% if (tiktokConfigured) { %>
                    <div class="disclosure-section" data-disclosure-section>
                      <div class="disclosure-header">
                        <span>Content Disclosure Setting</span>
                        <div class="toggle-wrap">
                          <label class="toggle">
                            <input type="checkbox" name="contentDisclosure" id="cd_<%= post.id %>" value="1" data-disclosure-toggle />
                            <span class="toggle-slider"></span>
                          </label>
                          <span style="font-size:11px;color:var(--text3);">Off by default</span>
                        </div>
                      </div>
                      <div class="disclosure-body" data-disclosure-body style="display:none;">
                        <p class="disclosure-note">
                          Indicate if your content promotes yourself, a brand, product, or service.
                          If enabled, TikTok will label this post as "Promotional content".
                        </p>
                        <div class="check-row">
                          <input type="checkbox" id="yourBrand_<%= post.id %>" name="yourBrand" value="1" />
                          <label for="yourBrand_<%= post.id %>">Your Brand — promoting your own business</label>
                        </div>
                        <div class="check-row">
                          <input type="checkbox" id="brandedContent_<%= post.id %>" name="brandedContent" value="1" />
                          <label for="brandedContent_<%= post.id %>">Branded Content — promoting a third-party brand</label>
                        </div>
                      </div>
                    </div>
                  <% } %>

                  <!-- Advanced -->
                  <details class="advanced">
                    <summary>Advanced / URLs</summary>
                    <div class="advanced-body">
                      <label>
                        Public Media URL
                        <input
                          type="url" name="publicMediaUrl" value="<%= post.publicMediaUrl || post.publicImageUrl || '' %>"
                          placeholder="<%= mediaType === 'video' ? 'https://example.com/video.mp4' : 'https://example.com/image.png' %>"
                          data-public-media-url
                        />
                      </label>
                      <% if (enableInstagram) { %>
                        <label>
                          Instagram media URL
                          <input
                            type="url" name="instagramMediaUrl" value="<%= post.instagramMediaUrl || '' %>"
                            placeholder="<%= mediaType === 'video' ? 'https://example.com/reel.mp4' : 'https://example.com/image.jpg' %>"
                          />
                        </label>
                      <% } %>
                      <% if (result.hasDebug) { %><pre><%= result.debugJson %></pre><% } %>
                      <% if (enableInstagram && igResult.hasDebug) { %><pre><%= igResult.debugJson %></pre><% } %>
                    </div>
                  </details>
                </form>

                <!-- ⑥ Music Usage Confirmation + Post Actions -->
                <% if (tiktokConfigured) { %>
                  <div class="music-declaration">
                    By posting, you agree to TikTok's <a href="https://www.tiktok.com/legal/page/global/music-usage-confirmation/en" target="_blank" rel="noreferrer">Music Usage Confirmation</a>.
                  </div>
                <% } %>

                <div class="card-actions">
                  <form class="inline-action" action="/posts/<%= post.id %>/prepare" method="post" data-publish-form onsubmit="return confirm('Post now? This ignores the schedule.');">
                    <input type="hidden" name="force" value="1" />
                    <button type="submit" class="btn btn-secondary">Post now</button>
                  </form>
                  <% if (enableInstagram && instagramStatus.readyToPublish) { %>
                    <form class="inline-action" action="/api/instagram/publish" method="post" data-instagram-publish-form>
                      <input type="hidden" name="postId" value="<%= post.id %>" />
                      <input type="hidden" name="dryRun" value="1" />
                      <button type="submit" class="btn btn-cyan">Test Instagram</button>
                    </form>
                  <% } %>
                  <form class="inline-action" action="/posts/<%= post.id %>/delete" method="post">
                    <button type="submit" class="btn btn-danger">Delete</button>
                  </form>
                </div>
              </div>
            </article>
          <% }); %>
        </div>
      </section>

      <!-- ─── Campaign Mode ─── -->
      <%
        const connectedCampaignAccounts = tiktokAccounts.filter(function(account) { return account.connected; });
        const campaignHistory = Array.isArray(campaigns) ? campaigns : [];
      %>
      <section class="panel campaign-mode" aria-labelledby="campaign-mode-heading">
        <div class="panel-head panel-head-rich">
          <div>
            <span class="panel-kicker">Campaigns</span>
            <h2 id="campaign-mode-heading">Campaign Command Center</h2>
            <p>One video, posted to each selected account on a staggered schedule.</p>
          </div>
          <span class="panel-step">CM</span>
        </div>

        <div class="campaign-layout">
          <form class="campaign-form" action="/campaigns" method="post" enctype="multipart/form-data" data-campaign-form>
            <div class="campaign-intake">
              <label class="campaign-video upload-zone">
                <span class="field-heading">Campaign video</span>
                <span class="field-note">One MP4, MOV, or WebM video.</span>
                <input type="file" name="campaignVideo" accept="video/mp4,video/quicktime,video/webm,.mp4,.mov,.webm" required data-campaign-video />
              </label>
              <label>
                Base schedule time
                <span class="field-note">Account 2 is automatically scheduled 15 minutes later.</span>
                <input type="datetime-local" name="campaignBaseScheduledAt" required data-campaign-base-time />
              </label>
              <input type="hidden" name="timezoneOffsetMinutes" data-timezone-offset />
            </div>

            <div class="campaign-account-grid">
              <% [1, 2].forEach(function(slot) { %>
                <article class="campaign-account-card" data-campaign-slot="<%= slot %>">
                  <h3>Account <%= slot %><%= slot === 2 ? ' (optional)' : '' %></h3>
                  <label>
                    TikTok account
                    <select name="campaignAccountId<%= slot %>" <%= slot === 1 ? 'required' : '' %> data-campaign-account>
                      <option value=""><%= slot === 1 ? 'Select an account' : 'No second account' %></option>
                      <% connectedCampaignAccounts.forEach(function(account) { %>
                        <option value="<%= account.accountId %>"><%= account.username ? `@${account.username}` : (account.displayName || `TikTok ${account.accountId.slice(0, 8)}`) %></option>
                      <% }); %>
                    </select>
                  </label>
                  <label>
                    Caption
                    <textarea name="campaignCaption<%= slot %>" placeholder="Account-specific caption" data-campaign-caption></textarea>
                  </label>
                  <label>
                    Hashtags
                    <textarea name="campaignHashtags<%= slot %>" placeholder="#accountSpecific #campaign" data-campaign-hashtags></textarea>
                  </label>
                </article>
              <% }); %>
            </div>

            <div class="actions upload-actions">
              <button type="submit" class="btn btn-primary btn-create" <%= connectedCampaignAccounts.length === 0 ? 'disabled' : '' %>>Create campaign</button>
            </div>
          </form>

          <aside class="campaign-preview" aria-live="polite">
            <span class="section-kicker">Preview</span>
            <h3>Schedule preview</h3>
            <p class="campaign-preview-note">Checks run automatically before anything is posted.</p>
            <details class="fine-print">
              <summary>How checks work</summary>
              <p class="campaign-preview-note">A read-only dry run checks accounts and schedule conflicts before any upload — creating the campaign remains the only step that writes, and it revalidates everything. Each job stays independent if the other account fails.</p>
              <p class="campaign-preview-note campaign-no-live-note">No-live demo: this dry run never calls TikTok, so it is safe to demo. A full post-simulation demo mode is intentionally not implemented — due jobs are always published for real by the scheduler.</p>
            </details>
            <div class="campaign-preview-verdict" data-campaign-verdict hidden></div>
            <button type="button" class="btn btn-ghost campaign-copy-btn" data-campaign-copy-verdict hidden>Copy dry-run verdict</button>
            <div data-campaign-preview>
              <p class="campaign-preview-note">Select an account and base time to preview the jobs.</p>
            </div>
          </aside>
        </div>

        <details class="collapse-block" aria-label="Campaign archive">
          <summary>Archive · Campaign history <span class="count"><%= campaignHistory.length %></span></summary>
          <div class="collapse-block-body">
            <div class="campaign-history" aria-label="Campaign history">
          <% if (campaignHistory.length === 0) { %>
            <p class="campaign-preview-note">No campaigns have been created yet.</p>
          <% } %>
          <% campaignHistory.forEach(function(campaign) { %>
            <article class="campaign-group">
              <header class="campaign-group-head">
                <div>
                  <strong>Campaign <%= campaign.campaignId.slice(0, 8) %></strong>
                  <small><%= helpers.formatDateTime(campaign.scheduleBaseTime) %> / <%= campaign.childJobs.length %> child job<%= campaign.childJobs.length === 1 ? '' : 's' %></small>
                </div>
                <span class="campaign-status"><%= campaign.campaignStatus.replaceAll('_', ' ') %></span>
              </header>
              <div class="campaign-job-list">
                <% campaign.childJobs.forEach(function(job) { %>
                  <% const campaignAccount = tiktokAccounts.find(function(account) { return account.accountId === job.accountId; }); %>
                  <% const childError = job.errorMessage || (job.errorEvidence && job.errorEvidence.reason) || ''; %>
                  <% const childRetryable = Boolean(job.errorEvidence && job.errorEvidence.retryable); %>
                  <div class="campaign-job">
                    <strong><%= campaignAccount && campaignAccount.username ? `@${campaignAccount.username}` : (campaignAccount && campaignAccount.displayName) || job.username || job.accountId %></strong>
                    <span class="campaign-job-copy"><%= job.caption %> / <%= job.hashtags %></span>
                    <time datetime="<%= job.scheduledAt %>"><%= helpers.formatDateTime(job.scheduledAt) %> / <%= job.campaignJobStatus.replaceAll('_', ' ') %></time>
                    <span class="campaign-job-meta" title="<%= job.id %>">job <%= job.id.slice(0, 8) %> / account <%= job.accountId %><%= job.publishId ? ` / publish ${job.publishId}` : '' %></span>
                    <% if (childError) { %>
                      <span class="campaign-job-error"><%= childError %><%= childRetryable ? ' (safe to requeue)' : '' %></span>
                    <% } %>
                  </div>
                <% }); %>
              </div>
              <% const oracleReview = helpers.campaignReview(campaign, schedulerEvidence); %>
              <div class="campaign-oracle" data-campaign-oracle>
                <div class="campaign-oracle-head">
                  <strong>Campaign review</strong>
                  <span class="campaign-status">verdict: <%= oracleReview.verdict %></span>
                </div>
                <p><%= oracleReview.summary %></p>
                <% if (oracleReview.blockedReason) { %>
                  <p class="campaign-oracle-blocked">Blocked: <%= oracleReview.blockedReason %></p>
                <% } %>
                <details class="fine-print">
                  <summary>Review details</summary>
                  <p>Local, deterministic review — no AI call.</p>
                  <span class="scheduler-evidence-line">posted <%= oracleReview.postedCount %> / accepted <%= oracleReview.acceptedCount %> / retry required <%= oracleReview.retryRequiredCount %> / failed <%= oracleReview.failedCount %> — evidence confidence <%= oracleReview.evidenceConfidence %></span>
                  <p>Next: <%= oracleReview.recommendedNextAction %></p>
                  <% if (oracleReview.riskNotes.length > 0) { %>
                    <ul>
                      <% oracleReview.riskNotes.forEach(function(note) { %>
                        <li><%= note %></li>
                      <% }); %>
                    </ul>
                  <% } %>
                </details>
              </div>
              <details class="campaign-evidence">
                <summary>Evidence summary</summary>
                <pre class="campaign-evidence-text" data-campaign-evidence><%= helpers.campaignEvidence(campaign) %></pre>
                <button type="button" class="btn btn-ghost campaign-copy-btn" data-campaign-copy-evidence>Copy evidence</button>
              </details>
            </article>
          <% }); %>
        </div>
          </div>
        </details>
      </section>

      <!-- ─── Creative Lab (secondary) ─── -->
      <section id="creative-lab" class="creative-lab-wrapper" aria-label="AI Creative Lab">
        <details class="creative-lab-details">
          <summary>
            <span>
              <strong>Creative Lab</strong>
              <small>Optional prompt tools.</small>
            </span>
            <em>Open</em>
          </summary>
          <div class="creative-lab-body">
            <div id="prompt-evolver-root"></div>
            <noscript>
              <div class="panel">
                <div class="panel-head panel-head-rich">
                  <div>
                    <span class="panel-kicker">Creative Lab</span>
                    <h2>Prompt tools</h2>
                    <p>Enable JavaScript to generate prompt variants.</p>
                  </div>
                </div>
              </div>
            </noscript>
          </div>
        </details>
      </section>

      <!-- ─── History ─── -->
      <details class="history-panel">
        <summary>
          <span class="history-title">
            <span class="history-icon" aria-hidden="true"></span>
            <span><small>Archive</small><strong>Post history</strong></span>
          </span>
          <span class="history-summary-meta"><span class="count"><%= historyPosts.length %> posted</span><span class="history-chevron" aria-hidden="true"></span></span>
        </summary>
        <div class="history-list">
          <% if (historyPosts.length === 0) { %>
            <div class="history-empty">No posted history</div>
          <% } %>
          <% historyPosts.forEach(function(post) { %>
            <% const mediaPath = helpers.mediaPath(post); %>
            <% const mediaType = helpers.mediaType(post); %>
            <% const result = helpers.postResult(post); %>
            <article class="history-card">
              <% if (mediaPath) { %>
                <a class="queue-thumb" href="<%= mediaPath %>" target="_blank" rel="noreferrer">
                  <img class="thumb-placeholder" src="/assets/chanter-logo.png" alt="" />
                  <% if (mediaType === 'video') { %>
                    <video src="<%= mediaPath %>" muted playsinline preload="metadata" data-preview-media></video>
                  <% } else { %>
                    <img src="<%= mediaPath %>" alt="<%= post.originalName %>" loading="lazy" data-preview-media />
                  <% } %>
                  <span class="media-chip"><%= helpers.mediaLabel(post) %></span>
                </a>
              <% } else { %>
                <div class="queue-thumb is-missing">
                  <img class="thumb-placeholder" src="/assets/chanter-logo.png" alt="" />
                  <span class="media-chip"><%= helpers.mediaLabel(post) %></span>
                </div>
              <% } %>
              <div class="queue-main">
                <div class="queue-top">
                  <div class="queue-title">
                    <h3><%= post.originalName %></h3>
                    <p class="queue-meta"><%= helpers.formatDateTime(post.postedAt || post.scheduledAt) %></p>
                  </div>
                  <span class="badge <%= result.tone %>"><%= displayResultLabel(result) %></span>
                </div>
                <p class="caption-preview"><%= captionPreview(post) %></p>
                <div class="card-actions">
                  <form class="inline-action" action="/posts/<%= post.id %>/delete" method="post">
                    <button type="submit" class="btn btn-danger">Remove</button>
                  </form>
                </div>
                <% if (result.hasDebug) { %>
                  <details class="advanced"><summary>Audit details</summary><div class="advanced-body"><pre><%= result.debugJson %></pre></div></details>
                <% } %>
              </div>
            </article>
          <% }); %>
        </div>
      </details>

      <!-- ─── Admin / Audit details ─── -->
      <details class="collapse-block page-admin-details" aria-label="Admin and audit details">
        <summary>Admin / Audit details</summary>
        <div class="collapse-block-body">
          <% if (instagramHealth && !instagramHealth.configured) { %>
            <div class="instagram-status-banner" role="status" aria-label="Instagram configuration status">
              <strong>Instagram: Not configured</strong>
              <span>Dry-run mode active</span>
              <span>Add Meta API keys to enable Instagram publishing</span>
            </div>
          <% } %>

          <%
            const showUnauditedWarning = tiktokConfigured && creatorInfo && privacyOptions.length > 0 && !privacyOptions.includes('PUBLIC_TO_EVERYONE');
          %>
          <% if (showUnauditedWarning) { %>
            <div class="unaudited-note">
              <strong>App not yet reviewed by TikTok:</strong> Until your TikTok Developer app passes the audit, all posts are restricted to <code>SELF_ONLY</code> privacy and up to 5 users per 24 h window. To lift this, <a href="https://developers.tiktok.com/doc/content-sharing-guidelines/" target="_blank" rel="noreferrer" style="color:inherit;text-decoration:underline;">complete the TikTok audit</a>.
            </div>
          <% } %>

          <%
            const heartbeat = schedulerEvidence ? schedulerEvidence.durableHeartbeat : null;
            const heartbeatStatus = heartbeat ? String(heartbeat.status || 'missing') : 'unavailable';
            const tickSummary = heartbeat && heartbeat.lastTickSummary ? heartbeat.lastTickSummary : null;
            const degradedReasons = schedulerEvidence && Array.isArray(schedulerEvidence.degradedReasons)
              ? schedulerEvidence.degradedReasons
              : [];
          %>
          <div class="scheduler-evidence" aria-label="Scheduler evidence" data-scheduler-evidence>
            <div class="scheduler-evidence-head">
              <h3>System status</h3>
              <span class="campaign-status"><%= !schedulerEvidence ? 'unavailable' : heartbeatStatus %></span>
            </div>
            <% if (!schedulerEvidence || heartbeatStatus === 'unavailable') { %>
              <p class="campaign-preview-note">Cron evidence could not be read right now. Check /health for the raw scheduler status.</p>
            <% } else if (heartbeatStatus === 'missing') { %>
              <p class="campaign-preview-note">Cron run evidence is not persisted yet. It appears after the first completed cron tick.</p>
            <% } else if (heartbeatStatus === 'invalid') { %>
              <p class="campaign-preview-note">A cron heartbeat exists but is incomplete. Check /health for details.</p>
            <% } else { %>
              <p class="campaign-preview-note">Scheduler last ran <%= helpers.formatDateTime(heartbeat.lastTickAt) %><%= heartbeat.stale ? ' — needs attention' : '' %>.</p>
              <details class="fine-print">
                <summary>Advanced evidence</summary>
                <span class="scheduler-evidence-line">last durable tick: <%= helpers.formatDateTime(heartbeat.lastTickAt) %> (<%= heartbeat.ageSeconds %>s ago) — <%= heartbeat.lastTickOk ? 'completed OK' : 'completed with errors' %><%= heartbeat.stale ? ' — STALE' : '' %></span>
                <% if (tickSummary) { %>
                  <span class="scheduler-evidence-line">last tick: checked <%= tickSummary.checked %> / posted <%= tickSummary.posted %> / accepted <%= Object.hasOwn(tickSummary, 'accepted') ? tickSummary.accepted : 0 %> / failed <%= tickSummary.failed %></span>
                <% } %>
                <span class="scheduler-evidence-line">overdue jobs: <%= schedulerEvidence.overdueTotalCount === null ? 'unknown' : schedulerEvidence.overdueTotalCount %> / stale processing locks: <%= schedulerEvidence.staleProcessingCount === null ? 'unknown' : schedulerEvidence.staleProcessingCount %></span>
                <% if (degradedReasons.length > 0) { %>
                  <ul>
                    <% degradedReasons.forEach(function(reason) { %>
                      <li><%= reason.message %></li>
                    <% }); %>
                  </ul>
                <% } %>
              </details>
            <% } %>
          </div>
        </div>
      </details>
    </div>

    <script type="module" src="/autoposter-dashboard/assets/prompt-evolver-main.js"></script>
    <script>
      // Timezone offset
      document.querySelectorAll('[data-timezone-offset]').forEach(el => {
        el.value = String(new Date().getTimezoneOffset());
      });

      // File kind helper
      function getFileKind(file) {
        const t = String(file.type || '').toLowerCase();
        const n = String(file.name || '').toLowerCase();
        if (t.startsWith('image/')) return 'photo';
        if (t.startsWith('video/')) return 'video';
        if (/\.(png|jpe?g|webp|gif)$/i.test(n)) return 'photo';
        if (/\.(mp4|mov|webm)$/i.test(n)) return 'video';
        return '';
      }

      // Upload form validation
      document.querySelectorAll('[data-upload-form]').forEach(form => {
        const input = form.querySelector('[data-media-upload]');
        const publicUrlInput = form.querySelector('[data-public-media-url]');
        const autoCaptionToggle = form.querySelector('[data-auto-caption-toggle]');
        const autoCaptionStatus = form.querySelector('[data-auto-caption-status]');
        const autoMusicToggle = form.querySelector('[data-auto-music-toggle]');
        const autoMusicStatus = form.querySelector('[data-auto-music-status]');
        const autoMusicTokenInput = form.querySelector('[data-auto-music-token]');
        const captionInput = form.querySelector('[data-caption-input]');
        const hashtagsInput = form.querySelector('[data-hashtags-input]');
        const submitButton = form.querySelector('[type="submit"]');
        if (!input || !publicUrlInput) return;
        const submitInitiallyDisabled = Boolean(submitButton && submitButton.disabled);
        const autoCaptionInitiallyDisabled = Boolean(autoCaptionToggle && autoCaptionToggle.disabled);
        const autoMusicInitiallyDisabled = Boolean(autoMusicToggle && autoMusicToggle.disabled);
        let analysisToken = 0;
        let analyzedKey = '';
        let failedKey = '';
        let pendingAnalysis = null;
        let musicStatusTimer = null;

        const validate = () => {
          const files = Array.from(input.files || []);
          const publicUrl = publicUrlInput.value.trim();
          let msg = '';
          let urlMsg = '';
          if (files.length === 0 && !publicUrl) msg = 'Choose a media file or enter a Public Media URL.';
          else if (files.some(f => !getFileKind(f))) msg = 'Use image files or MP4, MOV, or WebM video files.';
          if (publicUrl && !publicUrl.toLowerCase().startsWith('https://')) urlMsg = 'Public Media URL must use HTTPS.';
          input.setCustomValidity(msg);
          publicUrlInput.setCustomValidity(urlMsg);
          return !msg && !urlMsg;
        };

        const selectedVideos = () => Array.from(input.files || []).filter(file => getFileKind(file) === 'video');
        const videoKey = file => file ? [file.name, file.size, file.lastModified].join(':') : '';
        const wantsAnalysis = () => Boolean(
          (autoCaptionToggle && autoCaptionToggle.checked) ||
          (autoMusicToggle && autoMusicToggle.checked)
        );
        const analysisKey = file => [
          videoKey(file),
          `caption:${autoCaptionToggle && autoCaptionToggle.checked ? 1 : 0}`,
          `music:${autoMusicToggle && autoMusicToggle.checked ? 1 : 0}`
        ].join('|');
        const setAutoCaptionStatus = (message, tone = '') => {
          if (!autoCaptionStatus) return;
          autoCaptionStatus.textContent = message;
          autoCaptionStatus.dataset.tone = tone;
        };
        const setAutoMusicStatus = (message, tone = '') => {
          if (!autoMusicStatus) return;
          autoMusicStatus.textContent = message;
          autoMusicStatus.dataset.tone = tone;
        };
        const clearAutoMusicToken = () => {
          if (autoMusicTokenInput) autoMusicTokenInput.value = '';
        };
        const clearMusicStatusTimer = () => {
          if (musicStatusTimer) window.clearTimeout(musicStatusTimer);
          musicStatusTimer = null;
        };
        const setAnalyzing = (analyzing, token) => {
          if (token !== analysisToken) return;
          if (submitButton) submitButton.disabled = submitInitiallyDisabled || analyzing;
          if (autoCaptionToggle) autoCaptionToggle.disabled = autoCaptionInitiallyDisabled || analyzing;
          if (autoMusicToggle) autoMusicToggle.disabled = autoMusicInitiallyDisabled || analyzing;
        };

        const analyzeSelectedVideo = async () => {
          if (!wantsAnalysis()) return { ok: true, skipped: true };
          const videos = selectedVideos();
          const video = videos[0];
          if (!video) {
            if (autoCaptionToggle && autoCaptionToggle.checked) {
              setAutoCaptionStatus('Auto Caption runs on uploaded videos. Manual caption mode is still available.', '');
            }
            if (autoMusicToggle && autoMusicToggle.checked) {
              setAutoMusicStatus('Auto Music runs on uploaded videos. The original file will be used.', '');
            }
            return { ok: true, skipped: true };
          }

          const key = analysisKey(video);
          if (analyzedKey === key) return { ok: true, cached: true };
          if (pendingAnalysis && pendingAnalysis.key === key) return pendingAnalysis.promise;

          const token = ++analysisToken;
          analyzedKey = '';
          failedKey = '';
          setAnalyzing(true, token);
          if (autoCaptionToggle && autoCaptionToggle.checked) {
            setAutoCaptionStatus('Analyzing five frames and checking the audio track\u2026', 'working');
          }
          if (autoMusicToggle && autoMusicToggle.checked) {
            clearAutoMusicToken();
            setAutoMusicStatus('Selecting music\u2026', 'working');
            clearMusicStatusTimer();
            musicStatusTimer = window.setTimeout(() => {
              if (token === analysisToken) setAutoMusicStatus('Mixing background music\u2026', 'working');
            }, 800);
          }

          const promise = (async () => {
            try {
              const body = new FormData();
              body.append('video', video, video.name);
              body.append('caption', captionInput ? captionInput.value : '');
              body.append('hashtags', hashtagsInput ? hashtagsInput.value : '');
              body.append('autoMusic', autoMusicToggle && autoMusicToggle.checked ? '1' : '0');
              const response = await fetch('/api/auto-caption', {
                method: 'POST',
                headers: { Accept: 'application/json' },
                body
              });
              const payload = await response.json().catch(() => ({}));
              if (!response.ok || !payload.ok) {
                throw new Error(payload.reason || 'Auto Caption analysis failed.');
              }
              if (token !== analysisToken || !wantsAnalysis()) return { ok: false, stale: true };

              if (autoCaptionToggle && autoCaptionToggle.checked) {
                if (captionInput) {
                  captionInput.value = payload.caption || '';
                  captionInput.setCustomValidity('');
                }
                if (hashtagsInput) hashtagsInput.value = payload.hashtags || '';
                const audioNote = payload.analysis && payload.analysis.transcriptUsed
                  ? 'frames and transcript'
                  : 'video frames';
                const batchNote = videos.length > 1 ? ' The copy applies to every selected file.' : '';
                setAutoCaptionStatus(`Caption generated from ${audioNote}. Edit it before scheduling.${batchNote}`, 'success');
              }

              if (autoMusicToggle && autoMusicToggle.checked) {
                if (payload.music && payload.music.prepared && payload.music.token) {
                  if (autoMusicTokenInput) autoMusicTokenInput.value = payload.music.token;
                  const batchNote = videos.length > 1 ? ' Music applies to the first selected video.' : '';
                  setAutoMusicStatus(`Final video ready.${batchNote}`, 'success');
                } else {
                  clearAutoMusicToken();
                  setAutoMusicStatus('Music mixing failed. The original video will be used.', 'error');
                }
              }

              analyzedKey = key;
              return { ok: true };
            } catch (error) {
              if (token !== analysisToken) return { ok: false, stale: true };
              failedKey = key;
              if (autoCaptionToggle && autoCaptionToggle.checked) {
                setAutoCaptionStatus(error.message || 'Auto Caption failed. Keep or write a manual caption.', 'error');
              }
              if (autoMusicToggle && autoMusicToggle.checked) {
                clearAutoMusicToken();
                setAutoMusicStatus('Music mixing failed. The original video will be used.', 'error');
              }
              return { ok: false, error };
            } finally {
              if (token === analysisToken) {
                clearMusicStatusTimer();
                pendingAnalysis = null;
                setAnalyzing(false, token);
              }
            }
          })();

          pendingAnalysis = { key, promise };
          return promise;
        };

        input.addEventListener('change', () => {
          validate();
          analysisToken += 1;
          analyzedKey = '';
          failedKey = '';
          pendingAnalysis = null;
          clearMusicStatusTimer();
          clearAutoMusicToken();
          setAnalyzing(false, analysisToken);
          if (wantsAnalysis()) analyzeSelectedVideo();
        });
        publicUrlInput.addEventListener('input', validate);
        if (captionInput) {
          captionInput.addEventListener('input', () => captionInput.setCustomValidity(''));
        }
        if (autoCaptionToggle) {
          autoCaptionToggle.addEventListener('change', () => {
            analysisToken += 1;
            pendingAnalysis = null;
            if (autoCaptionToggle.checked) {
              analyzedKey = '';
              failedKey = '';
              analyzeSelectedVideo();
            } else {
              setAnalyzing(false, analysisToken);
              setAutoCaptionStatus('Auto Caption is off. Your current caption will be used unchanged.', '');
              analyzedKey = '';
              failedKey = '';
              if (wantsAnalysis()) analyzeSelectedVideo();
            }
          });
        }
        if (autoMusicToggle) {
          autoMusicToggle.addEventListener('change', () => {
            analysisToken += 1;
            pendingAnalysis = null;
            clearMusicStatusTimer();
            clearAutoMusicToken();
            analyzedKey = '';
            failedKey = '';
            if (autoMusicToggle.checked) {
              analyzeSelectedVideo();
            } else {
              setAnalyzing(false, analysisToken);
              setAutoMusicStatus('Auto Music is off. The original uploaded video will be used.', '');
              if (wantsAnalysis()) analyzeSelectedVideo();
            }
          });
        }

        form.addEventListener('submit', async e => {
          if (!validate()) {
            e.preventDefault();
            if (input.validationMessage) input.reportValidity();
            else publicUrlInput.reportValidity();
            return;
          }

          if (!wantsAnalysis()) return;
          const video = selectedVideos()[0];
          if (!video) return;
          const key = analysisKey(video);
          if (analyzedKey === key) return;

          if (failedKey === key) {
            if (!autoCaptionToggle || !autoCaptionToggle.checked || (captionInput && captionInput.value.trim())) return;
            e.preventDefault();
            if (captionInput) {
              captionInput.setCustomValidity('Auto Caption failed. Write a caption before scheduling.');
              captionInput.reportValidity();
              captionInput.focus();
            }
            return;
          }

          e.preventDefault();
          const result = await analyzeSelectedVideo();
          if (result.ok || !autoCaptionToggle || !autoCaptionToggle.checked || (captionInput && captionInput.value.trim())) {
            form.requestSubmit(submitButton || undefined);
          } else if (captionInput) {
            captionInput.setCustomValidity('Auto Caption failed. Write a caption before scheduling.');
            captionInput.reportValidity();
            captionInput.focus();
          }
        });
      });

      // Copy-to-clipboard with inline button feedback; prompt() fallback keeps
      // the text reachable when the Clipboard API is unavailable.
      async function copyTextWithFeedback(button, text) {
        const original = button.dataset.originalLabel || button.textContent;
        button.dataset.originalLabel = original;
        try {
          await navigator.clipboard.writeText(text);
          button.textContent = 'Copied ✓';
          setTimeout(() => { button.textContent = original; }, 1600);
        } catch (error) {
          window.prompt('Copy the evidence text below:', text);
          button.textContent = original;
        }
      }

      // Campaign evidence copy buttons (campaign history)
      document.querySelectorAll('[data-campaign-copy-evidence]').forEach(button => {
        button.addEventListener('click', () => {
          const details = button.closest('details');
          const evidence = details ? details.querySelector('[data-campaign-evidence]') : null;
          if (evidence) copyTextWithFeedback(button, evidence.textContent);
        });
      });

      // Campaign Mode preview and client-side safety checks
      document.querySelectorAll('[data-campaign-form]').forEach(form => {
        const videoInput = form.querySelector('[data-campaign-video]');
        const baseTimeInput = form.querySelector('[data-campaign-base-time]');
        const slots = Array.from(form.querySelectorAll('[data-campaign-slot]'));
        const preview = document.querySelector('[data-campaign-preview]');
        const verdict = document.querySelector('[data-campaign-verdict]');
        const copyVerdictButton = document.querySelector('[data-campaign-copy-verdict]');
        if (!videoInput || !baseTimeInput || slots.length !== 2 || !preview) return;

        const toLocalInput = date => {
          const local = new Date(date.getTime() - date.getTimezoneOffset() * 60000);
          return local.toISOString().slice(0, 16);
        };
        const minTime = new Date(Date.now() + 60000);
        minTime.setSeconds(0, 0);
        baseTimeInput.min = toLocalInput(minTime);
        if (!baseTimeInput.value) {
          const defaultTime = new Date(Date.now() + 10 * 60000);
          defaultTime.setSeconds(0, 0);
          baseTimeInput.value = toLocalInput(defaultTime);
        }

        const normalize = value => String(value || '').trim().replace(/\s+/g, ' ').toLocaleLowerCase();
        const controls = slots.map(slot => ({
          account: slot.querySelector('[data-campaign-account]'),
          caption: slot.querySelector('[data-campaign-caption]'),
          hashtags: slot.querySelector('[data-campaign-hashtags]')
        }));

        const validate = () => {
          const selected = controls.filter(control => control.account.value);
          controls.forEach(control => {
            const active = Boolean(control.account.value);
            control.caption.required = active;
            control.hashtags.required = active;
            control.account.setCustomValidity('');
            control.caption.setCustomValidity('');
            control.hashtags.setCustomValidity('');
          });

          const file = videoInput.files && videoInput.files[0];
          const validVideo = file && getFileKind(file) === 'video' && /\.(mp4|mov|webm)$/i.test(file.name);
          videoInput.setCustomValidity(file && !validVideo ? 'Use one MP4, MOV, or WebM video.' : '');
          if (selected.length === 2) {
            if (selected[0].account.value === selected[1].account.value) {
              selected[1].account.setCustomValidity('Select a different TikTok account.');
            }
            if (normalize(selected[0].caption.value) && normalize(selected[0].caption.value) === normalize(selected[1].caption.value)) {
              selected[1].caption.setCustomValidity('Use a different caption for each account.');
            }
            if (normalize(selected[0].hashtags.value) && normalize(selected[0].hashtags.value) === normalize(selected[1].hashtags.value)) {
              selected[1].hashtags.setCustomValidity('Use a different hashtag set for each account.');
            }
          }
          return form.checkValidity();
        };

        const renderPreview = () => {
          preview.replaceChildren();
          const baseTime = new Date(baseTimeInput.value);
          const selected = controls.filter(control => control.account.value);
          if (selected.length === 0 || Number.isNaN(baseTime.getTime())) {
            const empty = document.createElement('p');
            empty.className = 'campaign-preview-note';
            empty.textContent = 'Select an account and base time to preview the jobs.';
            preview.append(empty);
            return;
          }

          selected.forEach((control, index) => {
            const scheduledAt = new Date(baseTime.getTime() + index * 15 * 60000);
            const card = document.createElement('div');
            card.className = 'campaign-preview-card';
            const account = document.createElement('strong');
            account.textContent = control.account.options[control.account.selectedIndex].textContent;
            const time = document.createElement('span');
            time.textContent = scheduledAt.toLocaleString();
            const copy = document.createElement('p');
            copy.className = 'campaign-preview-note';
            copy.textContent = [control.caption.value.trim(), control.hashtags.value.trim()].filter(Boolean).join(' / ') || 'Add account-specific copy.';
            card.append(account, time, copy);
            preview.append(card);
          });
        };

        // Server dry-run: asks /api/campaigns/preview (read-only, nothing is
        // written or uploaded) whether the draft is safe to enqueue and shows
        // the verdict plus any account/schedule issues found against live state.
        let serverPreviewTimer = null;
        let serverPreviewSequence = 0;
        let verdictEvidenceText = '';

        const buildVerdictEvidenceText = result => {
          const lines = [`CAMPAIGN DRY-RUN VERDICT: ${result.safeToEnqueue ? 'SAFE TO ENQUEUE' : 'BLOCKED'}`];
          if (result.campaign) {
            lines.push(`base time: ${result.campaign.baseScheduledAt} / stagger: ${result.campaign.staggerMinutes}m`);
            lines.push(`accounts: ${(result.campaign.selectedAccountIds || []).join(', ')}`);
          }
          (Array.isArray(result.childJobs) ? result.childJobs : []).forEach((job, index) => {
            lines.push(`[${index + 1}] ${job.accountLabel || job.accountId} (${job.accountId}) — ${job.scheduledAt}${job.scheduleCollision ? ' — SCHEDULE COLLISION' : ''}`);
            const copy = [job.caption, job.hashtags].filter(Boolean).join(' / ');
            if (copy) lines.push(`    copy: ${copy}`);
          });
          (Array.isArray(result.errors) ? result.errors : []).forEach(issue => lines.push(`error: ${issue.message}`));
          (Array.isArray(result.warnings) ? result.warnings : [])
            .filter(warning => warning.code !== 'CAMPAIGN_MEDIA_VALIDATED_AT_CREATE')
            .forEach(warning => lines.push(`warning: ${warning.message}`));
          lines.push('read-only dry run - nothing was created; creating the campaign revalidates everything');
          return lines.join('\n');
        };

        const renderServerVerdict = result => {
          verdict.replaceChildren();
          verdict.className = `campaign-preview-verdict ${result.safeToEnqueue ? 'is-safe' : 'is-blocked'}`;
          const headline = document.createElement('strong');
          headline.textContent = result.safeToEnqueue
            ? 'Safe to enqueue — dry-run checks passed.'
            : 'Blocked — resolve these before creating the campaign.';
          verdict.append(headline);
          const readiness = result.readiness || null;
          if (readiness) {
            const facts = document.createElement('ul');
            [
              `Accounts selected: ${readiness.selectedAccountCount} of ${readiness.maxAccounts}`,
              readiness.accountSelectionMissing ? 'Blocked: no TikTok account selected.' : '',
              readiness.duplicateAccountSelection ? 'Blocked: the same account is selected twice.' : '',
              readiness.accountIssues && readiness.accountIssues.length ? `Account issues: ${readiness.accountIssues.join(', ')}` : '',
              readiness.scheduleCollisions && readiness.scheduleCollisions.length ? `Schedule collisions: ${readiness.scheduleCollisions.join(', ')}` : ''
            ].filter(Boolean).forEach(text => {
              const item = document.createElement('li');
              item.textContent = text;
              facts.append(item);
            });
            verdict.append(facts);
          }
          const messages = [...new Set([
            ...(Array.isArray(result.errors) ? result.errors : []).map(issue => issue.message),
            ...(Array.isArray(result.warnings) ? result.warnings : [])
              .filter(warning => warning.code !== 'CAMPAIGN_MEDIA_VALIDATED_AT_CREATE')
              .map(warning => `Warning: ${warning.message}`)
          ].filter(Boolean))];
          if (messages.length > 0) {
            const list = document.createElement('ul');
            messages.forEach(message => {
              const item = document.createElement('li');
              item.textContent = message;
              list.append(item);
            });
            verdict.append(list);
          }
          verdictEvidenceText = buildVerdictEvidenceText(result);
          if (copyVerdictButton) copyVerdictButton.hidden = false;
        };

        const runServerPreview = async () => {
          if (!verdict) return;
          const selected = controls.filter(control => control.account.value);
          const baseTime = new Date(baseTimeInput.value);
          if (selected.length === 0 || Number.isNaN(baseTime.getTime())) {
            verdict.hidden = true;
            if (copyVerdictButton) copyVerdictButton.hidden = true;
            return;
          }

          const sequence = ++serverPreviewSequence;
          verdict.hidden = false;
          if (copyVerdictButton) copyVerdictButton.hidden = true;
          verdict.className = 'campaign-preview-verdict';
          verdict.textContent = 'Running dry-run checks…';
          const body = {
            campaignBaseScheduledAt: baseTimeInput.value,
            timezoneOffsetMinutes: String(new Date().getTimezoneOffset())
          };
          controls.forEach((control, index) => {
            body[`campaignAccountId${index + 1}`] = control.account.value;
            body[`campaignCaption${index + 1}`] = control.caption.value;
            body[`campaignHashtags${index + 1}`] = control.hashtags.value;
          });

          try {
            const response = await fetch('/api/campaigns/preview', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
              body: JSON.stringify(body)
            });
            if (!response.ok) throw new Error(`Preview returned HTTP ${response.status}`);
            const result = await response.json();
            if (sequence !== serverPreviewSequence) return;
            renderServerVerdict(result);
          } catch (error) {
            if (sequence !== serverPreviewSequence) return;
            verdict.className = 'campaign-preview-verdict is-blocked';
            verdict.textContent = 'Dry-run check unavailable right now. The create step still validates everything before upload.';
          }
        };

        const requestServerPreview = () => {
          clearTimeout(serverPreviewTimer);
          serverPreviewTimer = setTimeout(runServerPreview, 500);
        };

        if (copyVerdictButton) {
          copyVerdictButton.addEventListener('click', () => {
            if (verdictEvidenceText) copyTextWithFeedback(copyVerdictButton, verdictEvidenceText);
          });
        }

        [videoInput, baseTimeInput, ...controls.flatMap(control => Object.values(control))].forEach(control => {
          control.addEventListener('input', () => { validate(); renderPreview(); requestServerPreview(); });
          control.addEventListener('change', () => { validate(); renderPreview(); requestServerPreview(); });
        });
        form.addEventListener('submit', event => {
          if (validate()) return;
          event.preventDefault();
          form.querySelector(':invalid')?.reportValidity();
        });
        renderPreview();
        runServerPreview();
      });

      // Edit form: public media URL validation
      document.querySelectorAll('[data-edit-form]').forEach(form => {
        const input = form.querySelector('[data-public-media-url]');
        if (!input) return;
        const validate = () => {
          const mediaType = form.dataset.mediaType;
          const hasLocal = form.dataset.hasLocalMedia === 'true';
          const hasUrl = input.value.trim().length > 0;
          const missing = mediaType === 'photo' && !hasLocal && !hasUrl;
          input.setCustomValidity(missing ? 'Add a Public Media URL for photo posts.' : '');
          return !missing;
        };
        input.addEventListener('input', validate);
        form.addEventListener('submit', e => { if (!validate()) { e.preventDefault(); input.reportValidity(); } });
      });

      // Publish form: optimistic badge
      document.querySelectorAll('[data-publish-form]').forEach(form => {
        form.addEventListener('submit', () => {
          const card = form.closest('[data-post-card]');
          const badge = card ? card.querySelector('[data-result-badge]') : null;
          const btn = form.querySelector('button');
          if (btn) { btn.disabled = true; btn.textContent = 'Publishing…'; }
          if (badge) { badge.className = 'badge publishing'; badge.textContent = 'Publishing'; }
        });
      });

      <% if (enableInstagram) { %>
        // Instagram test form
        document.querySelectorAll('[data-instagram-publish-form]').forEach(form => {
          form.addEventListener('submit', () => {
            const btn = form.querySelector('button');
            if (btn) { btn.disabled = true; btn.textContent = 'Testing…'; }
          });
        });
      <% } %>

      // Missing media thumbnails
      document.querySelectorAll('[data-preview-media]').forEach(media => {
        const mark = () => { const t = media.closest('.queue-thumb'); if (t) t.classList.add('is-missing'); };
        media.addEventListener('error', mark);
        if (media.tagName === 'IMG' && media.complete && media.naturalWidth === 0) mark();
      });

      // Content Disclosure toggle shows/hides body
      document.querySelectorAll('[data-disclosure-toggle]').forEach(toggle => {
        const section = toggle.closest('[data-disclosure-section]');
        if (!section) return;
        const body = section.querySelector('[data-disclosure-body]');
        if (!body) return;
        toggle.addEventListener('change', () => {
          body.style.display = toggle.checked ? '' : 'none';
        });
      });
    </script>
  </body>
</html>
