<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <title>Select YouTube Channel | <%= appName %></title>
    <style>
      :root { color-scheme: dark; font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; }
      * { box-sizing: border-box; }
      body { display: grid; min-width: 320px; min-height: 100vh; margin: 0; place-items: center; background: radial-gradient(ellipse 60% 42% at 50% -10%, rgba(255,255,255,.04), transparent 70%), #09090b; color: #f5f5f4; }
      .shell { width: min(100% - 32px, 480px); }
      .card { border: 1px solid rgba(255,255,255,.08); border-radius: 18px; background: linear-gradient(145deg,rgba(25,25,29,.96),rgba(14,14,17,.94)); box-shadow: 0 28px 90px rgba(0,0,0,.5); padding: 30px; }
      .eyebrow { margin: 0 0 7px; color: #71717a; font-size: 9px; font-weight: 800; letter-spacing: .15em; text-transform: uppercase; }
      h1 { margin: 0; font-size: 24px; letter-spacing: -.035em; }
      .intro { margin: 8px 0 20px; color: #a1a1aa; font-size: 13px; line-height: 1.55; }
      .channel { display: flex; align-items: center; gap: 12px; margin-bottom: 10px; border: 1px solid rgba(255,255,255,.1); border-radius: 12px; padding: 12px; cursor: pointer; }
      .channel:hover { border-color: rgba(255,255,255,.3); }
      .channel img { width: 40px; height: 40px; border-radius: 50%; background: #18181b; }
      .channel .placeholder { display: grid; width: 40px; height: 40px; place-items: center; border-radius: 50%; background: #18181b; color: #71717a; font-weight: 800; }
      .channel-copy { display: grid; gap: 2px; }
      .channel-copy strong { font-size: 14px; }
      .channel-copy small { color: #71717a; font-size: 11px; }
      button { width: 100%; min-height: 46px; margin-top: 14px; border: 0; border-radius: 11px; background: #f5f5f4; color: #0a0a0b; font: 750 13px inherit; cursor: pointer; }
      button:hover { background: #ffffff; }
      .security-note { margin: 18px 0 0; color: #71717a; font-size: 10px; line-height: 1.5; text-align: center; }
      a.cancel { display: block; margin-top: 12px; color: #71717a; font-size: 12px; text-align: center; }
    </style>
  </head>
  <body>
    <main class="shell">
      <section class="card">
        <p class="eyebrow">YouTube</p>
        <h1>Select a channel</h1>
        <p class="intro">Your Google account has more than one YouTube channel. Choose the one to connect to AutoPoster. Only the channels Google returned in this sign-in are listed.</p>
        <form action="/connect/youtube/select" method="post">
          <input type="hidden" name="selectionId" value="<%= selectionId %>" />
          <% channels.forEach(function(channel, index) { %>
            <label class="channel">
              <input type="radio" name="channelId" value="<%= channel.channelId %>" <%= index === 0 ? 'checked' : '' %> required />
              <% if (channel.thumbnailUrl) { %>
                <img src="<%= channel.thumbnailUrl %>" alt="" referrerpolicy="no-referrer" />
              <% } else { %>
                <span class="placeholder">YT</span>
              <% } %>
              <span class="channel-copy">
                <strong><%= channel.title || channel.handle || channel.channelId %></strong>
                <small><%= channel.handle || channel.channelId %></small>
              </span>
            </label>
          <% }); %>
          <button type="submit">Connect selected channel</button>
        </form>
        <a class="cancel" href="/private/autoposter">Cancel — connect nothing</a>
        <p class="security-note">This choice expires after 10 minutes and can be used once. Credentials stay encrypted on the server; nothing is stored for channels you don't select.</p>
      </section>
    </main>
  </body>
</html>
