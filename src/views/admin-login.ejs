<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <title>Admin Login | <%= appName %></title>
    <style>
      :root { color-scheme: dark; font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; }
      * { box-sizing: border-box; }
      body { display: grid; min-width: 320px; min-height: 100vh; margin: 0; place-items: center; background: radial-gradient(circle at 16% 0%,rgba(254,44,85,.15),transparent 34%),radial-gradient(circle at 88% 100%,rgba(37,244,238,.07),transparent 38%),#08090e; color: #f7f7fa; }
      .login-shell { width: min(100% - 32px,430px); }
      .brand { display: flex; align-items: center; justify-content: center; gap: 11px; margin-bottom: 22px; }
      .brand-mark { display: grid; width: 42px; height: 42px; place-items: center; border-radius: 13px; background: linear-gradient(145deg,#ff4568,#d91d48); box-shadow: 0 10px 28px rgba(254,44,85,.28); font-weight: 900; }
      .brand-copy { display: grid; line-height: 1.1; }
      .brand-copy strong { font-size: 14px; letter-spacing: .09em; }
      .brand-copy span { margin-top: 4px; color: #797f91; font-size: 9px; font-weight: 700; letter-spacing: .13em; text-transform: uppercase; }
      .login-card { border: 1px solid rgba(255,255,255,.1); border-radius: 20px; background: linear-gradient(145deg,rgba(24,27,39,.96),rgba(13,15,23,.94)); box-shadow: 0 28px 90px rgba(0,0,0,.42); padding: 30px; }
      .eyebrow { margin: 0 0 7px; color: #25f4ee; font-size: 9px; font-weight: 800; letter-spacing: .15em; text-transform: uppercase; }
      h1 { margin: 0; font-size: 27px; letter-spacing: -.035em; }
      .intro { margin: 8px 0 24px; color: #979cad; font-size: 13px; line-height: 1.55; }
      .message { margin-bottom: 16px; border: 1px solid rgba(255,255,255,.1); border-radius: 10px; padding: 10px 12px; color: #c4c7d1; font-size: 12px; }
      .message.error { border-color: rgba(248,113,113,.3); background: rgba(239,68,68,.09); color: #fca5a5; }
      label { display: grid; gap: 7px; color: #858a9b; font-size: 10px; font-weight: 800; letter-spacing: .08em; text-transform: uppercase; }
      input { width: 100%; min-height: 46px; border: 1px solid rgba(255,255,255,.1); border-radius: 11px; outline: none; background: rgba(0,0,0,.28); color: #fff; padding: 11px 13px; font: inherit; }
      input:focus { border-color: rgba(254,44,85,.8); box-shadow: 0 0 0 3px rgba(254,44,85,.14); }
      button { width: 100%; min-height: 46px; margin-top: 18px; border: 0; border-radius: 11px; background: #fe2c55; box-shadow: 0 8px 22px rgba(254,44,85,.2); color: #fff; font: 750 13px inherit; cursor: pointer; }
      button:hover { filter: brightness(1.08); }
      .security-note { margin: 18px 0 0; color: #656b7c; font-size: 10px; line-height: 1.5; text-align: center; }
    </style>
  </head>
  <body>
    <main class="login-shell">
      <div class="brand"><span class="brand-mark">C</span><span class="brand-copy"><strong>CHANTER</strong><span>Auto Poster</span></span></div>
      <section class="login-card">
        <p class="eyebrow">Restricted access</p>
        <h1>Admin login</h1>
        <p class="intro">Enter the server-side admin password to access publishing operations.</p>
        <% if (notice) { %><div class="message"><%= notice %></div><% } %>
        <% if (error) { %><div class="message error" role="alert"><%= error %></div><% } %>
        <form action="/admin-login" method="post">
          <input type="hidden" name="returnTo" value="<%= returnTo %>" />
          <label>Admin password<input type="password" name="password" autocomplete="current-password" autofocus required /></label>
          <button type="submit">Unlock AutoPoster</button>
        </form>
        <p class="security-note">The session is stored in an expiring signed, HTTP-only cookie.</p>
      </section>
    </main>
  </body>
</html>
